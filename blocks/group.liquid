{% doc %}
  Renders a group of blocks with configurable layout direction, gap and
  alignment.

  Designed as a layout primitive — use Column for vertical stacks
  (heading + body + button) and Row for inline groups (button row,
  trust icons, social links).

  @example
  {% content_for 'block', type: 'group', id: 'group' %}
{% enddoc %}

{%- liquid
  assign direction = block.settings.layout_direction | default: 'group--vertical'
  assign gap = block.settings.gap | default: 12
  assign padding = block.settings.padding | default: 0
  assign alignment = block.settings.alignment | default: 'flex-start'
  assign distribution = block.settings.distribution | default: 'flex-start'
-%}

<div
  class="group {{ direction }}"
  style="
    --group-gap: {{ gap }}px;
    --group-padding: {{ padding }}px;
    --group-alignment: {{ alignment }};
    --group-distribution: {{ distribution }};
  "
  {{ block.shopify_attributes }}
>
  {% content_for 'blocks' %}
  {%- comment -%}
    Render a placeholder slot. CSS hides it as soon as the group has at
    least one .shopify-block child via :has(), so it only shows in the
    theme editor or when a merchant intentionally clears the group.
  {%- endcomment -%}
  <span class="group__placeholder" aria-hidden="true">
    {{ 'blocks.group.placeholder' | t }}
  </span>
</div>

{% stylesheet %}
  .group {
    display: flex;
    flex-wrap: wrap;
    width: 100%;
    gap: var(--group-gap, 12px);
    /* Keep the wrapper measurable even when empty so the customizer can
       show its drop-target overlay and the merchant can drag blocks in. */
    min-height: 1px;
  }

  /* Editor-only placeholder shown when the group has no child blocks yet.
     The pseudo `:has()` check hides it as soon as a real block lands. */
  .group__placeholder {
    display: none;
    flex: 1;
    padding: 16px 20px;
    border: 1px dashed rgba(0, 0, 0, 0.25);
    border-radius: 4px;
    font-family: var(--font-label-family, sans-serif);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(0, 0, 0, 0.55);
    text-align: center;
  }

  .group:not(:has(> .shopify-block)) .group__placeholder {
    display: block;
  }

  .group--horizontal {
    flex-direction: row;
    align-items: var(--group-alignment, center);
    justify-content: var(--group-distribution, flex-start);
    padding: 0 var(--group-padding, 0);
  }

  .group--vertical {
    flex-direction: column;
    align-items: var(--group-alignment, flex-start);
    padding: var(--group-padding, 0) 0;
  }

  /* Each child theme block sits inside a .shopify-block wrapper. In a
     vertical group we want each child to take a full row; in a horizontal
     group children size to their content. */
  .group--vertical > .shopify-block {
    width: 100%;
  }

  .group--horizontal > .shopify-block {
    flex: 0 0 auto;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.group",
  "blocks": [{ "type": "@theme" }],
  "settings": [
    {
      "type": "select",
      "id": "layout_direction",
      "label": "t:labels.layout_direction",
      "default": "group--vertical",
      "options": [
        { "value": "group--horizontal", "label": "t:options.direction.horizontal" },
        { "value": "group--vertical", "label": "t:options.direction.vertical" }
      ]
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:labels.gap",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "t:labels.alignment",
      "info": "t:labels.alignment_info",
      "default": "flex-start",
      "options": [
        { "value": "flex-start", "label": "t:options.alignment.start" },
        { "value": "center", "label": "t:options.alignment.center" },
        { "value": "flex-end", "label": "t:options.alignment.end" },
        { "value": "stretch", "label": "t:options.alignment.stretch" }
      ]
    },
    {
      "visible_if": "{{ block.settings.layout_direction == 'group--horizontal' }}",
      "type": "select",
      "id": "distribution",
      "label": "t:labels.distribution",
      "info": "t:labels.distribution_info",
      "default": "flex-start",
      "options": [
        { "value": "flex-start",    "label": "t:options.distribution.start" },
        { "value": "center",        "label": "t:options.distribution.center" },
        { "value": "flex-end",      "label": "t:options.distribution.end" },
        { "value": "space-between", "label": "t:options.distribution.between" },
        { "value": "space-around",  "label": "t:options.distribution.around" },
        { "value": "space-evenly",  "label": "t:options.distribution.evenly" }
      ]
    },
    {
      "type": "range",
      "id": "padding",
      "label": "t:labels.padding",
      "default": 0,
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "t:general.column",
      "category": "t:general.layout",
      "settings": {
        "layout_direction": "group--vertical",
        "alignment": "flex-start",
        "gap": 12,
        "padding": 0
      },
      "blocks": [
        { "type": "heading", "settings": { "text": "Column heading", "tag": "h3", "size": "small" } },
        { "type": "description", "settings": { "text": "<p>Add a short description so merchants see how a column lays out.</p>" } }
      ]
    },
    {
      "name": "t:general.row",
      "category": "t:general.layout",
      "settings": {
        "layout_direction": "group--horizontal",
        "alignment": "center",
        "distribution": "flex-start",
        "gap": 12,
        "padding": 0
      },
      "blocks": [
        { "type": "button", "settings": { "label": "Action 1", "style": "primary" } },
        { "type": "button", "settings": { "label": "Action 2", "style": "outline" } }
      ]
    }
  ]
}
{% endschema %}
