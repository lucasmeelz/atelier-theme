{% doc %}
  Renders a single CTA button. Add multiple instances inside a content
  group to create a row of buttons.

  @example
  {% content_for 'block', type: 'button', id: 'button' %}
{% enddoc %}

{%- if block.settings.label != blank -%}
  <a
    href="{{ block.settings.link | default: '#' }}"
    class="btn btn--{{ block.settings.style }}"
    {{ block.shopify_attributes }}
  >
    <span class="btn__label">{{ block.settings.label }}</span>
    <span class="btn__fill" aria-hidden="true"></span>
  </a>
{%- endif -%}

{% schema %}
{
  "name": "t:blocks.button.name",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "t:blocks.button.label",
      "default": "Discover"
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:blocks.button.link"
    },
    {
      "type": "select",
      "id": "style",
      "label": "t:blocks.button.style",
      "info": "t:blocks.button.style_info",
      "options": [
        { "value": "primary",        "label": "t:blocks.button.style_primary" },
        { "value": "secondary",      "label": "t:blocks.button.style_secondary" },
        { "value": "outline",        "label": "t:blocks.button.style_outline" },
        { "value": "outline-black",  "label": "t:blocks.button.style_outline_black" },
        { "value": "outline-white",  "label": "t:blocks.button.style_outline_white" },
        { "value": "filled-black",   "label": "t:blocks.button.style_filled_black" },
        { "value": "filled-white",   "label": "t:blocks.button.style_filled_white" }
      ],
      "default": "primary"
    }
  ],
  "presets": [
    { "name": "t:blocks.button.name" }
  ]
}
{% endschema %}
