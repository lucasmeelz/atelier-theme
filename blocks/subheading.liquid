{% doc %}
  Renders an elegant bridging line between an eyebrow and a heading.
  Regular case (not uppercase), softer weight, optional italic.

  @example
  {% content_for 'block', type: 'subheading', id: 'subheading' %}
{% enddoc %}

{%- if block.settings.text != blank -%}
  <p
    class="block-subheading{% if block.settings.italic %} block-subheading--italic{% endif %}"
    {{ block.shopify_attributes }}
  >
    {{ block.settings.text }}
  </p>
{%- endif -%}

{% stylesheet %}
  /* Editorial bridging line between an eyebrow and a heading. Distinct
     class name from the global `.subheading` utility (which is label-style
     uppercase) to avoid collisions across sections that already use that
     utility for their kicker text. */
  .block-subheading {
    font-family: var(--font-body-family, sans-serif);
    font-size: clamp(0.9375rem, 1.4vw, 1.0625rem);
    font-weight: 400;
    line-height: 1.4;
    letter-spacing: 0.01em;
    margin: 0 0 1rem;
    opacity: 0.92;
    color: inherit;
  }

  .block-subheading--italic {
    font-style: italic;
    font-family: var(--font-heading-family, serif);
    font-size: clamp(1rem, 1.5vw, 1.125rem);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:blocks.subheading.name",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "t:blocks.subheading.text",
      "default": "Subheading"
    },
    {
      "type": "checkbox",
      "id": "italic",
      "label": "t:blocks.subheading.italic",
      "info": "t:blocks.subheading.italic_info",
      "default": false
    }
  ],
  "presets": [
    { "name": "t:blocks.subheading.name" }
  ]
}
{% endschema %}
