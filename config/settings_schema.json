[
  {
    "name": "theme_info",
    "theme_name": "Atelier",
    "theme_version": "1.0.0",
    "theme_author": "Meelz Agency",
    "theme_documentation_url": "https://meelz.agency",
    "theme_support_url": "https://meelz.agency"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color_scheme_group",
        "id": "color_schemes",
        "definition": [
          {
            "type": "color",
            "id": "background",
            "label": "Background",
            "default": "#FFFFFF"
          },
          {
            "type": "color",
            "id": "text",
            "label": "Text",
            "default": "#0A0A0A"
          },
          {
            "type": "color",
            "id": "text_subdued",
            "label": "Subdued text",
            "default": "#6B6B6B"
          },
          {
            "type": "color",
            "id": "accent",
            "label": "Accent",
            "default": "#B8946A"
          },
          {
            "type": "color",
            "id": "border",
            "label": "Border",
            "default": "#E2E0DB"
          },
          {
            "type": "color",
            "id": "button",
            "label": "Button background",
            "default": "#0A0A0A"
          },
          {
            "type": "color",
            "id": "button_text",
            "label": "Button text",
            "default": "#FFFFFF"
          },
          {
            "type": "color_background",
            "id": "background_gradient",
            "label": "Background gradient",
            "default": "none"
          }
        ],
        "role": {
          "text": "text",
          "background": {
            "solid": "background",
            "gradient": "background_gradient"
          },
          "links": "accent",
          "icons": "text",
          "primary_button": "button",
          "on_primary_button": "button_text",
          "primary_button_border": "button",
          "secondary_button": "background",
          "on_secondary_button": "text",
          "secondary_button_border": "border"
        }
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "type_heading_font",
        "default": "cormorant_n4",
        "label": "Heading font"
      },
      {
        "type": "font_picker",
        "id": "type_body_font",
        "default": "jost_n4",
        "label": "Body font"
      },
      {
        "type": "font_picker",
        "id": "type_subheading_font",
        "default": "jost_n4",
        "label": "Subheading font"
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "Page width",
        "options": [
          { "value": "1200px", "label": "Narrow (1200px)" },
          { "value": "1440px", "label": "Standard (1440px)" },
          { "value": "1600px", "label": "Wide (1600px)" }
        ],
        "default": "1440px"
      },
      {
        "type": "range",
        "id": "page_margin",
        "min": 10,
        "max": 100,
        "step": 2,
        "unit": "px",
        "label": "Page margin",
        "default": 20
      },
      {
        "type": "select",
        "id": "section_spacing",
        "label": "Section spacing",
        "options": [
          { "value": "compact", "label": "Compact" },
          { "value": "normal", "label": "Normal" },
          { "value": "loose", "label": "Loose" }
        ],
        "default": "normal"
      }
    ]
  },
  {
    "name": "Appearance",
    "settings": [
      {
        "type": "range",
        "id": "border_radius",
        "min": 0,
        "max": 24,
        "step": 1,
        "unit": "px",
        "label": "Border radius",
        "default": 0
      },
      {
        "type": "range",
        "id": "input_border_radius",
        "min": 0,
        "max": 12,
        "step": 1,
        "unit": "px",
        "label": "Input border radius",
        "default": 4
      },
      {
        "type": "range",
        "id": "backdrop_blur",
        "min": 0,
        "max": 20,
        "step": 1,
        "unit": "px",
        "label": "Backdrop blur",
        "default": 8
      }
    ]
  },
  {
    "name": "Animations",
    "settings": [
      {
        "type": "select",
        "id": "ease_type",
        "label": "Easing curve",
        "options": [
          { "value": "cubic-bezier(0.31, 0, 0.13, 1)", "label": "Atelier (Dior)" },
          { "value": "cubic-bezier(0.25, 0.1, 0.25, 1)", "label": "Ease" },
          { "value": "cubic-bezier(0.4, 0, 0.2, 1)", "label": "Material" }
        ],
        "default": "cubic-bezier(0.31, 0, 0.13, 1)"
      },
      {
        "type": "range",
        "id": "duration_fast",
        "min": 100,
        "max": 400,
        "step": 50,
        "unit": "ms",
        "label": "Fast duration",
        "default": 200
      },
      {
        "type": "range",
        "id": "duration_base",
        "min": 200,
        "max": 600,
        "step": 50,
        "unit": "ms",
        "label": "Base duration",
        "default": 350
      },
      {
        "type": "range",
        "id": "duration_slow",
        "min": 400,
        "max": 1000,
        "step": 50,
        "unit": "ms",
        "label": "Slow duration",
        "default": 600
      }
    ]
  }
]
