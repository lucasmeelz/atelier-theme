[
  {
    "name": "theme_info",
    "theme_name": "Atelier",
    "theme_version": "1.0.0",
    "theme_author": "Atelier",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:labels.heading_font"
      },
      {
        "type": "font_picker",
        "id": "type_heading_font",
        "default": "cormorant_n4",
        "label": "t:labels.heading_font"
      },
      {
        "type": "header",
        "content": "t:labels.body_font"
      },
      {
        "type": "font_picker",
        "id": "type_body_font",
        "default": "jost_n4",
        "label": "t:labels.body_font"
      }
    ]
  },
  {
    "name": "t:general.colors",
    "settings": [
      {
        "type": "color_scheme_group",
        "id": "color_schemes",
        "definition": [
          {
            "type": "header",
            "content": "t:labels.background"
          },
          {
            "type": "color",
            "id": "background",
            "label": "t:labels.background",
            "default": "#FFFFFF"
          },
          {
            "type": "color_background",
            "id": "background_gradient",
            "label": "t:labels.background_gradient",
            "info": "t:labels.background_gradient_info"
          },
          {
            "type": "header",
            "content": "t:labels.text_colors"
          },
          {
            "type": "color",
            "id": "text",
            "label": "t:labels.text",
            "default": "#0A0A0A"
          },
          {
            "type": "color",
            "id": "text_subdued",
            "label": "t:labels.text_subdued",
            "default": "#6B6B6B"
          },
          {
            "type": "header",
            "content": "t:labels.buttons"
          },
          {
            "type": "color",
            "id": "button_bg",
            "label": "t:labels.button_bg",
            "default": "#0A0A0A"
          },
          {
            "type": "color",
            "id": "button_text",
            "label": "t:labels.button_text",
            "default": "#FFFFFF"
          },
          {
            "type": "color",
            "id": "button_outline_text",
            "label": "t:labels.button_outline_text",
            "default": "#0A0A0A"
          },
          {
            "type": "header",
            "content": "t:labels.other_colors"
          },
          {
            "type": "color",
            "id": "accent",
            "label": "t:labels.accent_color",
            "default": "#B8946A"
          },
          {
            "type": "color",
            "id": "border",
            "label": "t:labels.border_color",
            "default": "#E2E0DB"
          },
          {
            "type": "color",
            "id": "link",
            "label": "t:labels.link_color",
            "default": "#0A0A0A"
          }
        ],
        "role": {
          "text": "text",
          "background": {
            "solid": "background",
            "gradient": "background_gradient"
          },
          "links": "link",
          "icons": "text",
          "primary_button": "button_bg",
          "on_primary_button": "button_text",
          "primary_button_border": "button_bg",
          "secondary_button": "background",
          "on_secondary_button": "button_outline_text",
          "secondary_button_border": "button_outline_text"
        }
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "range",
        "id": "max_page_width",
        "min": 1000,
        "max": 1600,
        "step": 40,
        "unit": "px",
        "label": "t:labels.page_width",
        "default": 1440
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 2,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 20
      },
      {
        "type": "range",
        "id": "section_padding_mobile",
        "min": 20,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "t:labels.section_padding_mobile",
        "default": 60
      },
      {
        "type": "range",
        "id": "section_padding_desktop",
        "min": 40,
        "max": 200,
        "step": 8,
        "unit": "px",
        "label": "t:labels.section_padding_desktop",
        "default": 120
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "t:labels.input_corner_radius",
        "default": 0
      }
    ]
  },
  {
    "name": "t:general.cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "t:labels.cart_type",
        "options": [
          {
            "value": "drawer",
            "label": "t:options.cart_type.drawer"
          },
          {
            "value": "page",
            "label": "t:options.cart_type.page"
          }
        ],
        "default": "drawer"
      }
    ]
  },
  {
    "name": "t:general.animations",
    "settings": [
      {
        "type": "select",
        "id": "page_transition",
        "label": "t:labels.page_transition",
        "info": "t:labels.page_transition_info",
        "options": [
          {
            "value": "none",
            "label": "t:options.page_transition.none"
          },
          {
            "value": "fade",
            "label": "t:options.page_transition.fade"
          },
          {
            "value": "slide-up",
            "label": "t:options.page_transition.slide_up"
          }
        ],
        "default": "fade"
      },
      {
        "type": "select",
        "id": "scroll_animations",
        "label": "t:labels.scroll_animations",
        "options": [
          {
            "value": "none",
            "label": "t:options.scroll_animations.none"
          },
          {
            "value": "fade-up",
            "label": "t:options.scroll_animations.fade_up"
          },
          {
            "value": "fade-in",
            "label": "t:options.scroll_animations.fade_in"
          }
        ],
        "default": "fade-up"
      },
      {
        "type": "range",
        "id": "animation_threshold",
        "min": 0,
        "max": 100,
        "step": 5,
        "label": "t:labels.animation_threshold",
        "info": "t:labels.animation_threshold_info",
        "default": 20
      }
    ]
  },
  {
    "name": "t:general.cursor",
    "settings": [
      {
        "type": "select",
        "id": "cursor_style",
        "label": "t:labels.cursor_style",
        "options": [
          {
            "value": "default",
            "label": "t:options.cursor_style.default"
          },
          {
            "value": "dot",
            "label": "t:options.cursor_style.dot"
          },
          {
            "value": "circle",
            "label": "t:options.cursor_style.circle"
          }
        ],
        "default": "default"
      },
      {
        "type": "color",
        "id": "cursor_color",
        "label": "t:labels.cursor_color",
        "default": "#0A0A0A"
      }
    ]
  },
  {
    "name": "t:general.product_cards",
    "settings": [
      {
        "type": "select",
        "id": "card_hover_effect",
        "label": "t:labels.card_hover_effect",
        "options": [
          {
            "value": "none",
            "label": "t:options.card_hover_effect.none"
          },
          {
            "value": "image-swap",
            "label": "t:options.card_hover_effect.image_swap"
          },
          {
            "value": "scale",
            "label": "t:options.card_hover_effect.scale"
          },
          {
            "value": "overlay",
            "label": "t:options.card_hover_effect.overlay"
          }
        ],
        "default": "image-swap"
      },
      {
        "type": "range",
        "id": "card_border_radius",
        "min": 0,
        "max": 16,
        "step": 1,
        "unit": "px",
        "label": "t:labels.card_border_radius",
        "default": 0
      },
      {
        "type": "select",
        "id": "quick_add_style",
        "label": "t:labels.quick_add_style",
        "options": [
          {
            "value": "none",
            "label": "t:options.quick_add_style.none"
          },
          {
            "value": "icon",
            "label": "t:options.quick_add_style.icon"
          },
          {
            "value": "button",
            "label": "t:options.quick_add_style.button"
          }
        ],
        "default": "icon"
      }
    ]
  },
  {
    "name": "t:general.social_media",
    "settings": [
      {
        "type": "header",
        "content": "t:labels.social_accounts"
      },
      {
        "type": "url",
        "id": "social_instagram_url",
        "label": "Instagram"
      },
      {
        "type": "url",
        "id": "social_facebook_url",
        "label": "Facebook"
      },
      {
        "type": "url",
        "id": "social_tiktok_url",
        "label": "TikTok"
      },
      {
        "type": "url",
        "id": "social_pinterest_url",
        "label": "Pinterest"
      },
      {
        "type": "url",
        "id": "social_youtube_url",
        "label": "YouTube"
      },
      {
        "type": "url",
        "id": "social_twitter_url",
        "label": "X (Twitter)"
      }
    ]
  },
  {
    "name": "t:general.favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "t:labels.favicon",
        "info": "t:labels.favicon_info"
      }
    ]
  }
]
