[
  {
    "name": "theme_info",
    "theme_name": "Atelier",
    "theme_version": "1.0.0",
    "theme_author": "Meelz Agency",
    "theme_documentation_url": "https://meelz.agency",
    "theme_support_url": "https://meelz.agency"
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "work_sans_n4",
        "label": "t:general.primary"
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          {
            "value": "90rem",
            "label": "t:options.page_width.narrow"
          },
          {
            "value": "110rem",
            "label": "t:options.page_width.wide"
          }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 20
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color_scheme_group",
        "id": "color_schemes",
        "definition": [
          {
            "type": "color",
            "id": "background",
            "label": "Background",
            "default": "#FFFFFF"
          },
          {
            "type": "color",
            "id": "text",
            "label": "Text",
            "default": "#0A0A0A"
          },
          {
            "type": "color",
            "id": "text_subdued",
            "label": "Subdued text",
            "default": "#6B6B6B"
          },
          {
            "type": "color",
            "id": "accent",
            "label": "Accent",
            "default": "#B8946A"
          },
          {
            "type": "color",
            "id": "border",
            "label": "Border",
            "default": "#E2E0DB"
          },
          {
            "type": "color",
            "id": "button",
            "label": "Button background",
            "default": "#0A0A0A"
          },
          {
            "type": "color",
            "id": "button_text",
            "label": "Button text",
            "default": "#FFFFFF"
          },
          {
            "type": "color_background",
            "id": "background_gradient",
            "label": "Background gradient",
            "default": "none"
          }
        ],
        "role": {
          "text": "text",
          "background": {
            "solid": "background",
            "gradient": "background_gradient"
          },
          "links": "accent",
          "icons": "text",
          "primary_button": "button",
          "on_primary_button": "button_text",
          "primary_button_border": "button",
          "secondary_button": "background",
          "on_secondary_button": "text",
          "secondary_button_border": "border"
        }
      }
    ]
  }
]
