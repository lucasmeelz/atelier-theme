{% doc %}
  @prompt
    Grand texte en gras rempli avec une image. Incluez un paramètre pour contrôler la couleur d'arrière-plan.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-text-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding }}px;
  }

  .ai-image-text-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-image-text-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    font-size: {{ block.settings.font_size }}px;
    line-height: 1.1;
    margin: 0;
    position: relative;
    display: inline-block;
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    background-size: cover;
    background-position: center;
    {% if block.settings.image %}
      background-image: url('{{ block.settings.image | image_url: width: 2000 }}');
    {% else %}
      background-image: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    {% endif %}
  }

  .ai-image-text-placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    padding: 40px;
    text-align: center;
    border-radius: 8px;
  }

  .ai-image-text-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: auto;
    max-width: 200px;
    margin-bottom: 16px;
  }

  .ai-image-text-empty-state-{{ ai_gen_id }} {
    font-size: 14px;
    color: #666;
    margin-top: 12px;
  }

  @media screen and (max-width: 749px) {
    .ai-image-text-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.font_size }}px * 0.6);
    }
  }
{% endstyle %}

<div class="ai-image-text-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-text-container-{{ ai_gen_id }}">
    {% if block.settings.text != blank %}
      <h2 class="ai-image-text-heading-{{ ai_gen_id }}">
        {{ block.settings.text }}
      </h2>
    {% else %}
      <div class="ai-image-text-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-image-text-empty-state-{{ ai_gen_id }}">
          Ajoutez votre texte et une image pour commencer
        </div>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Texte rempli d'image",
  "settings": [
    {
      "type": "header",
      "content": "Contenu"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Texte",
      "default": "TEXTE EN GRAS"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image de remplissage"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Police",
      "default": "cormorant_n4"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Taille de police",
      "min": 40,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 100
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Couleur d'arrière-plan",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Espacement intérieur",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Largeur sur ordinateur",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Texte rempli d'image"
    }
  ]
}
{% endschema %}
