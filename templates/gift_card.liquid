{% layout none %}

<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    {%- render 'css-variables' -%}
    {%- render 'meta-tags' -%}

    {{ content_for_header }}

    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: var(--font-body-family, sans-serif);
        font-size: var(--body-font-size-desktop, 15px);
        line-height: var(--body-line-height, 1.6);
        color: rgb(var(--color-text, 10, 10, 10));
        background-color: rgb(var(--color-background, 255, 255, 255));
        -webkit-font-smoothing: antialiased;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .gift-card {
        width: 100%;
        max-width: 520px;
        padding: 48px 24px;
        text-align: center;
      }

      .gift-card__shop-name {
        font-family: var(--font-heading-family, serif);
        font-weight: var(--font-heading-weight, 300);
        font-style: var(--font-heading-style, normal);
        font-size: clamp(1.5rem, 3vw, 2rem);
        line-height: var(--heading-line-height, 1.1);
        letter-spacing: var(--heading-letter-spacing, 0);
        margin-bottom: 40px;
      }

      .gift-card__image-wrap {
        position: relative;
        margin-bottom: 40px;
      }

      .gift-card__image {
        display: block;
        width: 100%;
        max-width: 400px;
        margin: 0 auto;
        border-radius: var(--card-border-radius, 0);
      }

      .gift-card__badge {
        display: inline-block;
        font-family: var(--font-body-family, sans-serif);
        font-size: 0.6875rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        padding: 6px 16px;
        border: 1px solid rgb(var(--color-border, 226, 224, 219));
        color: rgb(var(--color-text-subdued, 107, 107, 107));
        margin-bottom: 32px;
      }

      .gift-card__balance {
        font-family: var(--font-heading-family, serif);
        font-weight: var(--font-heading-weight, 300);
        font-style: var(--font-heading-style, normal);
        font-size: clamp(2.5rem, 6vw, 4rem);
        line-height: 1;
        letter-spacing: -0.02em;
        margin-bottom: 8px;
      }

      .gift-card__expiry {
        font-size: 0.8125rem;
        color: rgb(var(--color-text-subdued, 107, 107, 107));
        margin-bottom: 40px;
      }

      .gift-card__expired {
        color: rgb(var(--color-error, 194, 58, 58));
        font-weight: 500;
      }

      .gift-card__message {
        font-size: 0.8125rem;
        color: rgb(var(--color-text-subdued, 107, 107, 107));
        letter-spacing: 0.02em;
        margin-bottom: 16px;
      }

      .gift-card__code-wrap {
        position: relative;
        margin-bottom: 40px;
      }

      .gift-card__code {
        font-family: var(--font-body-family, sans-serif);
        font-size: clamp(1.125rem, 2.5vw, 1.375rem);
        font-weight: 500;
        letter-spacing: 0.15em;
        padding: 18px 24px;
        border: 1.5px dashed rgb(var(--color-border, 226, 224, 219));
        display: inline-block;
        min-width: 280px;
        user-select: all;
        -webkit-user-select: all;
        cursor: text;
      }

      .gift-card__copy {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        margin-top: 12px;
        font-family: var(--font-body-family, sans-serif);
        font-size: 0.6875rem;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 10px 24px;
        border: 1px solid rgb(var(--color-text, 10, 10, 10));
        background: none;
        color: rgb(var(--color-text, 10, 10, 10));
        cursor: pointer;
        transition: background-color 350ms cubic-bezier(0.31, 0, 0.13, 1),
                    color 350ms cubic-bezier(0.31, 0, 0.13, 1);
      }

      @media (hover: hover) {
        .gift-card__copy:hover {
          background-color: rgb(var(--color-text, 10, 10, 10));
          color: rgb(var(--color-background, 255, 255, 255));
        }
      }

      .gift-card__copy:focus-visible {
        outline: 2px solid rgb(var(--color-accent, 184, 148, 106));
        outline-offset: 2px;
      }

      .gift-card__copy svg {
        width: 14px;
        height: 14px;
      }

      .gift-card__apple-wallet {
        display: block;
        margin: 0 auto 32px;
      }

      .gift-card__apple-wallet img {
        display: block;
        height: 44px;
        width: auto;
        margin: 0 auto;
      }

      .gift-card__qr {
        margin: 0 auto 40px;
        display: flex;
        justify-content: center;
      }

      .gift-card__qr canvas,
      .gift-card__qr img {
        border-radius: var(--card-border-radius, 0);
      }

      .gift-card__back {
        font-family: var(--font-body-family, sans-serif);
        font-size: 0.75rem;
        font-weight: 500;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: rgb(var(--color-text, 10, 10, 10));
        text-decoration: none;
        border-bottom: 1px solid rgb(var(--color-text, 10, 10, 10));
        padding-bottom: 2px;
        transition: opacity 200ms cubic-bezier(0.31, 0, 0.13, 1);
      }

      @media (hover: hover) {
        .gift-card__back:hover {
          opacity: 0.6;
        }
      }

      .gift-card__back:focus-visible {
        outline: 2px solid rgb(var(--color-accent, 184, 148, 106));
        outline-offset: 4px;
      }

      @media screen and (max-width: 749px) {
        .gift-card {
          padding: 32px 20px;
        }

        .gift-card__code {
          min-width: auto;
          width: 100%;
        }
      }
    </style>
  </head>

  <body>
    <main>
      <div class="gift-card" role="main">

        <h1 class="gift-card__shop-name">{{ shop.name }}</h1>

        <div class="gift-card__image-wrap">
          {%- if settings.logo -%}
            {{ settings.logo | image_url: width: 400 | image_tag: alt: shop.name, class: 'gift-card__image', loading: 'eager' }}
          {%- else -%}
            <img
              src="{{ 'gift-card/card.svg' | shopify_asset_url }}"
              alt="{{ 'gift_card.card' | t }}"
              class="gift-card__image"
              width="400"
              height="260"
              loading="eager"
            >
          {%- endif -%}
        </div>

        {%- if gift_card.enabled == false or gift_card.expired -%}
          <p class="gift-card__badge gift-card__expired">{{ 'gift_card.expired' | t }}</p>
        {%- else -%}
          <p class="gift-card__badge">{{ 'gift_card.title' | t }}</p>
        {%- endif -%}

        <p class="gift-card__balance">{{ gift_card.balance | money }}</p>

        {%- if gift_card.expires_on -%}
          <p class="gift-card__expiry">
            {{ 'gift_card.expires_on' | t: date: gift_card.expires_on | date: '%B %e, %Y' }}
          </p>
        {%- endif -%}

        <p class="gift-card__message">{{ 'gift_card.use_at_checkout' | t }}</p>

        <div class="gift-card__code-wrap">
          <p class="gift-card__code" id="gift-card-code">{{ gift_card.code | format_code }}</p>
          <div>
            <button
              class="gift-card__copy"
              type="button"
              id="copy-code-btn"
              aria-label="{{ 'gift_card.copy_code' | t }}"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="9" y="9" width="13" height="13" rx="1" ry="1"></rect>
                <path d="M5 15H4a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h10a1 1 0 0 1 1 1v1"></path>
              </svg>
              <span id="copy-code-text">{{ 'gift_card.copy_code' | t }}</span>
            </button>
          </div>
        </div>

        {%- if gift_card.pass_url -%}
          <a href="{{ gift_card.pass_url }}" class="gift-card__apple-wallet">
            <img
              src="{{ 'gift-card/add-to-apple-wallet.svg' | shopify_asset_url }}"
              alt="{{ 'gift_card.add_to_apple_wallet' | t }}"
              width="200"
              height="44"
              loading="lazy"
            >
          </a>
        {%- endif -%}

        <div class="gift-card__qr" id="qr-code" data-identifier="{{ gift_card.qr_identifier }}"></div>

        <a href="{{ shop.url }}" class="gift-card__back">
          {{ 'gift_card.continue_shopping' | t }}
        </a>
      </div>
    </main>

    <script src="{{ 'qrcode.js' | shopify_asset_url }}" defer></script>
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        /* QR code */
        var qrEl = document.getElementById('qr-code');
        if (qrEl && typeof QRCode !== 'undefined') {
          new QRCode(qrEl, {
            text: qrEl.dataset.identifier,
            width: 140,
            height: 140
          });
        }

        /* Copy code */
        var copyBtn = document.getElementById('copy-code-btn');
        var copyText = document.getElementById('copy-code-text');
        var codeEl = document.getElementById('gift-card-code');
        if (copyBtn && codeEl) {
          copyBtn.addEventListener('click', function() {
            var code = codeEl.textContent.replace(/\s/g, '');
            if (navigator.clipboard) {
              navigator.clipboard.writeText(code).then(function() {
                copyText.textContent = {{ 'gift_card.code_copied' | t | json }};
                setTimeout(function() {
                  copyText.textContent = {{ 'gift_card.copy_code' | t | json }};
                }, 2000);
              });
            }
          });
        }
      });
    </script>
  </body>
</html>
