{
  "sections": {
    "main": {
      "type": "main-product",
      "blocks": {
        "vendor": {
          "type": "vendor"
        },
        "title": {
          "type": "title",
          "settings": {
            "heading_size": "h1"
          }
        },
        "price": {
          "type": "price",
          "settings": {
            "show_tax_notice": false
          }
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "picker_type": "buttons",
            "swatch_shape": "circle"
          }
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "show_dynamic_checkout": true
          }
        },
        "trust": {
          "type": "trust_indicators",
          "settings": {
            "icon_1": "shipping",
            "text_1": "Free shipping",
            "icon_2": "return",
            "text_2": "Easy returns",
            "icon_3": "lock",
            "text_3": "Secure payment"
          }
        },
        "description": {
          "type": "description",
          "settings": {
            "collapsible": true,
            "default_open": true
          }
        },
        "shipping_tab": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Shipping & Returns",
            "icon": "shipping"
          }
        },
        "share": {
          "type": "share"
        }
      },
      "block_order": [
        "vendor",
        "title",
        "price",
        "variant_picker",
        "buy_buttons",
        "trust",
        "description",
        "shipping_tab",
        "share"
      ],
      "settings": {
        "media_size": 55,
        "media_position": "left",
        "gallery_layout": "stacked",
        "sticky_info": true,
        "enable_zoom": true,
        "padding_top": 40,
        "padding_bottom": 40
      }
    }
  },
  "order": [
    "main"
  ]
}
