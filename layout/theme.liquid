<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {%- render 'css-variables' -%}

    {%- comment -%} Font preloading — only when font settings are available {%- endcomment -%}
    {%- if settings.type_heading_font != blank or settings.type_body_font != blank -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endif -%}

    {%- comment -%} Favicon {%- endcomment -%}
    {%- if settings.favicon -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}
    {{ 'component-button.css' | asset_url | stylesheet_tag }}
    {{ 'component-quick-view.css' | asset_url | stylesheet_tag }}

    {%- if settings.page_transition == 'none' -%}
      <style>@view-transition { navigation: none; }</style>
    {%- endif -%}

    {%- render 'meta-tags' -%}

    {{ content_for_header }}
    {%- render 'structured-data' -%}
  </head>

  <body
    class="color-{{ settings.default_color_scheme }}"
    data-cart-type="{{ settings.cart_type }}"
    {% if settings.button_hover_effect != 'none' %}data-button-hover="{{ settings.button_hover_effect }}"{% endif %}
    {% if settings.card_hover_effect != 'none' %}data-card-hover="{{ settings.card_hover_effect }}"{% endif %}
    {% if settings.image_hover_effect != 'none' %}data-image-hover="{{ settings.image_hover_effect }}"{% endif %}
  >
    <a class="skip-to-content" href="#main-content">
      {{- 'accessibility.skip_to_content' | t -}}
    </a>

    {%- sections 'header-group' -%}

    <main id="main-content" role="main">
      {{ content_for_layout }}
    </main>

    {%- sections 'footer-group' -%}

    <script src="{{ 'quick-view.js' | asset_url }}" defer></script>

    {%- comment -%} Quick View modal (shared across pages) {%- endcomment -%}
    <dialog
      class="quick-view-dialog"
      id="quick-view-modal"
      scroll-lock
      data-t-add-to-cart="{{ 'product.add_to_cart' | t | escape }}"
      data-t-sold-out="{{ 'product.sold_out' | t | escape }}"
      data-t-adding="{{ 'product.add_to_cart' | t | escape }}…"
      data-t-close="{{ 'accessibility.close' | t | escape }}"
      data-t-view-full="{{ 'product.view_full_details' | t | escape }}"
      data-money-format="{{ shop.money_format | escape }}"
    >
      <div class="quick-view__inner">
        <div class="quick-view__loading">
          <div class="quick-view__spinner"></div>
        </div>
      </div>
    </dialog>

    {%- comment -%} Scroll reveal animations {%- endcomment -%}
    {%- if settings.scroll_reveal != 'none' -%}
      <script>
        (function() {
          var animationType = '{{ settings.scroll_reveal }}';

          /* Auto-apply .reveal to all sections inside main */
          document.querySelectorAll('#main-content > section, #main-content > div > section').forEach(function(section) {
            if (!section.classList.contains('reveal')) {
              section.classList.add('reveal');
              section.dataset.animation = animationType;
            }
          });

          /* Index stagger children for incremental delay */
          function indexStaggerChildren(root) {
            root.querySelectorAll('[data-stagger]').forEach(function(child, i) {
              child.style.setProperty('--stagger-index', i);
            });
          }

          var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
              if (entry.isIntersecting) {
                indexStaggerChildren(entry.target);
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

          document.querySelectorAll('.reveal').forEach(function(el) {
            observer.observe(el);
          });

          document.addEventListener('shopify:section:load', function(e) {
            var section = e.target;
            if (!section.classList.contains('reveal')) {
              section.classList.add('reveal');
              section.dataset.animation = animationType;
            }
            if (!section.classList.contains('is-visible')) {
              observer.observe(section);
            }
          });
        })();
      </script>
    {%- endif -%}
  </body>
</html>
