<!doctype html>
<html lang="{{ request.locale.iso_code }}" class="no-js">
  <head>
    <script>document.documentElement.classList.replace('no-js', 'js');</script>
    {%- render 'css-variables' -%}

    {%- comment -%} Font preloading — only when font settings are available {%- endcomment -%}
    {%- if settings.type_heading_font != blank or settings.type_body_font != blank -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endif -%}

    {%- comment -%} Favicon {%- endcomment -%}
    {%- if settings.favicon -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}
    {{ 'component-button.css' | asset_url | stylesheet_tag }}
    {{ 'component-quick-view.css' | asset_url | stylesheet_tag }}

    {%- comment -%} Page transition: 'fade' is the critical.css default. {%- endcomment -%}
    {%- if settings.page_transition == 'none' -%}
      <style>@view-transition { navigation: none; }</style>
    {%- elsif settings.page_transition == 'curtain' -%}
      <style>
        /* Curtain — outgoing page recedes, incoming rises like a drawn curtain.
           The shared product image (if any) morphs independently above this. */
        ::view-transition-old(root) {
          animation: 460ms cubic-bezier(0.7, 0, 0.84, 0) both ecrin-curtain-old;
        }
        ::view-transition-new(root) {
          animation: 700ms cubic-bezier(0.16, 1, 0.3, 1) both ecrin-curtain-new;
        }
        @keyframes ecrin-curtain-old {
          to { opacity: 0; transform: scale(0.96); }
        }
        @keyframes ecrin-curtain-new {
          from { clip-path: inset(100% 0 0 0); }
          to { clip-path: inset(0 0 0 0); }
        }
        @media (prefers-reduced-motion: reduce) {
          ::view-transition-old(root),
          ::view-transition-new(root) { animation-duration: 1ms; }
        }
      </style>
    {%- endif -%}

    {%- render 'meta-tags' -%}

    {{ content_for_header }}
    {%- render 'structured-data' -%}
  </head>

  <body
    class="color-{{ settings.default_color_scheme }}"
    data-cart-type="{{ settings.cart_type }}"
    {% if settings.button_hover_effect != 'none' %}data-button-hover="{{ settings.button_hover_effect }}"{% endif %}
    {% if settings.image_hover_effect != 'none' %}data-image-hover="{{ settings.image_hover_effect }}"{% endif %}
    data-card-title-underline="{{ settings.product_card_title_underline }}"
  >
    <a class="skip-to-content" href="#main-content">
      {{- 'accessibility.skip_to_content' | t -}}
    </a>

    {%- sections 'header-group' -%}

    <main id="main-content" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {%- sections 'footer-group' -%}

    {%- comment -%} Stagger animation — trigger when cards approach the viewport.
       Scroll-triggered = user-initiated, so NOT disabled by reduced-motion.
       The CSS reduced-motion media query handles autonomous animations only.
       Cards are hidden only once a grid is "armed" by this script, so
       content stays visible without JS and in grids injected after load
       (AJAX collection filtering, customizer re-renders). {%- endcomment -%}
    <script>
      (function() {
        if (!('IntersectionObserver' in window)) return;

        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-staggering');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0, rootMargin: '0px 0px 10% 0px' });

        function armGrids(root) {
          (root || document).querySelectorAll('[data-stagger-cards]:not(.stagger-armed)').forEach(function(grid) {
            grid.classList.add('stagger-armed');
            observer.observe(grid);
          });
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', function() { armGrids(); });
        } else {
          armGrids();
        }

        document.addEventListener('shopify:section:load', function(e) { armGrids(e.target); });

        /* Grids injected later (AJAX filtering, recently viewed…) */
        new MutationObserver(function() { armGrids(); })
          .observe(document.body, { childList: true, subtree: true });
      })();
    </script>

    {%- comment -%} Shared-element transition: the clicked product card image
       morphs into the PDP hero image. Names must be unique per page, so we
       assign the name only to the clicked card's image just before navigation
       (the PDP hero carries the matching name via CSS). {%- endcomment -%}
    {%- if settings.page_transition != 'none' -%}
      <script>
        (function () {
          if (!('startViewTransition' in document)) return;
          document.addEventListener('click', function (e) {
            var link = e.target.closest('a.card-product__media-link');
            if (!link) return;
            var card = link.closest('.card-product');
            var img = card && card.querySelector('.card-product__image--primary');
            if (!img) return;
            document.querySelectorAll('[data-vt-product-media]').forEach(function (el) {
              el.style.viewTransitionName = '';
              el.removeAttribute('data-vt-product-media');
            });
            img.style.viewTransitionName = 'ecrin-product-media';
            img.setAttribute('data-vt-product-media', '');
          }, true);
        })();
      </script>
    {%- endif -%}

    {%- comment -%} Quick View drawer is lazy-created by component-quick-view.js
       (loaded per section: collection, featured-collection, recently-viewed,
       product-recommendations) when a [data-quick-view-trigger] is clicked. {%- endcomment -%}

    {%- comment -%} Smooth scroll (Lenis) {%- endcomment -%}
    {%- if settings.enable_smooth_scroll -%}
      <script src="{{ 'vendor-lenis.min.js' | asset_url }}" defer></script>
      <script src="{{ 'smooth-scroll.js' | asset_url }}" defer></script>
    {%- endif -%}

    {%- comment -%} Scroll reveal animations {%- endcomment -%}
    {%- if settings.scroll_reveal != 'none' -%}
      <script>
        (function() {
          var animationType = '{{ settings.scroll_reveal }}';

          /* Auto-apply .reveal to all sections inside main */
          document.querySelectorAll('#main-content > section, #main-content > div > section').forEach(function(section) {
            if (!section.classList.contains('reveal')) {
              section.classList.add('reveal');
              section.dataset.animation = animationType;
            }
          });

          /* Index stagger children for incremental delay */
          function indexStaggerChildren(root) {
            root.querySelectorAll('[data-stagger]').forEach(function(child, i) {
              child.style.setProperty('--stagger-index', i);
            });
          }

          var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
              if (entry.isIntersecting) {
                indexStaggerChildren(entry.target);
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          }, { threshold: 0, rootMargin: '0px 0px 20% 0px' });

          document.querySelectorAll('.reveal').forEach(function(el) {
            observer.observe(el);
          });

          document.addEventListener('shopify:section:load', function(e) {
            var section = e.target;
            if (!section.classList.contains('reveal')) {
              section.classList.add('reveal');
              section.dataset.animation = animationType;
            }
            if (!section.classList.contains('is-visible')) {
              observer.observe(section);
            }
          });
        })();
      </script>
    {%- endif -%}
  </body>
</html>
