{% comment %}
  Mega menu promo cards — 2 images max.
  Params:
    block {Block}  The mega_menu block with image_1/image_2 settings
{% endcomment %}

{%- assign has_promos = false -%}
{%- if block.settings.image_1 != blank or block.settings.image_2 != blank -%}
  {%- assign has_promos = true -%}
{%- endif -%}

{%- if has_promos -%}
  <div class="mega-menu-promo">
    {%- if block.settings.image_1 != blank -%}
      {%- assign img1_focal = block.settings.image_1.presentation.focal_point -%}
      {%- assign img1_style = 'object-position: ' | append: img1_focal -%}
      {%- if block.settings.image_1_url != blank -%}
        <a href="{{ block.settings.image_1_url }}" class="mega-menu-promo__card">
      {%- else -%}
        <div class="mega-menu-promo__card">
      {%- endif -%}
        <div class="mega-menu-promo__image-wrap">
          {{ block.settings.image_1 | image_url: width: 600 | image_tag:
            widths: '300, 400, 600',
            sizes: '280px',
            loading: 'lazy',
            class: 'mega-menu-promo__image',
            style: img1_style
          }}
        </div>
        {%- if block.settings.image_1_label != blank -%}
          <p class="mega-menu-promo__caption">{{ block.settings.image_1_label | escape }}</p>
        {%- endif -%}
      {%- if block.settings.image_1_url != blank -%}
        </a>
      {%- else -%}
        </div>
      {%- endif -%}
    {%- endif -%}

    {%- if block.settings.image_2 != blank -%}
      {%- assign img2_focal = block.settings.image_2.presentation.focal_point -%}
      {%- assign img2_style = 'object-position: ' | append: img2_focal -%}
      {%- if block.settings.image_2_url != blank -%}
        <a href="{{ block.settings.image_2_url }}" class="mega-menu-promo__card">
      {%- else -%}
        <div class="mega-menu-promo__card">
      {%- endif -%}
        <div class="mega-menu-promo__image-wrap">
          {{ block.settings.image_2 | image_url: width: 600 | image_tag:
            widths: '300, 400, 600',
            sizes: '280px',
            loading: 'lazy',
            class: 'mega-menu-promo__image',
            style: img2_style
          }}
        </div>
        {%- if block.settings.image_2_label != blank -%}
          <p class="mega-menu-promo__caption">{{ block.settings.image_2_label | escape }}</p>
        {%- endif -%}
      {%- if block.settings.image_2_url != blank -%}
        </a>
      {%- else -%}
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
{%- endif -%}
