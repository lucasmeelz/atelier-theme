{%- comment -%}
  Mega menu promo images
  Params:
    block   {Block}  Mega menu block with promo settings
{%- endcomment -%}

{%- liquid
  assign layout = block.settings.promo_layout | default: '2'
  assign has_promo_1 = false
  assign has_promo_2 = false
  assign has_promo_3 = false
  if block.settings.promo_1_image != blank
    assign has_promo_1 = true
  endif
  if block.settings.promo_2_image != blank
    assign has_promo_2 = true
  endif
  if block.settings.promo_3_image != blank
    assign has_promo_3 = true
  endif
  assign has_any_promo = false
  if has_promo_1 or has_promo_2 or has_promo_3
    assign has_any_promo = true
  endif
-%}

{%- if has_any_promo -%}
  <div class="mega-promo mega-promo--{{ layout }}" {{ block.shopify_attributes }}>

    {%- if has_promo_1 -%}
      <div class="mega-promo__card">
        {%- if block.settings.promo_1_link != blank -%}
          <a href="{{ block.settings.promo_1_link }}" class="mega-promo__link">
        {%- endif -%}
          <div class="mega-promo__image">
            {{ block.settings.promo_1_image | image_url: width: 800 | image_tag:
              loading: 'lazy',
              widths: '300,400,600,800',
              class: 'mega-promo__img',
              alt: block.settings.promo_1_heading | default: ''
            }}
          </div>
          {%- if block.settings.promo_1_heading != blank or block.settings.promo_1_subheading != blank -%}
            <div class="mega-promo__content">
              {%- if block.settings.promo_1_subheading != blank -%}
                <span class="mega-promo__subheading label">{{ block.settings.promo_1_subheading }}</span>
              {%- endif -%}
              {%- if block.settings.promo_1_heading != blank -%}
                <span class="mega-promo__heading">{{ block.settings.promo_1_heading }}</span>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- if block.settings.promo_1_link != blank -%}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if has_promo_2 and layout != '1' -%}
      <div class="mega-promo__card">
        {%- if block.settings.promo_2_link != blank -%}
          <a href="{{ block.settings.promo_2_link }}" class="mega-promo__link">
        {%- endif -%}
          <div class="mega-promo__image">
            {{ block.settings.promo_2_image | image_url: width: 800 | image_tag:
              loading: 'lazy',
              widths: '300,400,600,800',
              class: 'mega-promo__img',
              alt: block.settings.promo_2_heading | default: ''
            }}
          </div>
          {%- if block.settings.promo_2_heading != blank or block.settings.promo_2_subheading != blank -%}
            <div class="mega-promo__content">
              {%- if block.settings.promo_2_subheading != blank -%}
                <span class="mega-promo__subheading label">{{ block.settings.promo_2_subheading }}</span>
              {%- endif -%}
              {%- if block.settings.promo_2_heading != blank -%}
                <span class="mega-promo__heading">{{ block.settings.promo_2_heading }}</span>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- if block.settings.promo_2_link != blank -%}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if has_promo_3 and layout == '3' -%}
      <div class="mega-promo__card">
        {%- if block.settings.promo_3_link != blank -%}
          <a href="{{ block.settings.promo_3_link }}" class="mega-promo__link">
        {%- endif -%}
          <div class="mega-promo__image">
            {{ block.settings.promo_3_image | image_url: width: 800 | image_tag:
              loading: 'lazy',
              widths: '300,400,600,800',
              class: 'mega-promo__img',
              alt: block.settings.promo_3_heading | default: ''
            }}
          </div>
          {%- if block.settings.promo_3_heading != blank or block.settings.promo_3_subheading != blank -%}
            <div class="mega-promo__content">
              {%- if block.settings.promo_3_subheading != blank -%}
                <span class="mega-promo__subheading label">{{ block.settings.promo_3_subheading }}</span>
              {%- endif -%}
              {%- if block.settings.promo_3_heading != blank -%}
                <span class="mega-promo__heading">{{ block.settings.promo_3_heading }}</span>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- if block.settings.promo_3_link != blank -%}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
{%- endif -%}
