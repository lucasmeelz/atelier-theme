{%- comment -%}
  Menu Drawer — Dior-style 3-level navigation
  Parameters: menu, blocks, tab_1_menu, tab_1_label, tab_2_menu, tab_2_label
{%- endcomment -%}

{%- liquid
  assign has_tab_2 = false
  if tab_2_menu != blank and tab_2_label != blank
    assign has_tab_2 = true
  endif
  assign nav_menu = menu | default: tab_1_menu
-%}

<!-- Backdrop -->
<div class="drawer-backdrop" data-backdrop aria-hidden="true"></div>

<!-- Drawer -->
<nav class="drawer" data-drawer data-level="1" aria-label="{{ 'header.navigation' | t }}">
  <div class="drawer__inner">

    <!-- ============ L1 Panel ============ -->
    <div class="drawer__panel drawer__panel--l1">
      <button class="drawer__close" data-action="close" aria-label="{{ 'header.close_menu' | t }}">
        {%- render 'icon', name: 'close' -%}
        <span class="drawer__close-text">{{ 'header.close_menu' | t }}</span>
      </button>

      <!-- Tab 1 links -->
      <ul class="drawer__l1-list" data-tab-content="1" role="list">
        {%- for link in nav_menu.links -%}
          <li>
            {%- if link.links.size > 0 -%}
              <button class="drawer__l1-link" data-action="show-l2" data-target="t1-{{ forloop.index0 }}" aria-expanded="false" aria-controls="drawer-l2-t1-{{ forloop.index0 }}">
                <span class="drawer__l1-text">{{ link.title }}</span>
                {%- render 'icon', name: 'chevron-right' -%}
              </button>
            {%- else -%}
              <a href="{{ link.url }}" class="drawer__l1-link">
                <span class="drawer__l1-text">{{ link.title }}</span>
              </a>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>

      {%- if has_tab_2 -%}
        <!-- Tab 2 links -->
        <ul class="drawer__l1-list" data-tab-content="2" hidden role="list">
          {%- for link in tab_2_menu.links -%}
            <li>
              {%- if link.links.size > 0 -%}
                <button class="drawer__l1-link" data-action="show-l2" data-target="t2-{{ forloop.index0 }}" aria-expanded="false" aria-controls="drawer-l2-t2-{{ forloop.index0 }}">
                  <span class="drawer__l1-text">{{ link.title }}</span>
                  {%- render 'icon', name: 'chevron-right' -%}
                </button>
              {%- else -%}
                <a href="{{ link.url }}" class="drawer__l1-link">
                  <span class="drawer__l1-text">{{ link.title }}</span>
                </a>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>

        <!-- Universe tabs -->
        <div class="drawer__tabs">
          <button class="drawer__tab drawer__tab--active" data-action="switch-tab" data-tab="1">
            {{ tab_1_label }}
          </button>
          <button class="drawer__tab" data-action="switch-tab" data-tab="2">
            {{ tab_2_label }}
          </button>
        </div>
      {%- endif -%}
    </div>

    <!-- ============ L2 Panel ============ -->
    <div class="drawer__panel drawer__panel--l2">
      <div class="drawer__breadcrumb" data-breadcrumb="l2">
        <button data-action="back-l1" aria-label="{{ 'header.back' | t }}">
          {%- render 'icon', name: 'chevron-left' -%}
          <span data-breadcrumb-text aria-live="polite"></span>
        </button>
      </div>

      <!-- L2 groups — Tab 1 -->
      {%- for link in nav_menu.links -%}
        {%- if link.links.size > 0 -%}
          {%- assign l1_idx = forloop.index0 -%}
          <div class="drawer__l2-group" id="drawer-l2-t1-{{ l1_idx }}" data-l2-id="t1-{{ l1_idx }}" hidden>
            <ul class="drawer__l2-list" role="list">
              {%- for child in link.links -%}
                <li>
                  {%- if child.links.size > 0 -%}
                    <button class="drawer__l2-link" data-action="show-l3" data-target="t1-{{ l1_idx }}-{{ forloop.index0 }}">
                      <span>{{ child.title }}</span>
                      {%- render 'icon', name: 'chevron-right' -%}
                    </button>
                  {%- else -%}
                    <a href="{{ child.url }}" class="drawer__l2-link">
                      <span>{{ child.title }}</span>
                    </a>
                  {%- endif -%}
                </li>
              {%- endfor -%}
            </ul>

            {%- comment -%} Editorial images from mega_menu blocks {%- endcomment -%}
            {%- for block in blocks -%}
              {%- if block.type == 'mega_menu' -%}
                {%- assign block_handle = block.settings.menu_item | downcase | strip -%}
                {%- assign link_handle = link.title | downcase | strip -%}
                {%- if block_handle == link_handle -%}
                  <div class="drawer__editorial-images">
                    {%- if block.settings.image_1 -%}
                      <div class="drawer__editorial-item">
                        {%- if block.settings.image_1_url -%}
                          <a href="{{ block.settings.image_1_url }}">
                            {{ block.settings.image_1 | image_url: width: 400 | image_tag: alt: block.settings.image_1_label, loading: 'lazy', widths: '200, 300, 400' }}
                          </a>
                        {%- else -%}
                          {{ block.settings.image_1 | image_url: width: 400 | image_tag: alt: block.settings.image_1_label, loading: 'lazy', widths: '200, 300, 400' }}
                        {%- endif -%}
                        {%- if block.settings.image_1_label != blank -%}
                          <p class="drawer__editorial-title">{{ block.settings.image_1_label }}</p>
                        {%- endif -%}
                        {%- if block.settings.image_1_subtitle != blank -%}
                          <p class="drawer__editorial-subtitle">{{ block.settings.image_1_subtitle }}</p>
                        {%- endif -%}
                      </div>
                    {%- endif -%}
                    {%- if block.settings.image_2 -%}
                      <div class="drawer__editorial-item">
                        {%- if block.settings.image_2_url -%}
                          <a href="{{ block.settings.image_2_url }}">
                            {{ block.settings.image_2 | image_url: width: 400 | image_tag: alt: block.settings.image_2_label, loading: 'lazy', widths: '200, 300, 400' }}
                          </a>
                        {%- else -%}
                          {{ block.settings.image_2 | image_url: width: 400 | image_tag: alt: block.settings.image_2_label, loading: 'lazy', widths: '200, 300, 400' }}
                        {%- endif -%}
                        {%- if block.settings.image_2_label != blank -%}
                          <p class="drawer__editorial-title">{{ block.settings.image_2_label }}</p>
                        {%- endif -%}
                        {%- if block.settings.image_2_subtitle != blank -%}
                          <p class="drawer__editorial-subtitle">{{ block.settings.image_2_subtitle }}</p>
                        {%- endif -%}
                      </div>
                    {%- endif -%}
                    {%- if block.settings.image_3 -%}
                      <div class="drawer__editorial-item">
                        {%- if block.settings.image_3_url -%}
                          <a href="{{ block.settings.image_3_url }}">
                            {{ block.settings.image_3 | image_url: width: 400 | image_tag: alt: '', loading: 'lazy', widths: '200, 300, 400' }}
                          </a>
                        {%- else -%}
                          {{ block.settings.image_3 | image_url: width: 400 | image_tag: alt: '', loading: 'lazy', widths: '200, 300, 400' }}
                        {%- endif -%}
                        {%- if block.settings.image_3_subtitle != blank -%}
                          <p class="drawer__editorial-subtitle">{{ block.settings.image_3_subtitle }}</p>
                        {%- endif -%}
                      </div>
                    {%- endif -%}
                    {%- if block.settings.image_4 -%}
                      <div class="drawer__editorial-item">
                        {{ block.settings.image_4 | image_url: width: 400 | image_tag: alt: '', loading: 'lazy', widths: '200, 300, 400' }}
                      </div>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      {%- endfor -%}

      {%- if has_tab_2 -%}
        <!-- L2 groups — Tab 2 -->
        {%- for link in tab_2_menu.links -%}
          {%- if link.links.size > 0 -%}
            {%- assign l1_idx = forloop.index0 -%}
            <div class="drawer__l2-group" id="drawer-l2-t2-{{ l1_idx }}" data-l2-id="t2-{{ l1_idx }}" hidden>
              <ul class="drawer__l2-list" role="list">
                {%- for child in link.links -%}
                  <li>
                    {%- if child.links.size > 0 -%}
                      <button class="drawer__l2-link" data-action="show-l3" data-target="t2-{{ l1_idx }}-{{ forloop.index0 }}">
                        <span>{{ child.title }}</span>
                        {%- render 'icon', name: 'chevron-right' -%}
                      </button>
                    {%- else -%}
                      <a href="{{ child.url }}" class="drawer__l2-link">
                        <span>{{ child.title }}</span>
                      </a>
                    {%- endif -%}
                  </li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>

    <!-- ============ L3 Panel ============ -->
    <div class="drawer__panel drawer__panel--l3">
      <div class="drawer__breadcrumb" data-breadcrumb="l3">
        <button data-action="back-l2" aria-label="{{ 'header.back' | t }}">
          {%- render 'icon', name: 'chevron-left' -%}
          <span data-breadcrumb-text aria-live="polite"></span>
        </button>
      </div>

      <!-- L3 groups — Tab 1 -->
      {%- for link in nav_menu.links -%}
        {%- if link.links.size > 0 -%}
          {%- assign l1_idx = forloop.index0 -%}
          {%- for child in link.links -%}
            {%- if child.links.size > 0 -%}
              {%- assign l2_idx = forloop.index0 -%}
              <ul class="drawer__l3-list" data-l3-id="t1-{{ l1_idx }}-{{ l2_idx }}" hidden role="list">
                {%- for grandchild in child.links -%}
                  <li>
                    <a href="{{ grandchild.url }}" class="drawer__l3-link">
                      {{ grandchild.title }}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if has_tab_2 -%}
        <!-- L3 groups — Tab 2 -->
        {%- for link in tab_2_menu.links -%}
          {%- if link.links.size > 0 -%}
            {%- assign l1_idx = forloop.index0 -%}
            {%- for child in link.links -%}
              {%- if child.links.size > 0 -%}
                {%- assign l2_idx = forloop.index0 -%}
                <ul class="drawer__l3-list" data-l3-id="t2-{{ l1_idx }}-{{ l2_idx }}" hidden role="list">
                  {%- for grandchild in child.links -%}
                    <li>
                      <a href="{{ grandchild.url }}" class="drawer__l3-link">
                        {{ grandchild.title }}
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>

  </div>
</nav>
