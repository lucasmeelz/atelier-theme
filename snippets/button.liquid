{%- comment -%}
  Button component
  Params:
    label       {String}  Button text (required)
    url         {String}  Link URL (renders <a> when present)
    style       {String}  primary | secondary | outline-white | link (default: primary)
    size        {String}  default | small | full
    type        {String}  button | submit (default: button, ignored when url is set)
    class       {String}  Additional CSS classes
    aria_label  {String}  Accessible label override
    disabled    {Boolean} Disabled state
    id          {String}  Element ID
    name        {String}  Form input name (for submit buttons)
{%- endcomment -%}

{%- liquid
  assign btn_style = style | default: 'primary'
  assign btn_class = 'btn btn--' | append: btn_style
  if size == 'small'
    assign btn_class = btn_class | append: ' btn--small'
  elsif size == 'full'
    assign btn_class = btn_class | append: ' btn--full'
  endif
  if class != blank
    assign btn_class = btn_class | append: ' ' | append: class
  endif
  assign show_fill = true
  if btn_style == 'link'
    assign show_fill = false
  endif
-%}

{%- if url != blank -%}
  <a
    href="{{ url }}"
    class="{{ btn_class }}"
    {%- if aria_label != blank %} aria-label="{{ aria_label }}"{% endif -%}
    {%- if id != blank %} id="{{ id }}"{% endif -%}
  >
    <span class="btn__label">{{ label }}</span>
    {%- if show_fill -%}
      <span class="btn__fill" aria-hidden="true"></span>
    {%- endif -%}
  </a>
{%- else -%}
  <button
    type="{{ type | default: 'button' }}"
    class="{{ btn_class }}"
    {%- if aria_label != blank %} aria-label="{{ aria_label }}"{% endif -%}
    {%- if disabled %} disabled aria-disabled="true"{% endif -%}
    {%- if id != blank %} id="{{ id }}"{% endif -%}
    {%- if name != blank %} name="{{ name }}"{% endif -%}
  >
    <span class="btn__label">{{ label }}</span>
    {%- if show_fill -%}
      <span class="btn__fill" aria-hidden="true"></span>
    {%- endif -%}
  </button>
{%- endif -%}
