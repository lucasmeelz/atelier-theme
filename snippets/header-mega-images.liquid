{% comment %}
  Renders mega menu images for a mega_menu block.
  Params:
    block {Block}  The mega_menu block to render images from
{% endcomment %}

{%- if block != blank -%}
  {%- if block.settings.image_1 != blank or block.settings.image_2 != blank -%}
    <div class="header__dropdown-images" {{ block.shopify_attributes }}>
      {%- if block.settings.image_1 != blank -%}
        <div class="header__dropdown-image-card">
          {%- if block.settings.image_1_url != blank -%}
            <a href="{{ block.settings.image_1_url }}" class="header__dropdown-image-link">
          {%- endif -%}
            <div class="header__dropdown-image-wrapper">
              {{ block.settings.image_1 | image_url: width: 600 | image_tag:
                widths: '300, 400, 600',
                sizes: '300px',
                loading: 'lazy',
                class: 'header__dropdown-image',
                style: 'object-position: {{ block.settings.image_1.presentation.focal_point }}'
              }}
            </div>
            {%- if block.settings.image_1_label != blank -%}
              <p class="header__dropdown-image-caption">{{ block.settings.image_1_label | escape }}</p>
            {%- endif -%}
          {%- if block.settings.image_1_url != blank -%}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if block.settings.image_2 != blank -%}
        <div class="header__dropdown-image-card">
          {%- if block.settings.image_2_url != blank -%}
            <a href="{{ block.settings.image_2_url }}" class="header__dropdown-image-link">
          {%- endif -%}
            <div class="header__dropdown-image-wrapper">
              {{ block.settings.image_2 | image_url: width: 600 | image_tag:
                widths: '300, 400, 600',
                sizes: '300px',
                loading: 'lazy',
                class: 'header__dropdown-image',
                style: 'object-position: {{ block.settings.image_2.presentation.focal_point }}'
              }}
            </div>
            {%- if block.settings.image_2_label != blank -%}
              <p class="header__dropdown-image-caption">{{ block.settings.image_2_label | escape }}</p>
            {%- endif -%}
          {%- if block.settings.image_2_url != blank -%}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}
{%- endif -%}
