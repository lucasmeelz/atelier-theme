{%- comment -%}
  Icon system — inline SVG
  Params:
    name    {String}  Icon name (required)
    size    {Number}  Width/height in px (default: 20)
    class   {String}  Additional CSS classes
{%- endcomment -%}

{%- liquid
  assign icon_size = size | default: 20
  assign icon_class = 'icon icon--' | append: name
  if class != blank
    assign icon_class = icon_class | append: ' ' | append: class
  endif
  assign icon_style = '--icon-size: ' | append: icon_size | append: 'px'
-%}

