{%- comment -%}
  Icon snippet — renders inline SVGs by name
  Usage: {% render 'icon', name: 'menu' %}
{%- endcomment -%}

{%- case name -%}

  {%- when 'menu' -%}
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
      <line x1="3" y1="9" x2="21" y2="9" stroke="currentColor" stroke-width="0.75"/>
      <line x1="3" y1="15" x2="16" y2="15" stroke="currentColor" stroke-width="0.75"/>
    </svg>

  {%- when 'close' -%}
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
      <line x1="4" y1="4" x2="16" y2="16" stroke="currentColor" stroke-width="1.2"/>
      <line x1="16" y1="4" x2="4" y2="16" stroke="currentColor" stroke-width="1.2"/>
    </svg>

  {%- when 'search' -%}
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
      <circle cx="8.5" cy="8.5" r="5.5" stroke="currentColor" stroke-width="1.2"/>
      <line x1="12.8" y1="13.2" x2="17" y2="17" stroke="currentColor" stroke-width="1.2"/>
    </svg>

  {%- when 'wishlist' -%}
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
      <path d="M10 17s-7-4.5-7-9a3.5 3.5 0 0 1 7 1 3.5 3.5 0 0 1 7-1c0 4.5-7 9-7 9z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
    </svg>

  {%- when 'account' -%}
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
      <circle cx="10" cy="7" r="3.5" stroke="currentColor" stroke-width="1.2"/>
      <path d="M3 18c0-3.5 3-6 7-6s7 2.5 7 6" stroke="currentColor" stroke-width="1.2" fill="none"/>
    </svg>

  {%- when 'bag' -%}
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
      <path d="M4 7h12l-1 11H5L4 7z" stroke="currentColor" stroke-width="1.2" fill="none"/>
      <path d="M7 7V5a3 3 0 0 1 6 0v2" stroke="currentColor" stroke-width="1.2" fill="none"/>
    </svg>

  {%- when 'chevron-left' -%}
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
      <path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.2" fill="none"/>
    </svg>

  {%- when 'chevron-right' -%}
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
      <path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.2" fill="none"/>
    </svg>

  {%- when 'chevron-down' -%}
    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
      <polyline points="2,4 6,8 10,4" stroke="currentColor" stroke-width="1"/>
    </svg>

{%- endcase -%}
