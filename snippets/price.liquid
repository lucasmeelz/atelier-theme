{%- comment -%}
  Price component
  Params:
    product         {Product}   Product object (required)
    variant         {Variant}   Specific variant (optional, defaults to selected_or_first_available_variant)
    show_compare_at {Boolean}   Show compare-at price (default: true)
    show_unit_price {Boolean}   Show unit price (default: true)
    show_badges     {Boolean}   Show sale/sold-out badges (default: false — badges handled separately in card)
    class           {String}    Additional CSS classes
{%- endcomment -%}

{%- liquid
  assign current_variant = variant | default: product.selected_or_first_available_variant
  assign compare_at_price = current_variant.compare_at_price
  assign price = current_variant.price
  assign available = current_variant.available
  assign unit_price = current_variant.unit_price
  assign unit_price_measurement = current_variant.unit_price_measurement
  assign show_compare = show_compare_at | default: true
  assign show_unit = show_unit_price | default: true
  assign on_sale = false
  if compare_at_price > price and available
    assign on_sale = true
  endif
  assign price_varies = false
  if product.price_varies
    assign price_varies = true
  endif
-%}

<div class="price{% if on_sale %} price--on-sale{% endif %}{% unless available %} price--sold-out{% endunless %}{% if class %} {{ class }}{% endif %}" data-price>
  <div class="price__regular">
    {%- if price_varies -%}
      <span class="price__label visually-hidden">{{ 'product.from_price' | t: price: '' }}</span>
      <span class="price__from">{{ 'product.from_price' | t: price: price | money }}</span>
    {%- else -%}
      {%- if on_sale and show_compare -%}
        <span class="visually-hidden">{{ 'product.price' | t }}</span>
      {%- endif -%}
      <span class="price__current{% if on_sale %} price__current--sale{% endif %}">
        {{- price | money -}}
      </span>
    {%- endif -%}
  </div>

  {%- if on_sale and show_compare -%}
    <div class="price__compare">
      <span class="visually-hidden">{{ 'product.compare_at_price' | t }}</span>
      <s class="price__was">{{ compare_at_price | money }}</s>
    </div>
  {%- endif -%}

  {%- if show_unit and unit_price -%}
    <div class="price__unit">
      <span class="visually-hidden">{{ 'product.unit_price' | t }}</span>
      <span class="price__unit-price">
        {{- unit_price | money -}}
        <span class="price__unit-separator">{{ 'product.unit_price_separator' | t }}</span>
        {%- if unit_price_measurement.reference_value != 1 -%}
          {{- unit_price_measurement.reference_value -}}
        {%- endif -%}
        {{ unit_price_measurement.reference_unit }}
      </span>
    </div>
  {%- endif -%}

  {%- unless hide_tax_notice -%}
    {%- if cart.taxes_included -%}
      <span class="price__tax-notice">{{ 'product.includes_tax' | t }}</span>
    {%- endif -%}
  {%- endunless -%}
</div>
