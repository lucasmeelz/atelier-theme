{%- style -%}
  {%- comment -%} Heading font — all variants {%- endcomment -%}
  {{ settings.type_heading_font | font_face: font_display: 'swap' }}
  {{ settings.type_heading_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}
  {{ settings.type_heading_font | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}
  {{ settings.type_heading_font | font_modify: 'weight', 'bold' | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}

  {%- comment -%} Body font — all variants {%- endcomment -%}
  {{ settings.type_body_font | font_face: font_display: 'swap' }}
  {{ settings.type_body_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}
  {{ settings.type_body_font | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}
  {{ settings.type_body_font | font_modify: 'weight', 'bold' | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}

  {%- comment -%} Label font — all variants {%- endcomment -%}
  {{ settings.type_label_font | font_face: font_display: 'swap' }}
  {{ settings.type_label_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}

  :root {
    /* ===== TYPOGRAPHY ===== */

    /* Heading */
    --font-heading-family: {{ settings.type_heading_font.family }}, {{ settings.type_heading_font.fallback_families }};
    --font-heading-style: {{ settings.type_heading_font.style }};
    --font-heading-weight: {{ settings.type_heading_font.weight }};
    --heading-scale: {{ settings.heading_size_scale }};
    --heading-text-transform: {{ settings.heading_text_transform }};
    --heading-letter-spacing: {{ settings.heading_letter_spacing | divided_by: 100.0 }}em;
    --heading-line-height: {{ settings.heading_line_height }};

    /* Body */
    --font-body-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    --font-body-style: {{ settings.type_body_font.style }};
    --font-body-weight: {{ settings.type_body_font.weight }};
    {%- liquid
      assign body_min = settings.body_font_size_mobile
      assign body_max = settings.body_font_size_desktop
      assign body_slope_vw = body_max | minus: body_min | times: 100.0 | divided_by: 1065.0
      assign body_intercept_px = body_slope_vw | times: 3.75 | times: -1.0 | plus: body_min
    -%}
    --body-font-size: clamp({{ body_min }}px, {{ body_intercept_px | round: 3 }}px + {{ body_slope_vw | round: 3 }}vw, {{ body_max }}px);
    --body-line-height: {{ settings.body_line_height }};

    /* Labels and subheadings */
    --font-label-family: {{ settings.type_label_font.family }}, {{ settings.type_label_font.fallback_families }};
    --font-label-weight: {{ settings.type_label_font.weight }};
    --label-font-size: {{ settings.label_font_size }}px;
    --label-text-transform: {{ settings.label_text_transform }};
    --label-letter-spacing: {{ settings.label_letter_spacing | divided_by: 100.0 }}em;

    /* Buttons */
    {%- if settings.button_font_choice == 'heading' -%}
      --font-button-family: var(--font-heading-family);
      --font-button-weight: var(--font-heading-weight);
    {%- else -%}
      --font-button-family: var(--font-body-family);
      --font-button-weight: 500;
    {%- endif -%}
    --button-font-size: {{ settings.button_font_size }}px;
    --button-text-transform: {{ settings.button_text_transform }};
    --button-letter-spacing: {{ settings.button_letter_spacing | divided_by: 100.0 }}em;

    /* Heading sizes — fluid typography with clamp()
       Scales smoothly between 375px and 1440px viewport, multiplied by --heading-scale */
    --h1-size: calc(var(--heading-scale) * clamp(2.25rem, 1.81rem + 1.878vw, 3.5rem));
    --h2-size: calc(var(--heading-scale) * clamp(1.75rem, 1.486rem + 1.127vw, 2.5rem));
    --h3-size: calc(var(--heading-scale) * clamp(1.375rem, 1.243rem + 0.563vw, 1.75rem));
    --h4-size: calc(var(--heading-scale) * clamp(1.125rem, 1.037rem + 0.376vw, 1.375rem));
    --h5-size: calc(var(--heading-scale) * clamp(1rem, 0.956rem + 0.188vw, 1.125rem));
    --h6-size: calc(var(--heading-scale) * clamp(0.875rem, 0.831rem + 0.188vw, 1rem));

    /* ===== LAYOUT ===== */
    --page-width: {{ settings.page_width }}px;
    --page-margin: {{ settings.page_margin }}px;

    {%- case settings.section_spacing -%}
      {%- when 'compact' -%}
        --section-spacing-mobile: 40px;
        --section-spacing-desktop: 80px;
      {%- when 'normal' -%}
        --section-spacing-mobile: 60px;
        --section-spacing-desktop: 120px;
      {%- when 'loose' -%}
        --section-spacing-mobile: 80px;
        --section-spacing-desktop: 160px;
    {%- endcase -%}

    /* ===== APPEARANCE ===== */
    --button-border-radius: {{ settings.button_border_radius }}px;
    --input-border-radius: {{ settings.input_border_radius }}px;
    --card-border-radius: {{ settings.card_border_radius }}px;
    --icon-stroke-width: {{ settings.icon_stroke_width }}px;
    --backdrop-blur: {{ settings.backdrop_blur }}px;

    /* ===== MOTION ===== */
    --ease-ecrin: cubic-bezier(0.31, 0, 0.13, 1);
    --duration-fast: 200ms;
    --duration-base: 350ms;
    --duration-slow: 600ms;

    /* ===== FUNCTIONAL COLORS ===== */
    --color-success: 45, 125, 70;
    --color-error: 194, 58, 58;

    /* ===== BADGES ===== */
    --color-sale-badge: {{ settings.sale_badge_color }};
    --color-sold-out-badge: {{ settings.sold_out_badge_color }};

    /* ===== PRODUCT CARDS ===== */
    {%- case settings.product_card_image_ratio -%}
      {%- when 'portrait' -%}
        --card-image-ratio: 3 / 4;
      {%- when 'square' -%}
        --card-image-ratio: 1 / 1;
      {%- when 'landscape' -%}
        --card-image-ratio: 4 / 3;
      {%- when 'natural' -%}
        --card-image-ratio: auto;
    {%- endcase -%}
  }

  {%- comment -%} Color schemes — OS 2.0 color_scheme_group {%- endcomment -%}
  {%- for scheme in settings.color_schemes -%}
    {%- liquid
      assign scheme_bg = scheme.settings.background
      assign scheme_bg_gradient = scheme_bg
      if scheme.settings.background_gradient != blank
        assign scheme_bg_gradient = scheme.settings.background_gradient
      endif
    -%}

    {%- if forloop.index == 1 -%}
      :root,
    {%- endif -%}
    .color-{{ scheme.id }} {
      --color-background: {{ scheme_bg.red }}, {{ scheme_bg.green }}, {{ scheme_bg.blue }};
      --color-background-hex: {{ scheme_bg }};
      --gradient-background: {{ scheme_bg_gradient }};
      --color-text: {{ scheme.settings.text.red }}, {{ scheme.settings.text.green }}, {{ scheme.settings.text.blue }};
      --color-text-subdued: {{ scheme.settings.text_subdued.red }}, {{ scheme.settings.text_subdued.green }}, {{ scheme.settings.text_subdued.blue }};
      --color-accent: {{ scheme.settings.accent.red }}, {{ scheme.settings.accent.green }}, {{ scheme.settings.accent.blue }};
      --color-border: {{ scheme.settings.border.red }}, {{ scheme.settings.border.green }}, {{ scheme.settings.border.blue }};
      --color-button-bg: {{ scheme.settings.button_background.red }}, {{ scheme.settings.button_background.green }}, {{ scheme.settings.button_background.blue }};
      --color-button-text: {{ scheme.settings.button_label.red }}, {{ scheme.settings.button_label.green }}, {{ scheme.settings.button_label.blue }};
      --color-button-hover-bg: {{ scheme.settings.button_hover_background.red }}, {{ scheme.settings.button_hover_background.green }}, {{ scheme.settings.button_hover_background.blue }};
      --color-button-hover-text: {{ scheme.settings.button_hover_label.red }}, {{ scheme.settings.button_hover_label.green }}, {{ scheme.settings.button_hover_label.blue }};
      --color-secondary-btn-bg: {{ scheme.settings.secondary_button_background.red }}, {{ scheme.settings.secondary_button_background.green }}, {{ scheme.settings.secondary_button_background.blue }};
      --color-secondary-btn-text: {{ scheme.settings.secondary_button_label.red }}, {{ scheme.settings.secondary_button_label.green }}, {{ scheme.settings.secondary_button_label.blue }};
    }
  {%- endfor -%}

{%- endstyle -%}
