{%- comment -%}
  Newsletter — Email signup section
  Supports: centered or split layout, background image with overlay,
  heading, subheading, disclaimer text, customizable button
{%- endcomment -%}

{{ 'section-newsletter.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign heading = section.settings.heading
  assign heading_size = section.settings.heading_size
  assign subheading = section.settings.subheading
  assign button_label = section.settings.button_label
  assign disclaimer = section.settings.disclaimer
  assign layout = section.settings.layout
  assign image = section.settings.background_image
  assign overlay_opacity = section.settings.overlay_opacity | divided_by: 100.0
  assign color_scheme = section.settings.color_scheme
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom

  assign has_image = false
  if image != blank
    assign has_image = true
  endif
-%}

{%- style -%}
  #Section-{{ section.id }} {
    --section-padding-top: {{ padding_top }}px;
    --section-padding-bottom: {{ padding_bottom }}px;
    --newsletter-overlay-opacity: {{ overlay_opacity }};
  }
{%- endstyle -%}

<div
  id="Section-{{ section.id }}"
  class="newsletter color-{{ color_scheme }}{% if has_image and layout == 'centered' %} newsletter--has-bg{% endif %}"
>
  {%- if has_image and layout == 'centered' -%}
    <div class="newsletter__bg">
      {{ image | image_url: width: 2000 | image_tag:
        loading: 'lazy',
        widths: '750,1000,1500,2000',
        sizes: '100vw',
        class: 'newsletter__bg-img',
        alt: ''
      }}
      <div class="newsletter__overlay" aria-hidden="true"></div>
    </div>
  {%- endif -%}

  <div class="container">
    <div class="newsletter__grid newsletter__grid--{{ layout }}">

      {%- if has_image and layout == 'split' -%}
        <div class="newsletter__media">
          {{ image | image_url: width: 1200 | image_tag:
            loading: 'lazy',
            widths: '400,600,800,1200',
            sizes: '(min-width: 990px) 50vw, 100vw',
            class: 'newsletter__media-img',
            alt: ''
          }}
        </div>
      {%- endif -%}

      <div class="newsletter__content">
        <div class="newsletter__content-inner">
          {%- if heading != blank -%}
            <{{ heading_size }} class="newsletter__heading">{{ heading }}</{{ heading_size }}>
          {%- endif -%}

          {%- if subheading != blank -%}
            <div class="newsletter__subheading rte">{{ subheading }}</div>
          {%- endif -%}

          {%- form 'customer', class: 'newsletter__form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="newsletter__field-group">
              <label for="newsletter-email-{{ section.id }}" class="visually-hidden">
                {{ 'footer.newsletter_placeholder' | t }}
              </label>
              <input
                type="email"
                name="contact[email]"
                id="newsletter-email-{{ section.id }}"
                class="newsletter__input"
                placeholder="{{ 'footer.newsletter_placeholder' | t }}"
                required
                autocomplete="email"
                aria-label="{{ 'footer.newsletter_placeholder' | t }}"
              >
              <button type="submit" class="btn btn--primary newsletter__submit">
                <span class="btn__label">{{ button_label | default: 'Subscribe' }}</span>
              </button>
            </div>

            {%- if form.posted_successfully? -%}
              <p class="newsletter__success" role="status">
                {{ 'footer.newsletter_success' | t }}
              </p>
            {%- endif -%}

            {%- if form.errors -%}
              <p class="newsletter__error" role="alert">
                {{ form.errors.translated_fields.email | capitalize }}
                {{ form.errors.messages.email }}
              </p>
            {%- endif -%}
          {%- endform -%}

          {%- if disclaimer != blank -%}
            <div class="newsletter__disclaimer rte">{{ disclaimer }}</div>
          {%- endif -%}
        </div>
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.newsletter.name",
  "tag": "section",
  "class": "section-newsletter",
  "disabled_on": {
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.newsletter.instructions"
    },
    {
      "type": "header",
      "content": "t:sections.newsletter.content_header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.newsletter.heading",
      "default": "Subscribe to our newsletter"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.newsletter.heading_size",
      "options": [
        { "value": "h2", "label": "t:sections.newsletter.heading_large" },
        { "value": "h3", "label": "t:sections.newsletter.heading_medium" },
        { "value": "h4", "label": "t:sections.newsletter.heading_small" }
      ],
      "default": "h2"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "t:sections.newsletter.subheading"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.newsletter.button_label",
      "default": "Subscribe"
    },
    {
      "type": "richtext",
      "id": "disclaimer",
      "label": "t:sections.newsletter.disclaimer",
      "info": "t:sections.newsletter.disclaimer_info"
    },
    {
      "type": "header",
      "content": "t:sections.newsletter.layout_header"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "t:sections.newsletter.layout",
      "options": [
        { "value": "centered", "label": "t:sections.newsletter.layout_centered" },
        { "value": "split", "label": "t:sections.newsletter.layout_split" }
      ],
      "default": "centered"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "t:sections.newsletter.background_image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "t:sections.newsletter.overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 40
    },
    {
      "type": "header",
      "content": "t:sections.newsletter.style_header"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.newsletter.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.newsletter.padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.newsletter.padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "t:sections.newsletter.preset_name"
    }
  ]
}
{% endschema %}
