{%- comment -%}
  Video — Shopify hosted or YouTube/Vimeo embed
  Supports: autoplay (muted), poster image, play button overlay,
  full-width or contained, multiple aspect ratios
{%- endcomment -%}

{{ 'section-video.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign heading = section.settings.heading
  assign heading_size = section.settings.heading_size
  assign video = section.settings.video
  assign external_url = section.settings.external_video_url
  assign poster = section.settings.cover_image
  assign autoplay = section.settings.autoplay
  assign show_controls = section.settings.show_controls
  assign video_ratio = section.settings.video_ratio
  assign full_width = section.settings.full_width
  assign alt_text = section.settings.description | default: heading
  assign color_scheme = section.settings.color_scheme
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom

  assign has_video = false
  assign has_external = false

  if video != blank
    assign has_video = true
  endif

  if external_url != blank
    assign has_external = true
  endif

  assign is_youtube = false
  assign is_vimeo = false
  if has_external
    if external_url.type == 'youtube'
      assign is_youtube = true
    elsif external_url.type == 'vimeo'
      assign is_vimeo = true
    endif
  endif
-%}

{%- style -%}
  #Section-{{ section.id }} {
    --section-padding-top: {{ padding_top }}px;
    --section-padding-bottom: {{ padding_bottom }}px;
  }
{%- endstyle -%}

<div
  id="Section-{{ section.id }}"
  class="video-section color-{{ color_scheme }} full-width"
>
  <div class="{% if full_width %}video-section--full-width{% else %}container{% endif %}">
    {%- if heading != blank -%}
      <{{ heading_size }} class="video-section__heading">{{ heading }}</{{ heading_size }}>
    {%- endif -%}

    <video-player
      class="video-section__player video-section__player--{{ video_ratio }}"
      data-autoplay="{{ autoplay }}"
    >
      {%- if has_video -%}
        {%- comment -%} Shopify-hosted video {%- endcomment -%}
        <div class="video-section__media">
          {{ video | video_tag:
            autoplay: autoplay,
            muted: autoplay,
            loop: autoplay,
            controls: show_controls,
            playsinline: true,
            preload: 'metadata',
            image_size: '2000x',
            class: 'video-section__video',
            alt: alt_text
          }}
          {%- if poster != blank and autoplay == false -%}
            <div class="video-section__poster" data-poster>
              {{ poster | image_url: width: 2000 | image_tag:
                loading: 'lazy',
                widths: '750,1000,1500,2000',
                sizes: '100vw',
                class: 'video-section__poster-img',
                alt: alt_text
              }}
              <button class="video-section__play-btn" type="button" aria-label="{{ 'accessibility.play_video' | t }}">
                {%- render 'icon', name: 'play', size: 48 -%}
              </button>
            </div>
          {%- endif -%}
        </div>

      {%- elsif has_external -%}
        {%- comment -%} External YouTube/Vimeo {%- endcomment -%}
        <div class="video-section__media video-section__media--external">
          {%- if poster != blank and autoplay == false -%}
            <div class="video-section__poster" data-poster>
              {{ poster | image_url: width: 2000 | image_tag:
                loading: 'lazy',
                widths: '750,1000,1500,2000',
                sizes: '100vw',
                class: 'video-section__poster-img',
                alt: alt_text
              }}
              <button class="video-section__play-btn" type="button" aria-label="{{ 'accessibility.play_video' | t }}" data-video-url="{{ external_url }}">
                {%- render 'icon', name: 'play', size: 48 -%}
              </button>
            </div>
          {%- else -%}
            <div class="video-section__iframe-wrap" data-iframe-wrap>
              {%- if is_youtube -%}
                <iframe
                  src="https://www.youtube.com/embed/{{ external_url.id }}?autoplay={{ autoplay | default: 0 }}&mute={{ autoplay | default: 0 }}&loop={{ autoplay | default: 0 }}&controls={{ show_controls | default: 1 }}&rel=0&modestbranding=1&playsinline=1"
                  allow="autoplay; encrypted-media"
                  allowfullscreen
                  loading="lazy"
                  title="{{ alt_text }}"
                  class="video-section__iframe"
                ></iframe>
              {%- elsif is_vimeo -%}
                <iframe
                  src="https://player.vimeo.com/video/{{ external_url.id }}?autoplay={{ autoplay | default: 0 }}&muted={{ autoplay | default: 0 }}&loop={{ autoplay | default: 0 }}&controls={{ show_controls | default: 1 }}&playsinline=1"
                  allow="autoplay; encrypted-media"
                  allowfullscreen
                  loading="lazy"
                  title="{{ alt_text }}"
                  class="video-section__iframe"
                ></iframe>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>

      {%- else -%}
        {%- comment -%} Placeholder {%- endcomment -%}
        <div class="video-section__media video-section__placeholder">
          {{ 'lifestyle-1' | placeholder_svg_tag: 'video-section__placeholder-svg' }}
          <div class="video-section__play-btn video-section__play-btn--disabled" aria-hidden="true">
            {%- render 'icon', name: 'play', size: 48 -%}
          </div>
        </div>
      {%- endif -%}
    </video-player>
  </div>
</div>

<script src="{{ 'section-video.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "t:sections.video.name",
  "tag": "section",
  "class": "section-video",
  "disabled_on": {
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.video.content_header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.video.heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.video.heading_size",
      "options": [
        { "value": "h2", "label": "t:sections.video.heading_large" },
        { "value": "h3", "label": "t:sections.video.heading_medium" },
        { "value": "h4", "label": "t:sections.video.heading_small" }
      ],
      "default": "h2"
    },
    {
      "type": "header",
      "content": "t:sections.video.video_header"
    },
    {
      "type": "video",
      "id": "video",
      "label": "t:sections.video.video",
      "info": "t:sections.video.video_info"
    },
    {
      "type": "video_url",
      "id": "external_video_url",
      "accept": ["youtube", "vimeo"],
      "label": "t:sections.video.external_video_url",
      "info": "t:sections.video.external_video_url_info",
      "default": "https://www.youtube.com/watch?v=_9VUPq3SxOc"
    },
    {
      "type": "image_picker",
      "id": "cover_image",
      "label": "t:sections.video.cover_image",
      "info": "t:sections.video.cover_image_info"
    },
    {
      "type": "text",
      "id": "description",
      "label": "t:sections.video.description",
      "info": "t:sections.video.description_info"
    },
    {
      "type": "header",
      "content": "t:sections.video.playback_header"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "t:sections.video.autoplay",
      "info": "t:sections.video.autoplay_info",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_controls",
      "label": "t:sections.video.show_controls",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.video.layout_header"
    },
    {
      "type": "select",
      "id": "video_ratio",
      "label": "t:sections.video.video_ratio",
      "options": [
        { "value": "auto", "label": "t:sections.video.ratio_auto" },
        { "value": "16-9", "label": "16:9" },
        { "value": "21-9", "label": "21:9 (Cinematic)" },
        { "value": "4-3", "label": "4:3" },
        { "value": "1-1", "label": "1:1" }
      ],
      "default": "16-9"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "t:sections.video.full_width",
      "default": false
    },
    {
      "type": "header",
      "content": "t:sections.video.style_header"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.video.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.video.padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.video.padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "t:sections.video.preset_name"
    }
  ]
}
{% endschema %}
