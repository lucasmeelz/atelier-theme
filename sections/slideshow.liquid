{%- comment -%}
  Slideshow — Full-width image slider with content overlays
  Supports: fade/slide transitions, autoplay, touch swipe, mobile images
{%- endcomment -%}

{{ 'section-slideshow.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign transition = section.settings.transition_effect
  assign autoplay = section.settings.autoplay
  assign autoplay_speed = section.settings.autoplay_speed
  assign show_arrows = section.settings.show_arrows
  assign show_dots = section.settings.show_dots
  assign show_counter = section.settings.show_counter
  assign height = section.settings.height
  assign height_mobile = section.settings.height_mobile
  assign overlay_opacity = section.settings.overlay_opacity
  assign overlay_color = section.settings.overlay_color
  assign content_width = section.settings.content_width
-%}

{%- style -%}
  #Section-{{ section.id }} {
    --slideshow-height: {% case height %}{% when 'full' %}100vh{% when 'large' %}85vh{% when 'medium' %}70vh{% when 'small' %}50vh{% when 'x-small' %}40vh{% endcase %};
    --slideshow-height-mobile: {% case height_mobile %}{% when 'full' %}100svh{% when 'large' %}80svh{% when 'medium' %}60svh{% when 'small' %}45svh{% when 'auto' %}auto{% endcase %};
    --slideshow-overlay: {{ overlay_color.red }}, {{ overlay_color.green }}, {{ overlay_color.blue }};
    --slideshow-overlay-opacity: {{ overlay_opacity | divided_by: 100.0 }};
    --slideshow-content-width: {% case content_width %}{% when 'narrow' %}480px{% when 'medium' %}640px{% when 'wide' %}800px{% when 'full' %}100%{% endcase %};
  }
{%- endstyle -%}

<slideshow-section
  id="Section-{{ section.id }}"
  class="slideshow slideshow--{{ transition }}{% if autoplay %} slideshow--autoplay{% endif %}"
  data-autoplay="{{ autoplay }}"
  data-autoplay-speed="{{ autoplay_speed }}"
  data-transition="{{ transition }}"
  role="region"
  aria-roledescription="{{ 'slideshow.carousel' | t }}"
  aria-label="{{ section.settings.accessibility_label | default: '' }}{% if section.settings.accessibility_label == blank %}{{ 'slideshow.default_label' | t }}{% endif %}"
>
  <div class="slideshow__container">
    {%- for block in section.blocks -%}
      {%- liquid
        assign position = block.settings.content_position | default: 'center'
        assign alignment = block.settings.text_alignment | default: 'center'
        assign heading_size = block.settings.heading_size | default: 'h1'
      -%}
      <div
        class="slideshow__slide{% if forloop.first %} slideshow__slide--active{% endif %}"
        data-slide-index="{{ forloop.index0 }}"
        role="group"
        aria-roledescription="{{ 'slideshow.slide' | t }}"
        aria-label="{{ 'accessibility.slide_number' | t: number: forloop.index, total: section.blocks.size }}"
        {% unless forloop.first %}aria-hidden="true"{% endunless %}
        {{ block.shopify_attributes }}
      >
        {%- comment -%} Image {%- endcomment -%}
        <div class="slideshow__media">
          {%- if block.settings.image != blank -%}
            {%- if block.settings.image_mobile != blank -%}
              <picture>
                <source
                  media="(max-width: 749px)"
                  srcset="{{ block.settings.image_mobile | image_url: width: 750 }} 375w, {{ block.settings.image_mobile | image_url: width: 1500 }} 750w"
                  sizes="100vw"
                >
                {%- if forloop.first -%}
                  {{
                    block.settings.image
                    | image_url: width: 3000
                    | image_tag:
                      alt: block.settings.image.alt | default: block.settings.heading,
                      widths: '750, 1000, 1500, 2000, 3000',
                      loading: 'eager',
                      fetchpriority: 'high',
                      class: 'slideshow__image'
                  }}
                {%- else -%}
                  {{
                    block.settings.image
                    | image_url: width: 3000
                    | image_tag:
                      alt: block.settings.image.alt | default: block.settings.heading,
                      widths: '750, 1000, 1500, 2000, 3000',
                      loading: 'lazy',
                      fetchpriority: 'auto',
                      class: 'slideshow__image'
                  }}
                {%- endif -%}
              </picture>
            {%- else -%}
              {%- if forloop.first -%}
                {{
                  block.settings.image
                  | image_url: width: 3000
                  | image_tag:
                    alt: block.settings.image.alt | default: block.settings.heading,
                    widths: '375, 750, 1000, 1500, 2000, 3000',
                    loading: 'eager',
                    fetchpriority: 'high',
                    class: 'slideshow__image'
                }}
              {%- else -%}
                {{
                  block.settings.image
                  | image_url: width: 3000
                  | image_tag:
                    alt: block.settings.image.alt | default: block.settings.heading,
                    widths: '375, 750, 1000, 1500, 2000, 3000',
                    loading: 'lazy',
                    fetchpriority: 'auto',
                    class: 'slideshow__image'
                }}
              {%- endif -%}
            {%- endif -%}
          {%- else -%}
            <div class="slideshow__placeholder">
              {{ 'lifestyle-' | append: forloop.index | placeholder_svg_tag: 'slideshow__placeholder-svg' }}
            </div>
          {%- endif -%}
        </div>

        {%- comment -%} Overlay {%- endcomment -%}
        {%- if overlay_opacity > 0 -%}
          <div class="slideshow__overlay" aria-hidden="true"></div>
        {%- endif -%}

        {%- comment -%} Content {%- endcomment -%}
        {%- if block.settings.heading != blank or block.settings.text != blank or block.settings.button_label != blank -%}
          <div class="slideshow__content slideshow__content--{{ position }} slideshow__content--align-{{ alignment }}">
            <div class="slideshow__content-inner">
              {%- if block.settings.subheading != blank -%}
                <p class="slideshow__subheading label">{{ block.settings.subheading }}</p>
              {%- endif -%}
              {%- if block.settings.heading != blank -%}
                <{{ heading_size }} class="slideshow__heading slideshow__heading--{{ heading_size }}">
                  {{ block.settings.heading }}
                </{{ heading_size }}>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <p class="slideshow__text">{{ block.settings.text }}</p>
              {%- endif -%}
              {%- if block.settings.button_label != blank -%}
                <div class="slideshow__actions">
                  <a
                    href="{{ block.settings.button_link | default: '#' }}"
                    class="btn btn--{{ block.settings.button_style | default: 'outline-white' }}"
                  >
                    <span class="btn__label">{{ block.settings.button_label }}</span>
                    <span class="btn__fill" aria-hidden="true"></span>
                  </a>
                  {%- if block.settings.button_label_2 != blank -%}
                    <a
                      href="{{ block.settings.button_link_2 | default: '#' }}"
                      class="btn btn--{{ block.settings.button_style_2 | default: 'outline-white' }}"
                    >
                      <span class="btn__label">{{ block.settings.button_label_2 }}</span>
                      <span class="btn__fill" aria-hidden="true"></span>
                    </a>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    {%- comment -%} Arrows navigation {%- endcomment -%}
    {%- if show_arrows -%}
      <div class="slideshow__arrows">
        {%- comment -%} Intentional: white on dark image overlays {%- endcomment -%}
        <button class="slideshow__arrow slideshow__arrow--prev" aria-label="{{ 'accessibility.previous_slide' | t }}" data-prev>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
        </button>
        <button class="slideshow__arrow slideshow__arrow--next" aria-label="{{ 'accessibility.next_slide' | t }}" data-next>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </button>
      </div>
    {%- endif -%}

    {%- comment -%} Dots / Counter / Progress {%- endcomment -%}
    <div class="slideshow__controls">
      {%- if show_dots -%}
        <div class="slideshow__dots" role="tablist">
          {%- for block in section.blocks -%}
            <button
              class="slideshow__dot{% if forloop.first %} slideshow__dot--active{% endif %}"
              role="tab"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              aria-label="{{ 'accessibility.slide_number' | t: number: forloop.index, total: section.blocks.size }}"
              data-dot="{{ forloop.index0 }}"
            ></button>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- if show_counter -%}
        <div class="slideshow__counter" aria-hidden="true">
          <span class="slideshow__counter-current">01</span>
          <span class="slideshow__counter-sep">/</span>
          <span class="slideshow__counter-total">{{ section.blocks.size | prepend: '00' | slice: -2, 2 }}</span>
        </div>
      {%- endif -%}

      {%- if autoplay -%}
        <div class="slideshow__progress motion-auto" aria-hidden="true">
          <div class="slideshow__progress-fill" data-progress></div>
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}
</slideshow-section>

<script>
  /* Slideshow Section — Web Component */
  if (!customElements.get('slideshow-section')) {
    class SlideshowSection extends HTMLElement {
      constructor() {
        super();
        this.slides = [];
        this.dots = [];
        this.currentIndex = 0;
        this.isTransitioning = false;
        this.autoplayTimer = null;
        this.progressTimer = null;
        this.touchStartX = 0;
        this.touchStartY = 0;
      }

      connectedCallback() {
        this.slides = Array.from(this.querySelectorAll('.slideshow__slide'));
        this.dots = Array.from(this.querySelectorAll('.slideshow__dot'));
        this.counter = this.querySelector('.slideshow__counter-current');
        this.progressFill = this.querySelector('[data-progress]');
        this.transition = this.dataset.transition || 'fade';
        this.autoplayEnabled = this.dataset.autoplay === 'true';
        this.autoplaySpeed = parseInt(this.dataset.autoplaySpeed, 10) || 5000;

        if (this.slides.length < 2) return;

        this._bindEvents();
        if (this.autoplayEnabled) this._startAutoplay();
      }

      disconnectedCallback() {
        this._stopAutoplay();
        this._unbindEvents();
      }

      _bindEvents() {
        var prevBtn = this.querySelector('[data-prev]');
        var nextBtn = this.querySelector('[data-next]');

        this._onPrev = function() { this.prev(); }.bind(this);
        this._onNext = function() { this.next(); }.bind(this);

        if (prevBtn) prevBtn.addEventListener('click', this._onPrev);
        if (nextBtn) nextBtn.addEventListener('click', this._onNext);

        /* Dots — event delegation */
        this._onDotClick = function(e) {
          var dot = e.target.closest('.slideshow__dot');
          if (!dot) return;
          this.goTo(parseInt(dot.dataset.dot, 10));
        }.bind(this);

        var dotsContainer = this.querySelector('.slideshow__dots');
        if (dotsContainer) dotsContainer.addEventListener('click', this._onDotClick);

        /* Keyboard navigation */
        this._onKeydown = function(e) {
          if (e.key === 'ArrowLeft') this.prev();
          else if (e.key === 'ArrowRight') this.next();
        }.bind(this);
        this.addEventListener('keydown', this._onKeydown);

        /* Touch swipe */
        this._onTouchStart = function(e) {
          this.touchStartX = e.touches[0].clientX;
          this.touchStartY = e.touches[0].clientY;
        }.bind(this);

        this._onTouchEnd = function(e) {
          var deltaX = e.changedTouches[0].clientX - this.touchStartX;
          var deltaY = e.changedTouches[0].clientY - this.touchStartY;
          if (Math.abs(deltaX) > Math.abs(deltaY) && Math.abs(deltaX) > 50) {
            if (deltaX < 0) this.next();
            else this.prev();
          }
        }.bind(this);

        this.addEventListener('touchstart', this._onTouchStart, { passive: true });
        this.addEventListener('touchend', this._onTouchEnd, { passive: true });

        /* Pause autoplay on hover and focus */
        this._onPause = function() { this._stopAutoplay(); }.bind(this);
        this._onResume = function() { if (this.autoplayEnabled) this._startAutoplay(); }.bind(this);

        this.addEventListener('mouseenter', this._onPause);
        this.addEventListener('mouseleave', this._onResume);
        this.addEventListener('focusin', this._onPause);
        this.addEventListener('focusout', this._onResume);
      }

      _unbindEvents() {
        var prevBtn = this.querySelector('[data-prev]');
        var nextBtn = this.querySelector('[data-next]');
        if (prevBtn) prevBtn.removeEventListener('click', this._onPrev);
        if (nextBtn) nextBtn.removeEventListener('click', this._onNext);
        var dotsContainer = this.querySelector('.slideshow__dots');
        if (dotsContainer) dotsContainer.removeEventListener('click', this._onDotClick);
        this.removeEventListener('keydown', this._onKeydown);
        this.removeEventListener('touchstart', this._onTouchStart);
        this.removeEventListener('touchend', this._onTouchEnd);
        this.removeEventListener('mouseenter', this._onPause);
        this.removeEventListener('mouseleave', this._onResume);
        this.removeEventListener('focusin', this._onPause);
        this.removeEventListener('focusout', this._onResume);
      }

      prev() { this.goTo((this.currentIndex - 1 + this.slides.length) % this.slides.length); }
      next() { this.goTo((this.currentIndex + 1) % this.slides.length); }

      goTo(index) {
        if (index === this.currentIndex || this.isTransitioning) return;
        this.isTransitioning = true;

        var prev = this.slides[this.currentIndex];
        var next = this.slides[index];
        var direction = index > this.currentIndex ? 1 : -1;

        /* Update ARIA states */
        prev.setAttribute('aria-hidden', 'true');
        next.removeAttribute('aria-hidden');

        if (this.transition === 'slide') {
          next.classList.add('slideshow__slide--entering');
          next.style.transform = 'translateX(' + (direction * 100) + '%)';
          next.classList.add('slideshow__slide--active');

          requestAnimationFrame(function() {
            requestAnimationFrame(function() {
              prev.style.transform = 'translateX(' + (-direction * 100) + '%)';
              next.style.transform = 'translateX(0)';

              var onEnd = function() {
                prev.removeEventListener('transitionend', onEnd);
                prev.classList.remove('slideshow__slide--active');
                prev.style.transform = '';
                next.classList.remove('slideshow__slide--entering');
                this.isTransitioning = false;
              }.bind(this);

              prev.addEventListener('transitionend', onEnd);
              /* Safety timeout in case transitionend does not fire */
              setTimeout(function() { this.isTransitioning = false; }.bind(this), 800);
            }.bind(this));
          }.bind(this));
        } else {
          /* Fade transition */
          next.classList.add('slideshow__slide--active');
          var onEnd = function() {
            prev.removeEventListener('transitionend', onEnd);
            prev.classList.remove('slideshow__slide--active');
            this.isTransitioning = false;
          }.bind(this);
          prev.addEventListener('transitionend', onEnd);
          /* Safety timeout in case transitionend does not fire */
          setTimeout(function() { this.isTransitioning = false; }.bind(this), 800);
        }

        /* Update dot indicators */
        this.dots.forEach(function(dot, i) {
          dot.classList.toggle('slideshow__dot--active', i === index);
          dot.setAttribute('aria-selected', i === index ? 'true' : 'false');
        });

        /* Update counter display */
        if (this.counter) {
          this.counter.textContent = String(index + 1).padStart(2, '0');
        }

        this.currentIndex = index;

        /* Reset autoplay timer and progress bar */
        if (this.autoplayEnabled) {
          this._stopAutoplay();
          this._startAutoplay();
        }
      }

      _startAutoplay() {
        this._stopAutoplay();
        this._startProgress();
        this.autoplayTimer = setInterval(function() {
          this.next();
        }.bind(this), this.autoplaySpeed);
      }

      _stopAutoplay() {
        if (this.autoplayTimer) { clearInterval(this.autoplayTimer); this.autoplayTimer = null; }
        if (this.progressFill) {
          this.progressFill.style.transition = 'none';
          this.progressFill.style.width = '0%';
        }
      }

      _startProgress() {
        if (!this.progressFill) return;
        this.progressFill.style.transition = 'none';
        this.progressFill.style.width = '0%';
        requestAnimationFrame(function() {
          this.progressFill.style.transition = 'width ' + this.autoplaySpeed + 'ms linear';
          this.progressFill.style.width = '100%';
        }.bind(this));
      }
    }

    customElements.define('slideshow-section', SlideshowSection);
  }

  /* Shopify theme editor events */
  document.addEventListener('shopify:section:load', function(e) {
    var el = e.target.querySelector('slideshow-section');
    if (el) el.connectedCallback();
  });

  document.addEventListener('shopify:section:unload', function(e) {
    var el = e.target.querySelector('slideshow-section');
    if (el) el.disconnectedCallback();
  });

  document.addEventListener('shopify:block:select', function(e) {
    var slideshow = e.target.closest('slideshow-section');
    if (!slideshow) return;
    var slide = e.target.closest('.slideshow__slide');
    if (!slide) return;
    var index = parseInt(slide.dataset.slideIndex, 10);
    slideshow.autoplayEnabled = false;
    slideshow._stopAutoplay();
    slideshow.goTo(index);
  });
</script>

{% schema %}
{
  "name": "t:sections.slideshow.name",
  "tag": "section",
  "class": "section-slideshow",
  "max_blocks": 8,
  "disabled_on": {
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.slideshow.layout_header"
    },
    {
      "type": "select",
      "id": "height",
      "label": "t:sections.slideshow.height",
      "options": [
        { "value": "full", "label": "t:sections.slideshow.height_full" },
        { "value": "large", "label": "t:sections.slideshow.height_large" },
        { "value": "medium", "label": "t:sections.slideshow.height_medium" },
        { "value": "small", "label": "t:sections.slideshow.height_small" },
        { "value": "x-small", "label": "t:sections.slideshow.height_x_small" }
      ],
      "default": "large"
    },
    {
      "type": "select",
      "id": "height_mobile",
      "label": "t:sections.slideshow.height_mobile",
      "options": [
        { "value": "full", "label": "t:sections.slideshow.height_full" },
        { "value": "large", "label": "t:sections.slideshow.height_large" },
        { "value": "medium", "label": "t:sections.slideshow.height_medium" },
        { "value": "small", "label": "t:sections.slideshow.height_small" },
        { "value": "auto", "label": "t:sections.slideshow.height_auto" }
      ],
      "default": "medium"
    },
    {
      "type": "select",
      "id": "content_width",
      "label": "t:sections.slideshow.content_width",
      "options": [
        { "value": "narrow", "label": "t:sections.slideshow.content_narrow" },
        { "value": "medium", "label": "t:sections.slideshow.content_medium" },
        { "value": "wide", "label": "t:sections.slideshow.content_wide" },
        { "value": "full", "label": "t:sections.slideshow.content_full" }
      ],
      "default": "medium"
    },
    {
      "type": "header",
      "content": "t:sections.slideshow.transition_header"
    },
    {
      "type": "select",
      "id": "transition_effect",
      "label": "t:sections.slideshow.transition_effect",
      "options": [
        { "value": "fade", "label": "t:sections.slideshow.transition_fade" },
        { "value": "slide", "label": "t:sections.slideshow.transition_slide" }
      ],
      "default": "fade"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "t:sections.slideshow.autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "t:sections.slideshow.autoplay_speed",
      "min": 3000,
      "max": 8000,
      "step": 500,
      "unit": "ms",
      "default": 5000
    },
    {
      "type": "header",
      "content": "t:sections.slideshow.navigation_header"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "t:sections.slideshow.show_arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "t:sections.slideshow.show_dots",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_counter",
      "label": "t:sections.slideshow.show_counter",
      "default": false
    },
    {
      "type": "header",
      "content": "t:sections.slideshow.overlay_header"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "t:sections.slideshow.overlay_color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "t:sections.slideshow.overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "text",
      "id": "accessibility_label",
      "label": "t:sections.slideshow.accessibility_label",
      "info": "t:sections.slideshow.accessibility_label_info"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "t:sections.slideshow.block_slide",
      "limit": 8,
      "settings": [
        {
          "type": "header",
          "content": "t:sections.slideshow.media_header"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.slideshow.slide_image"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "t:sections.slideshow.slide_image_mobile",
          "info": "t:sections.slideshow.slide_image_mobile_info"
        },
        {
          "type": "header",
          "content": "t:sections.slideshow.content_header"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "t:sections.slideshow.slide_subheading"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.slideshow.slide_heading",
          "default": "Slide heading"
        },
        {
          "type": "select",
          "id": "heading_size",
          "label": "t:sections.slideshow.slide_heading_size",
          "options": [
            { "value": "h1", "label": "t:sections.slideshow.heading_h1" },
            { "value": "h2", "label": "t:sections.slideshow.heading_h2" },
            { "value": "h3", "label": "t:sections.slideshow.heading_h3" }
          ],
          "default": "h1"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "t:sections.slideshow.slide_text"
        },
        {
          "type": "select",
          "id": "content_position",
          "label": "t:sections.slideshow.content_position",
          "options": [
            { "value": "top-left", "label": "t:sections.slideshow.position_top_left" },
            { "value": "top-center", "label": "t:sections.slideshow.position_top_center" },
            { "value": "top-right", "label": "t:sections.slideshow.position_top_right" },
            { "value": "center-left", "label": "t:sections.slideshow.position_center_left" },
            { "value": "center", "label": "t:sections.slideshow.position_center" },
            { "value": "center-right", "label": "t:sections.slideshow.position_center_right" },
