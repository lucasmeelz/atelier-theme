{%- comment -%}
  Atelier Process — Horizontal scroll storytelling
  Each step = image + number + heading + text, scrolls horizontally
  Desktop: prev/next buttons, mobile: swipe with scroll-snap
{%- endcomment -%}

{{ 'section-atelier-process.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign show_step_numbers = section.settings.show_step_numbers
  assign color_scheme = section.settings.color_scheme
-%}

<div
  id="Section-{{ section.id }}"
  class="atelier-process section-spacing color-{{ color_scheme }}"
  data-section-id="{{ section.id }}"
>
  {%- if heading != blank or subheading != blank -%}
    <div class="container atelier-process__header">
      {%- if subheading != blank -%}
        <p class="atelier-process__subheading subheading">{{ subheading }}</p>
      {%- endif -%}
      {%- if heading != blank -%}
        <h2 class="atelier-process__heading h2">{{ heading }}</h2>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="atelier-process__track" id="atelier-track-{{ section.id }}">
    {%- for block in section.blocks -%}
      <div class="atelier-process__step" {{ block.shopify_attributes }}>
        <div class="atelier-process__image-wrap">
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 1440
              | image_tag:
                alt: block.settings.image.alt | default: block.settings.heading,
                widths: '375, 750, 1000, 1440',
                loading: 'lazy',
                class: 'atelier-process__image'
            }}
          {%- else -%}
            {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'atelier-process__image placeholder-svg' }}
          {%- endif -%}

          {%- if show_step_numbers -%}
            <span class="atelier-process__number" aria-hidden="true">
              {{- block.settings.custom_number | default: forloop.index -}}
            </span>
          {%- endif -%}
        </div>

        <div class="atelier-process__content">
          {%- if block.settings.heading != blank -%}
            <h3 class="atelier-process__step-heading">{{ block.settings.heading }}</h3>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <p class="atelier-process__step-text">{{ block.settings.text }}</p>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    <div class="atelier-process__nav container">
      <button class="atelier-process__nav-btn" data-prev aria-label="{{ 'accessibility.previous' | t }}" disabled>
        {%- render 'icon', name: 'chevron-left', size: 16 -%}
      </button>

      <div class="atelier-process__progress">
        <div class="atelier-process__progress-fill" style="width: {{ 100.0 | divided_by: section.blocks.size }}%;"></div>
      </div>

      <button class="atelier-process__nav-btn" data-next aria-label="{{ 'accessibility.next' | t }}">
        {%- render 'icon', name: 'chevron-right', size: 16 -%}
      </button>
    </div>
  {%- endif -%}
</div>

<script>
  if (!customElements.get('atelier-scroller')) {
    class AtelierScroller extends HTMLElement {
      connectedCallback() {
        this.track = this.querySelector('.atelier-process__track');
        if (!this.track) return;

        this.steps = Array.from(this.track.querySelectorAll('.atelier-process__step'));
        this.prevBtn = this.querySelector('[data-prev]');
        this.nextBtn = this.querySelector('[data-next]');
        this.progressFill = this.querySelector('.atelier-process__progress-fill');
        this.currentIndex = 0;

        this._onScroll = this._debounce(this._updateState.bind(this), 100);
        this.track.addEventListener('scroll', this._onScroll, { passive: true });

        if (this.prevBtn) this.prevBtn.addEventListener('click', this._goToPrev.bind(this));
        if (this.nextBtn) this.nextBtn.addEventListener('click', this._goToNext.bind(this));
      }

      disconnectedCallback() {
        if (this.track) this.track.removeEventListener('scroll', this._onScroll);
      }

      _goToPrev() {
        if (this.currentIndex > 0) this._scrollTo(this.currentIndex - 1);
      }

      _goToNext() {
        if (this.currentIndex < this.steps.length - 1) this._scrollTo(this.currentIndex + 1);
      }

      _scrollTo(index) {
        var step = this.steps[index];
        if (!step) return;
        var trackRect = this.track.getBoundingClientRect();
        var stepRect = step.getBoundingClientRect();
        var offset = stepRect.left - trackRect.left + this.track.scrollLeft;
        var center = offset - (trackRect.width - stepRect.width) / 2;
        this.track.scrollTo({ left: center, behavior: 'smooth' });
      }

      _updateState() {
        var trackRect = this.track.getBoundingClientRect();
        var trackCenter = trackRect.left + trackRect.width / 2;
        var closest = 0;
        var closestDist = Infinity;

        this.steps.forEach(function(step, i) {
          var rect = step.getBoundingClientRect();
          var dist = Math.abs(rect.left + rect.width / 2 - trackCenter);
          if (dist < closestDist) {
            closestDist = dist;
            closest = i;
          }
        });

        this.currentIndex = closest;

        if (this.prevBtn) this.prevBtn.disabled = closest === 0;
        if (this.nextBtn) this.nextBtn.disabled = closest === this.steps.length - 1;

        if (this.progressFill) {
          var progress = ((closest + 1) / this.steps.length) * 100;
          this.progressFill.style.width = progress + '%';
        }
      }

      _debounce(fn, wait) {
        var timer;
        return function() {
          clearTimeout(timer);
          timer = setTimeout(fn, wait);
        };
      }
    }

    customElements.define('atelier-scroller', AtelierScroller);
  }

  /* Wrap section in custom element */
  (function() {
    var section = document.querySelector('#Section-{{ section.id }}');
    if (section && !section.closest('atelier-scroller')) {
      var wrapper = document.createElement('atelier-scroller');
      section.parentNode.insertBefore(wrapper, section);
      wrapper.appendChild(section);
    }
  })();
</script>

{% schema %}
{
  "name": "t:sections.atelier_process.name",
  "tag": "section",
  "class": "section-atelier-process",
  "disabled_on": {
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.atelier_process.heading",
      "default": "Our process"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.atelier_process.subheading",
      "default": "Craftsmanship"
    },
    {
      "type": "checkbox",
      "id": "show_step_numbers",
      "label": "t:sections.atelier_process.show_step_numbers",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.atelier_process.color_scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "t:sections.atelier_process.block_step",
      "limit": 8,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.atelier_process.step_image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.atelier_process.step_heading",
          "default": "Step heading"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "t:sections.atelier_process.step_text",
          "default": "Describe this step of your process."
        },
        {
          "type": "text",
          "id": "custom_number",
          "label": "t:sections.atelier_process.custom_number",
          "info": "t:sections.atelier_process.custom_number_info"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.atelier_process.preset_name",
      "blocks": [
        { "type": "step", "settings": { "heading": "Source", "text": "We carefully select the finest raw materials from trusted artisans." } },
        { "type": "step", "settings": { "heading": "Craft", "text": "Each piece is handcrafted with meticulous attention to detail." } },
        { "type": "step", "settings": { "heading": "Refine", "text": "Multiple rounds of quality control ensure perfection." } },
        { "type": "step", "settings": { "heading": "Deliver", "text": "Beautifully packaged and shipped with care." } }
      ]
    }
  ]
}
{% endschema %}
