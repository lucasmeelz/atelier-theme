{%- comment -%}
  Recently Viewed Products — Shows products the customer has browsed
  Uses localStorage to track viewed product handles, renders via Section Rendering API
{%- endcomment -%}

{{ 'section-recently-viewed.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign heading = section.settings.heading
  assign heading_size = section.settings.heading_size
  assign products_to_show = section.settings.products_to_show
  assign columns_desktop = section.settings.columns_desktop
  assign image_ratio = section.settings.image_ratio
  assign show_secondary_image = section.settings.show_secondary_image
  assign show_vendor = section.settings.show_vendor
  assign color_scheme = section.settings.color_scheme
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
-%}

{%- style -%}
  #Section-{{ section.id }} {
    --section-padding-top: {{ padding_top }}px;
    --section-padding-bottom: {{ padding_bottom }}px;
  }
{%- endstyle -%}

<div
  id="Section-{{ section.id }}"
  class="recently-viewed color-{{ color_scheme }}"
  data-section-id="{{ section.id }}"
  data-products-to-show="{{ products_to_show }}"
  data-columns="{{ columns_desktop }}"
  style="display: none;"
>
  <div class="container">
    {%- if heading != blank -%}
      <div class="recently-viewed__header">
        <{{ heading_size }} class="recently-viewed__heading">{{ heading }}</{{ heading_size }}>
      </div>
    {%- endif -%}

    <div
      class="recently-viewed__grid"
      style="--rv-columns: {{ columns_desktop }};"
      data-recently-viewed-grid
    >
      {%- comment -%} Products injected by JS {%- endcomment -%}
    </div>
  </div>
</div>

<script>
  (function() {
    var STORAGE_KEY = 'ecrin:recently-viewed';
    var MAX_STORED = 20;
    var section = document.getElementById('Section-{{ section.id }}');
    if (!section) return;

    var productsToShow = parseInt(section.dataset.productsToShow, 10) || 4;
    var grid = section.querySelector('[data-recently-viewed-grid]');

    /* Track current product page */
    {%- if request.page_type == 'product' -%}
      try {
        var stored = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
        var currentHandle = '{{ product.handle }}';
        stored = stored.filter(function(h) { return h !== currentHandle; });
        stored.unshift(currentHandle);
        if (stored.length > MAX_STORED) stored = stored.slice(0, MAX_STORED);
        localStorage.setItem(STORAGE_KEY, JSON.stringify(stored));
      } catch(e) {}
    {%- endif -%}

    /* Render recently viewed products */
    try {
      var handles = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');

      {%- if request.page_type == 'product' -%}
        handles = handles.filter(function(h) { return h !== '{{ product.handle }}'; });
      {%- endif -%}

      handles = handles.slice(0, productsToShow);

      if (handles.length === 0) return;

      section.style.display = '';

      function formatMoney(cents, format) {
        var amount = (cents / 100).toFixed(2);
        return format.replace(/\{\{\s*amount\s*\}\}/, amount)
                     .replace(/\{\{\s*amount_no_decimals\s*\}\}/, Math.round(cents / 100))
                     .replace(/\{\{\s*amount_with_comma_separator\s*\}\}/, amount.replace('.', ','))
                     .replace(/\{\{\s*amount_no_decimals_with_comma_separator\s*\}\}/, Math.round(cents / 100));
      }

      var imageRatio = '{{ image_ratio }}';
      var showSecondary = {{ show_secondary_image | json }};
      var showVendor = {{ show_vendor | json }};
      var columns = parseInt(section.dataset.columns, 10) || 4;
      var moneyFormat = {{ shop.money_format | json }};

      /* Fetch each product and render a card */
      var fragment = document.createDocumentFragment();
      var loaded = 0;

      handles.forEach(function(handle, index) {
        fetch('/products/' + handle + '.js')
          .then(function(r) { return r.json(); })
          .then(function(product) {
            var item = document.createElement('div');
            item.className = 'recently-viewed__item';

            var image = product.featured_image;
            var price = formatMoney(product.price, moneyFormat);
            var comparePrice = product.compare_at_price ? formatMoney(product.compare_at_price, moneyFormat) : null;
            var available = product.available;

            var ratioClass = '';
            if (imageRatio === 'portrait') ratioClass = 'style="--card-image-ratio: 3 / 4;"';
            else if (imageRatio === 'square') ratioClass = 'style="--card-image-ratio: 1 / 1;"';
            else if (imageRatio === 'landscape') ratioClass = 'style="--card-image-ratio: 4 / 3;"';

            var html = '<div class="card-product">';
            html += '<div class="card-product__media">';
            html += '<a href="/products/' + handle + '" class="card-product__media-link" aria-label="' + product.title + '" tabindex="-1">';
            html += '<div class="card-product__media-wrapper" ' + ratioClass + '>';
            if (image) {
              html += '<img src="' + image + '" alt="' + product.title + '" class="card-product__image card-product__image--primary" loading="lazy" width="400" height="400">';
              if (showSecondary && product.images && product.images.length > 1) {
                html += '<img src="' + product.images[1] + '" alt="" class="card-product__image card-product__image--secondary" loading="lazy" width="400" height="400">';
              }
            }
            html += '</div></a>';

            /* Badges */
            if (!available) {
              html += '<div class="card-product__badges"><span class="card-product__badge card-product__badge--sold-out">{{ "product.sold_out" | t }}</span></div>';
            } else if (comparePrice) {
              html += '<div class="card-product__badges"><span class="card-product__badge card-product__badge--sale">{{ "product.sale" | t }}</span></div>';
            }

            html += '</div>'; /* close media */

            /* Info */
            html += '<div class="card-product__info">';
            html += '<h3 class="card-product__title"><a href="/products/' + handle + '">' + product.title + '</a></h3>';
            if (showVendor && product.vendor) {
              html += '<p class="card-product__vendor">' + product.vendor + '</p>';
            }
            html += '<div class="card-product__price">';
            if (comparePrice) {
              html += '<s class="card-product__price-compare">' + comparePrice + '</s> ';
            }
            html += '<span>' + price + '</span>';
            html += '</div>';
            html += '</div>'; /* close info */
            html += '</div>'; /* close card */

            item.innerHTML = html;
            item.dataset.index = index;
            grid.appendChild(item);

            loaded++;
          })
          .catch(function() {
            loaded++;
          });
      });
    } catch(e) {}
  })();
</script>

{% schema %}
{
  "name": "t:sections.recently_viewed.name",
  "tag": "section",
  "class": "section-recently-viewed",
  "disabled_on": {
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.recently_viewed.heading",
      "default": "Recently viewed"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.recently_viewed.heading_size",
      "options": [
        { "value": "h2", "label": "t:sections.recently_viewed.heading_large" },
        { "value": "h3", "label": "t:sections.recently_viewed.heading_medium" }
      ],
      "default": "h2"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "t:sections.recently_viewed.products_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "t:sections.recently_viewed.columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "t:sections.recently_viewed.image_ratio",
      "options": [
        { "value": "natural", "label": "t:sections.recently_viewed.natural" },
        { "value": "portrait", "label": "t:sections.recently_viewed.portrait" },
        { "value": "square", "label": "t:sections.recently_viewed.square" },
        { "value": "landscape", "label": "t:sections.recently_viewed.landscape" }
      ],
      "default": "portrait"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "label": "t:sections.recently_viewed.show_secondary",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "t:sections.recently_viewed.show_vendor",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.recently_viewed.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.recently_viewed.padding_top",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.recently_viewed.padding_bottom",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "t:sections.recently_viewed.preset_name"
    }
  ]
}
{% endschema %}
