{%- comment -%}
  Recently Viewed Products — Shows products the customer has browsed
  Uses localStorage to track viewed product handles, renders via Section Rendering API
{%- endcomment -%}

{{ 'section-recently-viewed.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{%- if settings.product_card_enable_carousel -%}
  <script src="{{ 'component-card-carousel.js' | asset_url }}" defer="defer"></script>
{%- endif -%}
{%- if section.settings.show_quick_add -%}
  {{ 'component-quick-view.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'component-quick-view.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- liquid
  assign heading = section.settings.heading
  assign heading_size = section.settings.heading_size
  assign products_to_show = section.settings.products_to_show
  assign columns_desktop = section.settings.columns_desktop
  assign image_ratio = section.settings.image_ratio
  assign show_secondary_image = section.settings.show_secondary_image
  assign show_vendor = section.settings.show_vendor
  assign show_rating = section.settings.show_rating
  assign show_quick_add = section.settings.show_quick_add
  assign show_color_swatches = section.settings.show_color_swatches
  assign color_scheme = section.settings.color_scheme
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
-%}

{%- style -%}
  #Section-{{ section.id }} {
    --section-padding-top: {{ padding_top }}px;
    --section-padding-bottom: {{ padding_bottom }}px;
  }
{%- endstyle -%}

{%- comment -%} Card template for Section Rendering API — renders a single product card when fetched on a product URL {%- endcomment -%}
<template data-recently-viewed-card>
  {%- if product -%}
    <div class="recently-viewed__item">
      {%- render 'card-product',
        product: product,
        image_ratio: image_ratio,
        show_secondary_image: show_secondary_image,
        show_vendor: show_vendor,
        show_rating: show_rating,
        show_quick_add: show_quick_add,
        show_color_swatches: show_color_swatches,
        color_scheme: color_scheme,
        columns: columns_desktop,
        lazy: true
      -%}
    </div>
  {%- endif -%}
</template>

<div
  id="Section-{{ section.id }}"
  class="recently-viewed color-{{ color_scheme }}"
  data-section-id="{{ section.id }}"
  data-products-to-show="{{ products_to_show }}"
  style="display: none;"
>
  <div class="container">
    {%- if heading != blank -%}
      <div class="recently-viewed__header">
        <{{ heading_size }} class="recently-viewed__heading">{{ heading }}</{{ heading_size }}>
      </div>
    {%- endif -%}

    <div
      class="recently-viewed__grid"
      style="--rv-columns: {{ columns_desktop }};"
      data-recently-viewed-grid
    >
      {%- comment -%} Products injected by JS via Section Rendering API {%- endcomment -%}
    </div>
  </div>
</div>

<script>
  (function() {
    var STORAGE_KEY = 'ecrin:recently-viewed';
    var MAX_STORED = 20;
    var sectionId = '{{ section.id }}';
    var section = document.getElementById('Section-' + sectionId);
    if (!section) return;

    var productsToShow = parseInt(section.dataset.productsToShow, 10) || 4;
    var grid = section.querySelector('[data-recently-viewed-grid]');
    if (!grid) return;

    /* Track current product page */
    {%- if request.page_type == 'product' -%}
      try {
        var stored = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
        var currentHandle = '{{ product.handle }}';
        stored = stored.filter(function(h) { return h !== currentHandle; });
        stored.unshift(currentHandle);
        if (stored.length > MAX_STORED) stored = stored.slice(0, MAX_STORED);
        localStorage.setItem(STORAGE_KEY, JSON.stringify(stored));
      } catch(e) {}
    {%- endif -%}

    /* Render recently viewed products via Section Rendering API */
    try {
      var handles = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');

      {%- if request.page_type == 'product' -%}
        handles = handles.filter(function(h) { return h !== '{{ product.handle }}'; });
      {%- endif -%}

      handles = handles.slice(0, productsToShow);
      if (handles.length === 0) return;

      section.style.display = '';

      /* Pre-create placeholder slots to maintain viewing order */
      var slots = {};
      handles.forEach(function(handle) {
        var slot = document.createElement('div');
        slot.className = 'recently-viewed__item';
        slot.dataset.handle = handle;
        slot.style.visibility = 'hidden';
        grid.appendChild(slot);
        slots[handle] = slot;
      });

      var routesRoot = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) || '/';

      handles.forEach(function(handle) {
        fetch(routesRoot + 'products/' + handle + '?sections=' + sectionId)
          .then(function(r) { return r.json(); })
          .then(function(data) {
            var html = data[sectionId];
            if (!html) return;

            var doc = new DOMParser().parseFromString(html, 'text/html');
            var template = doc.querySelector('[data-recently-viewed-card]');
            if (!template) return;

            var source = template.content || template;
            var card = source.querySelector('.recently-viewed__item');
            if (!card) return;

            var slot = slots[handle];
            if (slot && slot.parentNode) {
              slot.outerHTML = card.outerHTML;
            }
          })
          .catch(function() {
            var slot = slots[handle];
            if (slot && slot.parentNode) slot.remove();
          });
      });
    } catch(e) {}
  })();
</script>

{% schema %}
{
  "name": "t:sections.recently_viewed.name",
  "tag": "section",
  "class": "section-recently-viewed",
  "disabled_on": {
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.recently_viewed.heading",
      "default": "Recently viewed"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.recently_viewed.heading_size",
      "options": [
        { "value": "h2", "label": "t:sections.recently_viewed.heading_large" },
        { "value": "h3", "label": "t:sections.recently_viewed.heading_medium" }
      ],
      "default": "h2"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "t:sections.recently_viewed.products_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "t:sections.recently_viewed.columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "t:sections.recently_viewed.image_ratio",
      "options": [
        { "value": "natural", "label": "t:sections.recently_viewed.natural" },
        { "value": "portrait", "label": "t:sections.recently_viewed.portrait" },
        { "value": "square", "label": "t:sections.recently_viewed.square" },
        { "value": "landscape", "label": "t:sections.recently_viewed.landscape" }
      ],
      "default": "portrait"
    },
    {
      "type": "header",
      "content": "t:sections.recently_viewed.card_header"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "label": "t:sections.recently_viewed.show_secondary",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "t:sections.recently_viewed.show_vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "t:sections.recently_viewed.show_rating",
      "default": false,
      "info": "t:sections.recently_viewed.show_rating_info"
    },
    {
      "type": "checkbox",
      "id": "show_quick_add",
      "label": "t:sections.recently_viewed.show_quick_add",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_color_swatches",
      "label": "t:sections.recently_viewed.show_color_swatches",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.recently_viewed.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.recently_viewed.padding_top",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.recently_viewed.padding_bottom",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "t:sections.recently_viewed.preset_name"
    }
  ]
}
{% endschema %}
