{%- comment -%}
  Cart drawer section — slides from right
  Accessible, AJAX-powered, block-based footer, accelerated checkout
{%- endcomment -%}

{{ 'section-cart-drawer.css' | asset_url | stylesheet_tag }}

<cart-drawer class="cart-drawer" id="cart-drawer" aria-hidden="true" role="dialog" aria-modal="true" aria-label="{{ 'cart.title' | t }}">
  <div class="cart-drawer__overlay" data-cart-drawer-close aria-hidden="true"></div>

  <div class="cart-drawer__panel color-{{ section.settings.color_scheme }}">

    {%- comment -%} Header {%- endcomment -%}
    <div class="cart-drawer__header">
      <h2 class="cart-drawer__title">
        {{ 'cart.title' | t }}
        <span class="cart-drawer__count" data-cart-drawer-count>
          ({{ cart.item_count }})
        </span>
      </h2>
      <button class="btn--icon cart-drawer__close" data-cart-drawer-close aria-label="{{ 'accessibility.close' | t }}">
        {%- render 'icon', name: 'close', size: 18 -%}
      </button>
    </div>

    {%- comment -%} Header blocks (above items) {%- endcomment -%}
    <div class="cart-drawer__header-blocks" data-cart-drawer-header-blocks>
      {%- for block in section.blocks -%}
        {%- case block.type -%}

          {%- when 'free_shipping_bar' -%}
            {%- liquid
              assign threshold = block.settings.threshold | default: settings.free_shipping_threshold | times: 100
              assign cart_total = cart.total_price
              assign remaining = threshold | minus: cart_total
              assign progress = cart_total | times: 100.0 | divided_by: threshold
              if progress > 100
                assign progress = 100
              endif
            -%}
            <div class="cart-drawer__shipping-bar" {{ block.shopify_attributes }} data-shipping-bar data-threshold="{{ threshold }}">
              <div class="cart-drawer__shipping-progress" style="--progress: {{ progress }}%;">
                <div class="cart-drawer__shipping-fill"></div>
              </div>
              <p class="cart-drawer__shipping-text" data-shipping-text>
                {%- if remaining > 0 -%}
                  {%- assign remaining_formatted = remaining | money -%}
                  {{ 'cart.free_shipping_remaining' | t: amount: remaining_formatted }}
                {%- else -%}
                  {{ 'cart.free_shipping_reached' | t }}
                {%- endif -%}
              </p>
            </div>

          {%- when 'announcement' -%}
            {%- if block.settings.text != blank -%}
              <div class="cart-drawer__announcement" {{ block.shopify_attributes }}>
                {%- if block.settings.icon != 'none' -%}
                  <span class="cart-drawer__announcement-icon">
                    {%- render 'icon', name: block.settings.icon, size: 16 -%}
                  </span>
                {%- endif -%}
                <p class="cart-drawer__announcement-text">{{ block.settings.text }}</p>
              </div>
            {%- endif -%}

        {%- endcase -%}
      {%- endfor -%}
    </div>

    {%- comment -%} Cart items {%- endcomment -%}
    <div class="cart-drawer__body" data-cart-drawer-body>
      {%- if cart.item_count > 0 -%}
        <form action="{{ routes.cart_url }}" method="post" id="cart-drawer-form">
          <ul class="cart-drawer__items" role="list">
            {%- for item in cart.items -%}
              <li class="cart-drawer__item" data-cart-item data-key="{{ item.key }}">
                {%- comment -%} Image {%- endcomment -%}
                <a href="{{ item.url }}" class="cart-drawer__item-image" tabindex="-1" aria-hidden="true">
                  {%- if item.image -%}
                    {{ item.image | image_url: width: 200 | image_tag:
                      loading: 'lazy',
                      widths: '100,150,200',
                      class: 'cart-drawer__img',
                      alt: item.image.alt | default: item.product.title
                    }}
                  {%- endif -%}
                </a>

                {%- comment -%} Details {%- endcomment -%}
                <div class="cart-drawer__item-details">
                  <a href="{{ item.url }}" class="cart-drawer__item-title">{{ item.product.title }}</a>

                  {%- unless item.product.has_only_default_variant -%}
                    <p class="cart-drawer__item-variant">
                      {%- for option in item.options_with_values -%}
                        {{ option.value }}{%- unless forloop.last -%} / {%- endunless -%}
                      {%- endfor -%}
                    </p>
                  {%- endunless -%}

                  {%- if item.selling_plan_allocation -%}
                    <p class="cart-drawer__item-selling-plan">{{ item.selling_plan_allocation.selling_plan.name }}</p>
                  {%- endif -%}

                  {%- comment -%} Price {%- endcomment -%}
                  <div class="cart-drawer__item-price">
                    {%- if item.original_line_price != item.final_line_price -%}
                      <s class="cart-drawer__item-price-original">{{ item.original_line_price | money }}</s>
                    {%- endif -%}
                    <span class="cart-drawer__item-price-final">{{ item.final_line_price | money }}</span>
                  </div>

                  {%- if item.unit_price -%}
                    <div class="cart-drawer__item-unit-price">
                      {{ item.unit_price | money }} {{ 'product.unit_price_separator' | t }}
                      {%- if item.unit_price_measurement.reference_value != 1 -%}
                        {{ item.unit_price_measurement.reference_value }}
                      {%- endif -%}
                      {{ item.unit_price_measurement.reference_unit }}
                    </div>
                  {%- endif -%}

                  {%- comment -%} Line item discounts {%- endcomment -%}
                  {%- for discount in item.line_level_discount_allocations -%}
                    <p class="cart-drawer__item-discount">
                      {%- render 'icon', name: 'check', size: 14 -%}
                      {{ discount.discount_application.title }} (-{{ discount.amount | money }})
                    </p>
                  {%- endfor -%}

                  {%- comment -%} Quantity + remove {%- endcomment -%}
                  <div class="cart-drawer__item-actions">
                    <div class="cart-drawer__quantity">
                      <button
                        class="cart-drawer__quantity-btn btn--icon"
                        data-quantity-minus
                        aria-label="{{ 'accessibility.decrease_quantity' | t: title: item.product.title }}"
                      >
                        {%- render 'icon', name: 'minus', size: 14 -%}
                      </button>
                      <input
                        type="number"
                        class="cart-drawer__quantity-input"
                        name="updates[{{ item.key }}]"
                        value="{{ item.quantity }}"
                        min="0"
                        aria-label="{{ 'cart.quantity' | t }}"
                        data-quantity-input
                      >
                      <button
                        class="cart-drawer__quantity-btn btn--icon"
                        data-quantity-plus
                        aria-label="{{ 'accessibility.increase_quantity' | t: title: item.product.title }}"
                      >
                        {%- render 'icon', name: 'plus', size: 14 -%}
                      </button>
                    </div>

                    <button
                      class="cart-drawer__remove btn--icon"
                      data-remove-item
                      aria-label="{{ 'accessibility.remove_item' | t: title: item.product.title }}"
                    >
                      {%- render 'icon', name: 'trash', size: 16 -%}
                    </button>
                  </div>
                </div>
              </li>
            {%- endfor -%}
          </ul>
        </form>
      {%- else -%}
        <div class="cart-drawer__empty">
          <p>{{ 'cart.empty' | t }}</p>
          <a href="{{ routes.all_products_collection_url }}" class="btn btn--secondary">
            <span class="btn__label">{{ 'cart.continue_shopping' | t }}</span>
            <span class="btn__fill" aria-hidden="true"></span>
          </a>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Footer — blocks + subtotal + checkout {%- endcomment -%}
    {%- if cart.item_count > 0 -%}
      <div class="cart-drawer__footer" data-cart-drawer-footer>

        {%- comment -%} Footer blocks (before subtotal) {%- endcomment -%}
        {%- for block in section.blocks -%}
          {%- case block.type -%}

            {%- when 'cart_note' -%}
              <details class="cart-drawer__note-toggle" {{ block.shopify_attributes }}>
                <summary class="cart-drawer__note-summary label">{{ 'cart.note' | t }}</summary>
                <textarea
                  class="cart-drawer__note-textarea"
                  name="note"
                  form="cart-drawer-form"
                  placeholder="{{ 'cart.note_placeholder' | t }}"
                  aria-label="{{ 'cart.note' | t }}"
                >{{ cart.note }}</textarea>
              </details>

            {%- when 'gift_note' -%}
              <details class="cart-drawer__note-toggle" {{ block.shopify_attributes }}>
                <summary class="cart-drawer__note-summary label">
                  {%- render 'icon', name: 'gift', size: 14 -%}
                  {% if block.settings.label != blank %}{{ block.settings.label }}{% else %}{{ 'cart.gift_note' | t }}{% endif %}
                </summary>
                <textarea
                  class="cart-drawer__note-textarea"
                  name="attributes[gift_note]"
                  form="cart-drawer-form"
                  placeholder="{% if block.settings.placeholder != blank %}{{ block.settings.placeholder }}{% else %}{{ 'cart.gift_note_placeholder' | t }}{% endif %}"
                >{{ cart.attributes['gift_note'] }}</textarea>
              </details>

            {%- when 'trust_badges' -%}
              <div class="cart-drawer__trust" {{ block.shopify_attributes }}>
                {%- if block.settings.badge_1_text != blank -%}
                  <div class="cart-drawer__trust-item">
                    {%- render 'icon', name: block.settings.badge_1_icon, size: 16 -%}
                    <span>{{ block.settings.badge_1_text }}</span>
                  </div>
                {%- endif -%}
                {%- if block.settings.badge_2_text != blank -%}
                  <div class="cart-drawer__trust-item">
                    {%- render 'icon', name: block.settings.badge_2_icon, size: 16 -%}
                    <span>{{ block.settings.badge_2_text }}</span>
                  </div>
                {%- endif -%}
                {%- if block.settings.badge_3_text != blank -%}
                  <div class="cart-drawer__trust-item">
                    {%- render 'icon', name: block.settings.badge_3_icon, size: 16 -%}
                    <span>{{ block.settings.badge_3_text }}</span>
                  </div>
                {%- endif -%}
              </div>

          {%- endcase -%}
        {%- endfor -%}

        {%- comment -%} Order discounts {%- endcomment -%}
        {%- for discount in cart.cart_level_discount_applications -%}
          <div class="cart-drawer__discount">
            {%- render 'icon', name: 'check', size: 14 -%}
            <span>{{ discount.title }}</span>
            <span>-{{ discount.total_allocated_amount | money }}</span>
          </div>
        {%- endfor -%}

        {%- comment -%} Subtotal {%- endcomment -%}
        <div class="cart-drawer__subtotal">
          <span>{{ 'cart.subtotal' | t }}</span>
          <span data-cart-drawer-subtotal>{{ cart.total_price | money }}</span>
        </div>

        <p class="cart-drawer__taxes-notice">
          {%- if cart.taxes_included -%}
            {{ 'cart.taxes_included' | t }}.
          {%- endif -%}
          {{ 'cart.taxes_notice' | t }}
        </p>

        {%- comment -%} Checkout button {%- endcomment -%}
        <div class="cart-drawer__checkout-buttons">
          <button type="submit" name="checkout" form="cart-drawer-form" class="btn btn--primary btn--full">
            <span class="btn__label">{{ 'cart.checkout' | t }}</span>
            <span class="btn__fill" aria-hidden="true"></span>
          </button>

          {%- comment -%} Accelerated checkout (dynamic, Shopify renders) {%- endcomment -%}
          <div class="cart-drawer__dynamic-checkout">
            {{ content_for_additional_checkout_buttons }}
          </div>
        </div>
      </div>
    {%- endif -%}

  </div>
</cart-drawer>

<script src="{{ 'section-cart-drawer.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "t:general.cart",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.cart_drawer.color_scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "free_shipping_bar",
      "name": "t:sections.cart_drawer.blocks.free_shipping_bar",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "threshold",
          "label": "t:sections.cart_drawer.blocks.shipping_threshold",
          "info": "t:sections.cart_drawer.blocks.shipping_threshold_info"
        }
      ]
    },
    {
      "type": "announcement",
      "name": "t:sections.cart_drawer.blocks.announcement",
      "limit": 2,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "t:sections.cart_drawer.blocks.icon",
          "options": [
            { "value": "none", "label": "t:sections.cart_drawer.blocks.icon_none" },
            { "value": "gift", "label": "t:sections.cart_drawer.blocks.icon_gift" },
            { "value": "shipping", "label": "t:sections.cart_drawer.blocks.icon_shipping" },
            { "value": "lock", "label": "t:sections.cart_drawer.blocks.icon_lock" },
            { "value": "leaf", "label": "t:sections.cart_drawer.blocks.icon_leaf" },
            { "value": "heart", "label": "t:sections.cart_drawer.blocks.icon_heart" },
            { "value": "diamond", "label": "t:sections.cart_drawer.blocks.icon_diamond" },
            { "value": "crown", "label": "t:sections.cart_drawer.blocks.icon_crown" },
            { "value": "sparkle", "label": "t:sections.cart_drawer.blocks.icon_sparkle" }
          ],
          "default": "gift"
        },
        {
          "type": "text",
          "id": "text",
          "label": "t:sections.cart_drawer.blocks.announcement_text",
          "default": "Complimentary gift wrapping on all orders"
        }
      ]
    },
    {
      "type": "cart_note",
      "name": "t:sections.cart_drawer.blocks.cart_note",
      "limit": 1
    },
    {
      "type": "gift_note",
      "name": "t:sections.cart_drawer.blocks.gift_note",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "t:sections.cart_drawer.blocks.gift_note_label",
          "default": "Add a gift message"
        },
        {
          "type": "text",
          "id": "placeholder",
          "label": "t:sections.cart_drawer.blocks.gift_note_placeholder",
          "default": "Write your personal message here..."
        }
      ]
    },
    {
      "type": "trust_badges",
      "name": "t:sections.cart_drawer.blocks.trust_badges",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "badge_1_icon",
          "label": "t:sections.cart_drawer.blocks.badge_1_icon",
          "options": [
            { "value": "shipping", "label": "t:sections.cart_drawer.blocks.icon_shipping" },
            { "value": "lock", "label": "t:sections.cart_drawer.blocks.icon_lock" },
            { "value": "return", "label": "t:sections.cart_drawer.blocks.icon_return" },
            { "value": "shield", "label": "t:sections.cart_drawer.blocks.icon_shield" },
            { "value": "leaf", "label": "t:sections.cart_drawer.blocks.icon_leaf" },
            { "value": "gift", "label": "t:sections.cart_drawer.blocks.icon_gift" },
            { "value": "heart", "label": "t:sections.cart_drawer.blocks.icon_heart" },
            { "value": "diamond", "label": "t:sections.cart_drawer.blocks.icon_diamond" }
          ],
          "default": "shipping"
        },
        {
          "type": "text",
          "id": "badge_1_text",
          "label": "t:sections.cart_drawer.blocks.badge_1_text",
          "default": "Free shipping"
        },
        {
          "type": "select",
          "id": "badge_2_icon",
          "label": "t:sections.cart_drawer.blocks.badge_2_icon",
          "options": [
            { "value": "shipping", "label": "t:sections.cart_drawer.blocks.icon_shipping" },
            { "value": "lock", "label": "t:sections.cart_drawer.blocks.icon_lock" },
            { "value": "return", "label": "t:sections.cart_drawer.blocks.icon_return" },
            { "value": "shield", "label": "t:sections.cart_drawer.blocks.icon_shield" },
            { "value": "leaf", "label": "t:sections.cart_drawer.blocks.icon_leaf" },
            { "value": "gift", "label": "t:sections.cart_drawer.blocks.icon_gift" },
            { "value": "heart", "label": "t:sections.cart_drawer.blocks.icon_heart" },
            { "value": "diamond", "label": "t:sections.cart_drawer.blocks.icon_diamond" }
          ],
          "default": "lock"
        },
        {
          "type": "text",
          "id": "badge_2_text",
          "label": "t:sections.cart_drawer.blocks.badge_2_text",
          "default": "Secure checkout"
        },
        {
          "type": "select",
          "id": "badge_3_icon",
          "label": "t:sections.cart_drawer.blocks.badge_3_icon",
          "options": [
            { "value": "shipping", "label": "t:sections.cart_drawer.blocks.icon_shipping" },
            { "value": "lock", "label": "t:sections.cart_drawer.blocks.icon_lock" },
            { "value": "return", "label": "t:sections.cart_drawer.blocks.icon_return" },
            { "value": "shield", "label": "t:sections.cart_drawer.blocks.icon_shield" },
            { "value": "leaf", "label": "t:sections.cart_drawer.blocks.icon_leaf" },
            { "value": "gift", "label": "t:sections.cart_drawer.blocks.icon_gift" },
            { "value": "heart", "label": "t:sections.cart_drawer.blocks.icon_heart" },
            { "value": "diamond", "label": "t:sections.cart_drawer.blocks.icon_diamond" }
          ],
          "default": "return"
        },
        {
          "type": "text",
          "id": "badge_3_text",
          "label": "t:sections.cart_drawer.blocks.badge_3_text",
          "default": "Easy returns"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:general.cart",
      "blocks": [
        { "type": "free_shipping_bar" },
        { "type": "cart_note" },
        { "type": "trust_badges" }
      ]
    }
  ]
}
{% endschema %}
