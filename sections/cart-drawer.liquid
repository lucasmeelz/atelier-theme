{%- comment -%}
  Cart drawer section — slides from right
  Accessible, AJAX-powered, free shipping bar, accelerated checkout
{%- endcomment -%}

{{ 'section-cart-drawer.css' | asset_url | stylesheet_tag }}

<cart-drawer class="cart-drawer" id="cart-drawer" aria-hidden="true" role="dialog" aria-modal="true" aria-label="{{ 'cart.title' | t }}">
  <div class="cart-drawer__overlay" data-cart-drawer-close aria-hidden="true"></div>

  <div class="cart-drawer__panel color-{{ section.settings.color_scheme }}">

    {%- comment -%} Header {%- endcomment -%}
    <div class="cart-drawer__header">
      <h2 class="cart-drawer__title">
        {{ 'cart.title' | t }}
        <span class="cart-drawer__count" data-cart-drawer-count>
          ({{ cart.item_count }})
        </span>
      </h2>
      <button class="btn--icon cart-drawer__close" data-cart-drawer-close aria-label="{{ 'accessibility.close' | t }}">
        {%- render 'icon', name: 'close', size: 18 -%}
      </button>
    </div>

    {%- comment -%} Free shipping bar {%- endcomment -%}
    {%- if settings.show_free_shipping_bar -%}
      {%- liquid
        assign threshold = settings.free_shipping_threshold | times: 100
        assign cart_total = cart.total_price
        assign remaining = threshold | minus: cart_total
        assign progress = cart_total | times: 100.0 | divided_by: threshold
        if progress > 100
          assign progress = 100
        endif
      -%}
      <div class="cart-drawer__shipping-bar" data-shipping-bar data-threshold="{{ threshold }}">
        <div class="cart-drawer__shipping-progress" style="--progress: {{ progress }}%;">
          <div class="cart-drawer__shipping-fill"></div>
        </div>
        <p class="cart-drawer__shipping-text" data-shipping-text>
          {%- if remaining > 0 -%}
            {{ 'cart.free_shipping_remaining' | t: amount: remaining | money }}
          {%- else -%}
            {{ 'cart.free_shipping_reached' | t }}
          {%- endif -%}
        </p>
      </div>
    {%- endif -%}

    {%- comment -%} Cart items {%- endcomment -%}
    <div class="cart-drawer__body" data-cart-drawer-body>
      {%- if cart.item_count > 0 -%}
        <form action="{{ routes.cart_url }}" method="post" id="cart-drawer-form">
          <ul class="cart-drawer__items" role="list">
            {%- for item in cart.items -%}
              <li class="cart-drawer__item" data-cart-item data-key="{{ item.key }}">
                {%- comment -%} Image {%- endcomment -%}
                <a href="{{ item.url }}" class="cart-drawer__item-image" tabindex="-1" aria-hidden="true">
                  {%- if item.image -%}
                    {{ item.image | image_url: width: 200 | image_tag:
                      loading: 'lazy',
                      widths: '100,150,200',
                      class: 'cart-drawer__img',
                      alt: item.image.alt | default: item.product.title
                    }}
                  {%- endif -%}
                </a>

                {%- comment -%} Details {%- endcomment -%}
                <div class="cart-drawer__item-details">
                  <a href="{{ item.url }}" class="cart-drawer__item-title">{{ item.product.title }}</a>

                  {%- unless item.product.has_only_default_variant -%}
                    <p class="cart-drawer__item-variant">
                      {%- for option in item.options_with_values -%}
                        {{ option.value }}{%- unless forloop.last -%} / {%- endunless -%}
                      {%- endfor -%}
                    </p>
                  {%- endunless -%}

                  {%- if item.selling_plan_allocation -%}
                    <p class="cart-drawer__item-selling-plan">{{ item.selling_plan_allocation.selling_plan.name }}</p>
                  {%- endif -%}

                  {%- comment -%} Price {%- endcomment -%}
                  <div class="cart-drawer__item-price">
                    {%- if item.original_line_price != item.final_line_price -%}
                      <s class="cart-drawer__item-price-original">{{ item.original_line_price | money }}</s>
                    {%- endif -%}
                    <span class="cart-drawer__item-price-final">{{ item.final_line_price | money }}</span>
                  </div>

                  {%- if item.unit_price -%}
                    <div class="cart-drawer__item-unit-price">
                      {{ item.unit_price | money }} {{ 'product.unit_price_separator' | t }}
                      {%- if item.unit_price_measurement.reference_value != 1 -%}
                        {{ item.unit_price_measurement.reference_value }}
                      {%- endif -%}
                      {{ item.unit_price_measurement.reference_unit }}
                    </div>
                  {%- endif -%}

                  {%- comment -%} Line item discounts {%- endcomment -%}
                  {%- for discount in item.line_level_discount_allocations -%}
                    <p class="cart-drawer__item-discount">
                      {%- render 'icon', name: 'check', size: 14 -%}
                      {{ discount.discount_application.title }} (-{{ discount.amount | money }})
                    </p>
                  {%- endfor -%}

                  {%- comment -%} Quantity + remove {%- endcomment -%}
                  <div class="cart-drawer__item-actions">
                    <div class="cart-drawer__quantity">
                      <button
                        class="cart-drawer__quantity-btn btn--icon"
                        data-quantity-minus
                        aria-label="{{ 'accessibility.decrease_quantity' | t: title: item.product.title }}"
                      >
                        {%- render 'icon', name: 'minus', size: 14 -%}
                      </button>
                      <input
                        type="number"
                        class="cart-drawer__quantity-input"
                        name="updates[{{ item.key }}]"
                        value="{{ item.quantity }}"
                        min="0"
                        aria-label="{{ 'cart.quantity' | t }}"
                        data-quantity-input
                      >
                      <button
                        class="cart-drawer__quantity-btn btn--icon"
                        data-quantity-plus
                        aria-label="{{ 'accessibility.increase_quantity' | t: title: item.product.title }}"
                      >
                        {%- render 'icon', name: 'plus', size: 14 -%}
                      </button>
                    </div>

                    <button
                      class="cart-drawer__remove btn--icon"
                      data-remove-item
                      aria-label="{{ 'accessibility.remove_item' | t: title: item.product.title }}"
                    >
                      {%- render 'icon', name: 'trash', size: 16 -%}
                    </button>
                  </div>
                </div>
              </li>
            {%- endfor -%}
          </ul>
        </form>
      {%- else -%}
        <div class="cart-drawer__empty">
          <p>{{ 'cart.empty' | t }}</p>
          <a href="{{ routes.all_products_collection_url }}" class="btn btn--secondary">
            <span class="btn__label">{{ 'cart.continue_shopping' | t }}</span>
            <span class="btn__fill" aria-hidden="true"></span>
          </a>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Footer — subtotal + checkout {%- endcomment -%}
    {%- if cart.item_count > 0 -%}
      <div class="cart-drawer__footer">
        {%- comment -%} Cart note {%- endcomment -%}
        {%- if settings.enable_cart_note -%}
          <details class="cart-drawer__note-toggle">
            <summary class="cart-drawer__note-summary label">{{ 'cart.note' | t }}</summary>
            <textarea
              class="cart-drawer__note-textarea"
              name="note"
              form="cart-drawer-form"
              placeholder="{{ 'cart.note_placeholder' | t }}"
            >{{ cart.note }}</textarea>
          </details>
        {%- endif -%}

        {%- comment -%} Order discounts {%- endcomment -%}
        {%- for discount in cart.cart_level_discount_applications -%}
          <div class="cart-drawer__discount">
            {%- render 'icon', name: 'check', size: 14 -%}
            <span>{{ discount.title }}</span>
            <span>-{{ discount.total_allocated_amount | money }}</span>
          </div>
        {%- endfor -%}

        {%- comment -%} Subtotal {%- endcomment -%}
        <div class="cart-drawer__subtotal">
          <span>{{ 'cart.subtotal' | t }}</span>
          <span data-cart-drawer-subtotal>{{ cart.total_price | money }}</span>
        </div>

        <p class="cart-drawer__taxes-notice">
          {%- if cart.taxes_included -%}
            {{ 'cart.taxes_included' | t }}.
          {%- endif -%}
          {{ 'cart.taxes_notice' | t }}
        </p>

        {%- comment -%} Checkout button {%- endcomment -%}
        <div class="cart-drawer__checkout-buttons">
          <button type="submit" name="checkout" form="cart-drawer-form" class="btn btn--primary btn--full">
            <span class="btn__label">{{ 'cart.checkout' | t }}</span>
            <span class="btn__fill" aria-hidden="true"></span>
          </button>

          {%- comment -%} Accelerated checkout (dynamic, Shopify renders) {%- endcomment -%}
          <div class="cart-drawer__dynamic-checkout">
            {{ content_for_additional_checkout_buttons }}
          </div>
        </div>
      </div>
    {%- endif -%}

  </div>
</cart-drawer>

<script src="{{ 'section-cart-drawer.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "t:general.cart",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.cart_drawer.color_scheme",
      "default": "scheme-1"
    }
  ]
}
{% endschema %}
