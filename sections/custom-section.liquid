{%- comment -%}
  Custom Section — Flexible content blocks container
  Allows merchants to add theme blocks in a styled wrapper
{%- endcomment -%}

{%- liquid
  assign color_scheme = section.settings.color_scheme
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
-%}

{%- style -%}
  #Section-{{ section.id }} {
    --section-padding-top: {{ padding_top }}px;
    --section-padding-bottom: {{ padding_bottom }}px;
  }

  .custom-section-wrap {
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
  }
{%- endstyle -%}

<section
  id="Section-{{ section.id }}"
  class="custom-section-wrap color-{{ color_scheme }} full-width"
>
  <div class="container">
    {%- for block in section.blocks -%}
      <div {{ block.shopify_attributes }}>
        {%- case block.type -%}
          {%- when '@app' -%}
            {% render block %}
          {%- when '@theme' -%}
            {% render block %}
        {%- endcase -%}
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.custom_section.name",
  "tag": "section",
  "class": "section-custom",
  "disabled_on": {
    "groups": ["header", "custom.overlay"]
  },
  "blocks": [
    { "type": "@app" },
    { "type": "@theme" }
  ],
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.custom_section.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.custom_section.padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.custom_section.padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "t:sections.custom_section.preset_name"
    }
  ]
}
{% endschema %}
