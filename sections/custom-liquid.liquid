{%- comment -%}
  Custom Liquid — Allows merchants and apps to add custom Liquid code.
  Required by Shopify Theme Store for app compatibility.
{%- endcomment -%}

{%- style -%}
  #Section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<div
  id="Section-{{ section.id }}"
  class="custom-liquid color-{{ section.settings.color_scheme }}"
  style="padding-top: var(--section-padding-top); padding-bottom: var(--section-padding-bottom);"
>
  <div class="container">
    {{ section.settings.liquid }}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.custom_liquid.name",
  "tag": "section",
  "class": "section-custom-liquid",
  "disabled_on": {
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "liquid",
      "id": "liquid",
      "label": "t:sections.custom_liquid.liquid",
      "info": "t:sections.custom_liquid.liquid_info"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.custom_liquid.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.custom_liquid.padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.custom_liquid.padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "t:sections.custom_liquid.preset_name"
    }
  ]
}
{% endschema %}
