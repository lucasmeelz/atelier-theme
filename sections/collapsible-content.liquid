{%- comment -%}
  Collapsible Content / FAQ — Accessible accordion section
  Uses native <details>/<summary> with CSS animations
  Plus/minus icon via ::after pseudo-element (Shopify editor safe)
{%- endcomment -%}

{{ 'section-collapsible-content.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign color_scheme = section.settings.color_scheme
  assign layout = section.settings.layout
  assign heading_tag = section.settings.heading_size | default: 'h2'
  assign open_first = section.settings.open_first
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
-%}

{%- style -%}
  #Section-{{ section.id }} {
    --section-padding-top: {{ padding_top }}px;
    --section-padding-bottom: {{ padding_bottom }}px;
  }
{%- endstyle -%}

<div
  id="Section-{{ section.id }}"
  class="collapsible-content color-{{ color_scheme }} full-width"
>
  <div class="container">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="collapsible-content__header">
        {%- if section.settings.subheading != blank -%}
          <p class="collapsible-content__subheading label">
            {{ section.settings.subheading }}
          </p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <{{ heading_tag }} class="collapsible-content__heading">
            {{ section.settings.heading }}
          </{{ heading_tag }}>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="collapsible-content__inner collapsible-content__inner--{{ layout }}">
      {%- for block in section.blocks -%}
        <details
          class="collapsible-content__item"
          {% if open_first and forloop.first %}open{% endif %}
          {{ block.shopify_attributes }}
        >
          <summary>
            <span class="collapsible-content__item-heading">
              {%- if block.settings.heading != blank -%}{{ block.settings.heading }}{%- else -%}{{ 'sections.collapsible_content.default_heading' | t }}{%- endif -%}
            </span>
          </summary>
          <div class="collapsible-content__body">
            <div class="collapsible-content__body-inner">
              <div class="rte">
                {{ block.settings.content }}
              </div>
            </div>
          </div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</div>

<script>
  /* JS-driven accordion animation. The <details> element is fully
     controlled by the script: native toggling is intercepted so we can
     animate the body's max-height reliably across browsers that now
     wrap non-summary content in a ::details-content pseudo. */
  (function () {
    const section = document.getElementById('Section-{{ section.id }}');
    if (!section) return;

    const items = section.querySelectorAll('.collapsible-content__item');
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    items.forEach(function (details) {
      const summary = details.querySelector('summary');
      const body = details.querySelector('.collapsible-content__body');
      const inner = details.querySelector('.collapsible-content__body-inner');
      if (!summary || !body || !inner) return;

      function measuredHeight() {
        return inner.scrollHeight;
      }

      function openItem() {
        if (details.classList.contains('is-open')) return;
        details.open = true;
        details.classList.remove('is-closing', 'is-open-complete');
        details.classList.add('is-open');
        const h = measuredHeight();
        body.style.setProperty('--body-height', h + 'px');
        if (prefersReduced) {
          details.classList.add('is-open-complete');
          body.style.removeProperty('--body-height');
          return;
        }
        /* Reset any inline max-height from a prior close, then animate to h */
        body.style.maxHeight = '0px';
        /* Force reflow so the browser registers the starting state */
        void body.offsetHeight;
        body.style.maxHeight = h + 'px';
        const onEnd = function (e) {
          if (e.propertyName !== 'max-height') return;
          body.removeEventListener('transitionend', onEnd);
          if (details.classList.contains('is-open')) {
            body.style.maxHeight = '';
            details.classList.add('is-open-complete');
          }
        };
        body.addEventListener('transitionend', onEnd);
      }

      function closeItem() {
        if (!details.open) return;
        const h = body.offsetHeight || measuredHeight();
        details.classList.remove('is-open-complete');
        details.classList.add('is-closing');
        body.style.maxHeight = h + 'px';
        /* Force reflow, then collapse */
        void body.offsetHeight;
        if (prefersReduced) {
          details.open = false;
          details.classList.remove('is-open', 'is-closing');
          body.style.maxHeight = '';
          return;
        }
        body.style.maxHeight = '0px';
        const onEnd = function (e) {
          if (e.propertyName !== 'max-height') return;
          body.removeEventListener('transitionend', onEnd);
          details.open = false;
          details.classList.remove('is-open', 'is-closing');
          body.style.maxHeight = '';
        };
        body.addEventListener('transitionend', onEnd);
      }

      summary.addEventListener('click', function (event) {
        event.preventDefault();
        if (details.open) {
          closeItem();
        } else {
          openItem();
        }
      });

      summary.addEventListener('keydown', function (event) {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          if (details.open) {
            closeItem();
          } else {
            openItem();
          }
        }
      });

      /* Initialize items that render with [open] already set */
      if (details.open) {
        details.classList.add('is-open', 'is-open-complete');
      }
    });
  })();
</script>

{% schema %}
{
  "name": "t:sections.collapsible_content.name",
  "tag": "section",
  "class": "section-collapsible-content",
  "max_blocks": 12,
  "disabled_on": {
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:sections.collapsible_content.heading",
      "default": "Frequently asked questions"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.collapsible_content.heading_size",
      "options": [
        { "value": "h2", "label": "t:sections.collapsible_content.heading_large" },
        { "value": "h3", "label": "t:sections.collapsible_content.heading_medium" }
      ],
      "default": "h2"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.collapsible_content.subheading"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "t:sections.collapsible_content.layout",
      "options": [
        { "value": "contained", "label": "t:sections.collapsible_content.layout_contained" },
        { "value": "full_width", "label": "t:sections.collapsible_content.layout_full_width" }
      ],
      "default": "contained"
    },
    {
      "type": "checkbox",
      "id": "open_first",
      "label": "t:sections.collapsible_content.open_first",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.collapsible_content.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.collapsible_content.padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.collapsible_content.padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "t:sections.collapsible_content.blocks.row",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.collapsible_content.blocks.heading",
          "default": "Collapsible row"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "t:sections.collapsible_content.blocks.content",
          "default": "<p>Share details about your shipping, return, or customer service policies.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.collapsible_content.preset_name",
      "blocks": [
        {
          "type": "row",
          "settings": {
            "heading": "What materials do you use?",
            "content": "<p>We source only the finest materials from trusted artisans around the world. Each piece is crafted with meticulous attention to detail, ensuring exceptional quality and lasting beauty.</p>"
          }
        },
        {
          "type": "row",
          "settings": {
            "heading": "What is your shipping policy?",
            "content": "<p>We offer complimentary express shipping on all orders. Items are carefully packaged in our signature gift boxes and typically arrive within 3-5 business days.</p>"
          }
        },
        {
          "type": "row",
          "settings": {
            "heading": "Do you offer returns or exchanges?",
            "content": "<p>We accept returns within 30 days of delivery. Items must be in their original condition and packaging. Please contact our concierge team to initiate a return or exchange.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
