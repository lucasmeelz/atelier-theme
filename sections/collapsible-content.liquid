{%- comment -%}
  Collapsible Content / FAQ — Accessible accordion section
  Uses native <details>/<summary> with CSS animations
  Plus/minus icon via ::after pseudo-element (Shopify editor safe)
{%- endcomment -%}

{{ 'section-collapsible-content.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign color_scheme = section.settings.color_scheme
  assign layout = section.settings.layout
  assign heading_tag = section.settings.heading_size | default: 'h2'
  assign open_first = section.settings.open_first
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
-%}

{%- style -%}
  #Section-{{ section.id }} {
    --section-padding-top: {{ padding_top }}px;
    --section-padding-bottom: {{ padding_bottom }}px;
  }
{%- endstyle -%}

<div
  id="Section-{{ section.id }}"
  class="collapsible-content color-{{ color_scheme }}"
>
  <div class="container">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="collapsible-content__header">
        {%- if section.settings.subheading != blank -%}
          <p class="collapsible-content__subheading label">
            {{ section.settings.subheading }}
          </p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <{{ heading_tag }} class="collapsible-content__heading">
            {{ section.settings.heading }}
          </{{ heading_tag }}>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="collapsible-content__inner collapsible-content__inner--{{ layout }}">
      {%- for block in section.blocks -%}
        <details
          class="collapsible-content__item"
          {% if open_first and forloop.first %}open{% endif %}
          {{ block.shopify_attributes }}
        >
          <summary>
            <span class="collapsible-content__item-heading">
              {{ block.settings.heading | default: 'sections.collapsible_content.default_heading' | t }}
            </span>
          </summary>
          <div class="collapsible-content__body">
            <div class="collapsible-content__body-inner">
              <div class="rte">
                {{ block.settings.content }}
              </div>
            </div>
          </div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</div>

<script>
  /* Smooth accordion animation — measure content height for max-height transition */
  (function () {
    const section = document.getElementById('Section-{{ section.id }}');
    if (!section) return;

    const items = section.querySelectorAll('.collapsible-content__item');

    items.forEach(function (details) {
      const body = details.querySelector('.collapsible-content__body');
      const inner = details.querySelector('.collapsible-content__body-inner');
      if (!body || !inner) return;

      /* Set measured height when open */
      function setHeight() {
        body.style.setProperty('--body-height', inner.scrollHeight + 'px');
      }

      details.addEventListener('toggle', function () {
        if (details.open) {
          setHeight();
        }
      });

      /* Initialize open items */
      if (details.open) {
        setHeight();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "t:sections.collapsible_content.name",
  "tag": "section",
  "class": "section-collapsible-content",
  "max_blocks": 12,
  "disabled_on": {
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:sections.collapsible_content.heading",
      "default": "Frequently asked questions"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.collapsible_content.heading_size",
      "options": [
        { "value": "h2", "label": "t:sections.collapsible_content.heading_large" },
        { "value": "h3", "label": "t:sections.collapsible_content.heading_medium" }
      ],
      "default": "h2"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.collapsible_content.subheading"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "t:sections.collapsible_content.layout",
      "options": [
        { "value": "contained", "label": "t:sections.collapsible_content.layout_contained" },
        { "value": "full_width", "label": "t:sections.collapsible_content.layout_full_width" }
      ],
      "default": "contained"
    },
    {
      "type": "checkbox",
      "id": "open_first",
      "label": "t:sections.collapsible_content.open_first",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.collapsible_content.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.collapsible_content.padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.collapsible_content.padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "t:sections.collapsible_content.blocks.row",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.collapsible_content.blocks.heading",
          "default": "Collapsible row"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "t:sections.collapsible_content.blocks.content",
          "default": "<p>Share details about your shipping, return, or customer service policies.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.collapsible_content.preset_name",
      "blocks": [
        {
          "type": "row",
          "settings": {
            "heading": "What materials do you use?",
            "content": "<p>We source only the finest materials from trusted artisans around the world. Each piece is crafted with meticulous attention to detail, ensuring exceptional quality and lasting beauty.</p>"
          }
        },
        {
          "type": "row",
          "settings": {
            "heading": "What is your shipping policy?",
            "content": "<p>We offer complimentary express shipping on all orders. Items are carefully packaged in our signature gift boxes and typically arrive within 3-5 business days.</p>"
          }
        },
        {
          "type": "row",
          "settings": {
            "heading": "Do you offer returns or exchanges?",
            "content": "<p>We accept returns within 30 days of delivery. Items must be in their original condition and packaging. Please contact our concierge team to initiate a return or exchange.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
