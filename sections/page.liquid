{%- comment -%}
  Page — Generic page content with proper typography and spacing
{%- endcomment -%}

{%- liquid
  assign color_scheme = section.settings.color_scheme
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign content_width = section.settings.content_width
-%}

{%- style -%}
  #Section-{{ section.id }} {
    --section-padding-top: {{ padding_top }}px;
    --section-padding-bottom: {{ padding_bottom }}px;
  }

  .page-section {
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
    background: rgb(var(--color-background));
    color: rgb(var(--color-text));
  }

  .page__container {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 var(--page-margin);
  }

  .page__title {
    margin: 0 0 40px;
    max-width: {{ content_width }}px;
  }

  .page__content {
    max-width: {{ content_width }}px;
  }

  .page__content.rte > *:first-child {
    margin-top: 0;
  }

  .page__content.rte > *:last-child {
    margin-bottom: 0;
  }
{%- endstyle -%}

<section
  id="Section-{{ section.id }}"
  class="page-section color-{{ color_scheme }}"
>
  <div class="page__container">
    <h1 class="page__title h2">{{ page.title }}</h1>
    <div class="page__content rte">
      {{ page.content }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:general.page",
  "tag": "section",
  "settings": [
    {
      "type": "range",
      "id": "content_width",
      "label": "t:sections.rich_text.content_width",
      "min": 500,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "default": 800
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.blog_posts.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.blog_posts.padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.blog_posts.padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ]
}
{% endschema %}
