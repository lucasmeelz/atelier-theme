{%- comment -%}
  Main Cart — Full cart page
  Line items with quantity, totals, notes, checkout
{%- endcomment -%}

{{ 'section-main-cart.css' | asset_url | stylesheet_tag }}
{{ 'component-cart-line.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-main-cart.js' | asset_url }}" defer></script>

{%- liquid
  assign show_payment_icons = section.settings.show_payment_icons
  assign color_scheme = section.settings.color_scheme
-%}

<div id="Section-{{ section.id }}" class="main-cart color-{{ color_scheme }}">
  <div class="container">
    <main-cart-section data-section-id="{{ section.id }}">
    <h1 class="main-cart__title">{{ 'cart.title' | t }}</h1>

    <p
      class="main-cart__notice"
      data-cart-notice
      data-t-quantity-adjusted="{{ 'cart.quantity_adjusted' | t }}"
      role="alert"
      hidden
    ></p>

    {%- if cart.item_count > 0 -%}
      <form action="{{ routes.cart_url }}" method="post" id="cart-form">
        <div class="main-cart__grid">

          {%- comment -%} Line items column — shared cart-line component (B-04) {%- endcomment -%}
          <div class="main-cart__items">
            {%- for item in cart.items -%}
              {%- render 'cart-line-item', item: item, context: 'page', tag: 'div', show_line_total: true -%}
            {%- endfor -%}
          </div>

          {%- comment -%} Summary column — block-based {%- endcomment -%}
          <div class="main-cart__summary">

            {%- comment -%} Blocks: top area (shipping bar, announcements) {%- endcomment -%}
            {%- for block in section.blocks -%}
              {%- case block.type -%}

                {%- when 'free_shipping_bar' -%}
                  {%- liquid
                    assign threshold = block.settings.threshold | default: settings.free_shipping_threshold | times: 100
                    assign cart_total = cart.total_price
                    assign remaining = threshold | minus: cart_total
                    assign progress = cart_total | times: 100.0 | divided_by: threshold
                    if progress > 100
                      assign progress = 100
                    endif
                  -%}
                  <div class="main-cart__shipping-bar" {{ block.shopify_attributes }} style="--progress: {{ progress }}%;">
                    <div class="main-cart__shipping-progress">
                      <div class="main-cart__shipping-fill"></div>
                    </div>
                    <p class="main-cart__shipping-text">
                      {%- if remaining > 0 -%}
                        {%- assign remaining_formatted = remaining | money -%}
                        {{ 'cart.free_shipping_remaining' | t: amount: remaining_formatted }}
                      {%- else -%}
                        {{ 'cart.free_shipping_reached' | t }}
                      {%- endif -%}
                    </p>
                  </div>

                {%- when 'announcement' -%}
                  {%- if block.settings.text != blank -%}
                    <div class="main-cart__announcement" {{ block.shopify_attributes }}>
                      {%- if block.settings.icon != 'none' -%}
                        <span class="main-cart__announcement-icon">
                          {%- render 'icon', name: block.settings.icon, size: 16 -%}
                        </span>
                      {%- endif -%}
                      <p class="main-cart__announcement-text">{{ block.settings.text }}</p>
                    </div>
                  {%- endif -%}

              {%- endcase -%}
            {%- endfor -%}

            {%- comment -%} Blocks: notes area {%- endcomment -%}
            {%- for block in section.blocks -%}
              {%- case block.type -%}

                {%- when 'cart_note' -%}
                  <details class="main-cart__notes" {{ block.shopify_attributes }}>
                    <summary class="main-cart__notes-toggle label">
                      {{ 'cart.note' | t }}
                    </summary>
                    <div class="main-cart__notes-content">
                      <textarea name="note" class="main-cart__notes-textarea" placeholder="{{ 'cart.note_placeholder' | t }}">{{ cart.note }}</textarea>
                    </div>
                  </details>

                {%- when 'gift_note' -%}
                  <details class="main-cart__notes" {{ block.shopify_attributes }}>
                    <summary class="main-cart__notes-toggle label">
                      {%- render 'icon', name: 'gift', size: 14 -%}
                      {% if block.settings.label != blank %}{{ block.settings.label }}{% else %}{{ 'cart.gift_note' | t }}{% endif %}
                    </summary>
                    <div class="main-cart__notes-content">
                      <textarea
                        name="attributes[gift_note]"
                        class="main-cart__notes-textarea"
                        placeholder="{% if block.settings.placeholder != blank %}{{ block.settings.placeholder }}{% else %}{{ 'cart.gift_note_placeholder' | t }}{% endif %}"
                      >{{ cart.attributes['gift_note'] }}</textarea>
                    </div>
                  </details>

              {%- endcase -%}
            {%- endfor -%}

            {%- comment -%} Trust badges block {%- endcomment -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'trust_badges' -%}
                <div class="main-cart__trust" {{ block.shopify_attributes }}>
                  {%- if block.settings.badge_1_text != blank -%}
                    <div class="main-cart__trust-item">
                      {%- render 'icon', name: block.settings.badge_1_icon, size: 16 -%}
                      <span>{{ block.settings.badge_1_text }}</span>
                    </div>
                  {%- endif -%}
                  {%- if block.settings.badge_2_text != blank -%}
                    <div class="main-cart__trust-item">
                      {%- render 'icon', name: block.settings.badge_2_icon, size: 16 -%}
                      <span>{{ block.settings.badge_2_text }}</span>
                    </div>
                  {%- endif -%}
                  {%- if block.settings.badge_3_text != blank -%}
                    <div class="main-cart__trust-item">
                      {%- render 'icon', name: block.settings.badge_3_icon, size: 16 -%}
                      <span>{{ block.settings.badge_3_text }}</span>
                    </div>
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endfor -%}

            {%- comment -%} Totals {%- endcomment -%}
            <div class="main-cart__totals">
              <div class="main-cart__subtotal">
                <span>{{ 'cart.subtotal' | t }}</span>
                <span class="main-cart__subtotal-price">{{ cart.total_price | money }}</span>
              </div>

              {%- if cart.cart_level_discount_applications.size > 0 -%}
                {%- for discount in cart.cart_level_discount_applications -%}
                  <div class="main-cart__discount">
                    <span>{{ discount.title }}</span>
                    <span>-{{ discount.total_allocated_amount | money }}</span>
                  </div>
                {%- endfor -%}
              {%- endif -%}

              <p class="main-cart__taxes-note">
                {%- if cart.taxes_included and shop.shipping_policy.body != blank -%}
                  {{ 'cart.taxes_included_shipping_at_checkout_html' | t: link: shop.shipping_policy.url }}
                {%- elsif cart.taxes_included -%}
                  {{ 'cart.taxes_included_but_shipping_at_checkout' | t }}
                {%- elsif shop.shipping_policy.body != blank -%}
                  {{ 'cart.taxes_and_shipping_at_checkout_html' | t: link: shop.shipping_policy.url }}
                {%- else -%}
                  {{ 'cart.taxes_and_shipping_at_checkout' | t }}
                {%- endif -%}
              </p>
            </div>

            <button type="submit" name="checkout" class="btn btn--primary main-cart__checkout">
              <span class="btn__label">{{ 'cart.checkout' | t }}</span>
              <span class="btn__fill" aria-hidden="true"></span>
            </button>

            {%- if additional_checkout_buttons -%}
              <div class="main-cart__dynamic-checkout">
                {{ content_for_additional_checkout_buttons }}
              </div>
            {%- endif -%}

            {%- if show_payment_icons -%}
              <div class="main-cart__payment-icons">
                {%- for type in shop.enabled_payment_types -%}
                  {{ type | payment_type_svg_tag: class: 'main-cart__payment-icon' }}
                {%- endfor -%}
              </div>
            {%- endif -%}
          </div>

        </div>
      </form>

      {%- comment -%} Upsell — outside the cart form (no nested forms); plain
         POST reloads /cart with the item added {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'cart_upsell' and block.settings.collection != blank -%}
          {%- liquid
            assign upsell_collection = collections[block.settings.collection]
            assign upsell_max = block.settings.max_products | default: 3
            assign upsell_shown = 0
          -%}
          {%- if upsell_collection.products_count > 0 -%}
            <div class="main-cart__upsell" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <p class="main-cart__upsell-heading label">{{ block.settings.heading }}</p>
              {%- endif -%}
              <div class="main-cart__upsell-list">
                {%- for upsell_product in upsell_collection.products limit: 24 -%}
                  {%- if upsell_shown >= upsell_max -%}{%- break -%}{%- endif -%}
                  {%- unless upsell_product.available -%}{%- continue -%}{%- endunless -%}
                  {%- assign upsell_in_cart = false -%}
                  {%- for line in cart.items -%}
                    {%- if line.product_id == upsell_product.id -%}
                      {%- assign upsell_in_cart = true -%}
                      {%- break -%}
                    {%- endif -%}
                  {%- endfor -%}
                  {%- if upsell_in_cart -%}{%- continue -%}{%- endif -%}
                  {%- assign upsell_shown = upsell_shown | plus: 1 -%}
                  {%- assign upsell_variant = upsell_product.selected_or_first_available_variant -%}
                  <div class="main-cart__upsell-item">
                    <a href="{{ upsell_product.url }}" class="main-cart__upsell-image" tabindex="-1" aria-hidden="true">
                      {%- if upsell_product.featured_image -%}
                        {{ upsell_product.featured_image | image_url: width: 200 | image_tag:
                          loading: 'lazy',
                          widths: '100,200',
                          class: 'main-cart__upsell-img',
                          alt: upsell_product.featured_image.alt | default: upsell_product.title
                        }}
                      {%- endif -%}
                    </a>
                    <div class="main-cart__upsell-info">
                      <a href="{{ upsell_product.url }}" class="main-cart__upsell-title">{{ upsell_product.title }}</a>
                      <span class="main-cart__upsell-price">{{ upsell_variant.price | money }}</span>
                    </div>
                    <form action="{{ routes.cart_add_url }}" method="post" class="main-cart__upsell-form">
                      <input type="hidden" name="id" value="{{ upsell_variant.id }}">
                      <input type="hidden" name="quantity" value="1">
                      <button type="submit" class="main-cart__upsell-add btn btn--outline" aria-label="{{ 'cart.add_upsell' | t: title: upsell_product.title }}">
                        <span class="btn__label">{{ 'product.add_to_cart' | t }}</span>
                        <span class="btn__fill" aria-hidden="true"></span>
                      </button>
                    </form>
                  </div>
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}

    {%- else -%}
      <div class="main-cart__empty">
        <span class="main-cart__empty-icon" aria-hidden="true">
          {%- render 'icon', name: 'bag', size: 48 -%}
        </span>
        <p class="main-cart__empty-title">{{ 'cart.empty' | t }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary main-cart__empty-btn">
          <span class="btn__label">{{ 'cart.continue_shopping' | t }}</span>
          <span class="btn__fill" aria-hidden="true"></span>
        </a>
      </div>
    {%- endif -%}
    </main-cart-section>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main_cart.name",
  "tag": "section",
  "class": "section-main-cart",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "t:sections.main_cart.show_payment_icons",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.main_cart.color_scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "free_shipping_bar",
      "name": "t:sections.cart_drawer.blocks.free_shipping_bar",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "threshold",
          "label": "t:sections.cart_drawer.blocks.shipping_threshold",
          "info": "t:sections.cart_drawer.blocks.shipping_threshold_info"
        }
      ]
    },
    {
      "type": "cart_upsell",
      "name": "t:sections.cart_drawer.blocks.cart_upsell",
      "limit": 1,
      "settings": [
        {
          "type": "paragraph",
          "content": "t:sections.cart_drawer.blocks.cart_upsell_info"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.cart_drawer.blocks.cart_upsell_heading",
          "default": "Complete your order"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "t:sections.cart_drawer.blocks.cart_upsell_collection"
        },
        {
          "type": "range",
          "id": "max_products",
          "label": "t:sections.cart_drawer.blocks.cart_upsell_max",
          "min": 2,
          "max": 4,
          "step": 1,
          "default": 3
        }
      ]
    },
    {
      "type": "announcement",
      "name": "t:sections.cart_drawer.blocks.announcement",
      "limit": 2,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "t:sections.cart_drawer.blocks.icon",
          "options": [
            { "value": "none", "label": "t:sections.cart_drawer.blocks.icon_none" },
            { "value": "gift", "label": "t:sections.cart_drawer.blocks.icon_gift" },
            { "value": "shipping", "label": "t:sections.cart_drawer.blocks.icon_shipping" },
            { "value": "lock", "label": "t:sections.cart_drawer.blocks.icon_lock" },
            { "value": "leaf", "label": "t:sections.cart_drawer.blocks.icon_leaf" },
            { "value": "heart", "label": "t:sections.cart_drawer.blocks.icon_heart" },
            { "value": "diamond", "label": "t:sections.cart_drawer.blocks.icon_diamond" },
            { "value": "crown", "label": "t:sections.cart_drawer.blocks.icon_crown" },
            { "value": "sparkle", "label": "t:sections.cart_drawer.blocks.icon_sparkle" }
          ],
          "default": "gift"
        },
        {
          "type": "text",
          "id": "text",
          "label": "t:sections.cart_drawer.blocks.announcement_text",
          "default": "Complimentary gift wrapping on all orders"
        }
      ]
    },
    {
      "type": "cart_note",
      "name": "t:sections.cart_drawer.blocks.cart_note",
      "limit": 1
    },
    {
      "type": "gift_note",
      "name": "t:sections.cart_drawer.blocks.gift_note",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "t:sections.cart_drawer.blocks.gift_note_label",
          "default": "Add a gift message"
        },
        {
          "type": "text",
          "id": "placeholder",
          "label": "t:sections.cart_drawer.blocks.gift_note_placeholder",
          "default": "Write your personal message here..."
        }
      ]
    },
    {
      "type": "trust_badges",
      "name": "t:sections.cart_drawer.blocks.trust_badges",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "badge_1_icon",
          "label": "t:sections.cart_drawer.blocks.badge_1_icon",
          "options": [
            { "value": "shipping", "label": "t:sections.cart_drawer.blocks.icon_shipping" },
            { "value": "lock", "label": "t:sections.cart_drawer.blocks.icon_lock" },
            { "value": "return", "label": "t:sections.cart_drawer.blocks.icon_return" },
            { "value": "shield", "label": "t:sections.cart_drawer.blocks.icon_shield" },
            { "value": "leaf", "label": "t:sections.cart_drawer.blocks.icon_leaf" },
            { "value": "gift", "label": "t:sections.cart_drawer.blocks.icon_gift" },
            { "value": "heart", "label": "t:sections.cart_drawer.blocks.icon_heart" },
            { "value": "diamond", "label": "t:sections.cart_drawer.blocks.icon_diamond" }
          ],
          "default": "shipping"
        },
        {
          "type": "text",
          "id": "badge_1_text",
          "label": "t:sections.cart_drawer.blocks.badge_1_text",
          "default": "Free shipping"
        },
        {
          "type": "select",
          "id": "badge_2_icon",
          "label": "t:sections.cart_drawer.blocks.badge_2_icon",
          "options": [
            { "value": "shipping", "label": "t:sections.cart_drawer.blocks.icon_shipping" },
            { "value": "lock", "label": "t:sections.cart_drawer.blocks.icon_lock" },
            { "value": "return", "label": "t:sections.cart_drawer.blocks.icon_return" },
            { "value": "shield", "label": "t:sections.cart_drawer.blocks.icon_shield" },
            { "value": "leaf", "label": "t:sections.cart_drawer.blocks.icon_leaf" },
            { "value": "gift", "label": "t:sections.cart_drawer.blocks.icon_gift" },
            { "value": "heart", "label": "t:sections.cart_drawer.blocks.icon_heart" },
            { "value": "diamond", "label": "t:sections.cart_drawer.blocks.icon_diamond" }
          ],
          "default": "lock"
        },
        {
          "type": "text",
          "id": "badge_2_text",
          "label": "t:sections.cart_drawer.blocks.badge_2_text",
          "default": "Secure checkout"
        },
        {
          "type": "select",
          "id": "badge_3_icon",
          "label": "t:sections.cart_drawer.blocks.badge_3_icon",
          "options": [
            { "value": "shipping", "label": "t:sections.cart_drawer.blocks.icon_shipping" },
            { "value": "lock", "label": "t:sections.cart_drawer.blocks.icon_lock" },
            { "value": "return", "label": "t:sections.cart_drawer.blocks.icon_return" },
            { "value": "shield", "label": "t:sections.cart_drawer.blocks.icon_shield" },
            { "value": "leaf", "label": "t:sections.cart_drawer.blocks.icon_leaf" },
            { "value": "gift", "label": "t:sections.cart_drawer.blocks.icon_gift" },
            { "value": "heart", "label": "t:sections.cart_drawer.blocks.icon_heart" },
            { "value": "diamond", "label": "t:sections.cart_drawer.blocks.icon_diamond" }
          ],
          "default": "return"
        },
        {
          "type": "text",
          "id": "badge_3_text",
          "label": "t:sections.cart_drawer.blocks.badge_3_text",
          "default": "Easy returns"
        }
      ]
    }
  ]
}
{% endschema %}
