{%- comment -%}
  Editorial Story — Immersive vertical storytelling section
  Alternating blocks of full-width images, centered text, pull quotes, and videos
  Inspiration: Jacquemus campaigns, Dior Savoir-faire pages
{%- endcomment -%}

{{ 'section-editorial.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign color_scheme = section.settings.color_scheme
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
-%}

{%- style -%}
  #Section-{{ section.id }} {
    --section-padding-top: {{ padding_top }}px;
    --section-padding-bottom: {{ padding_bottom }}px;
  }
{%- endstyle -%}

<div
  id="Section-{{ section.id }}"
  class="editorial color-{{ color_scheme }}"
  data-section-id="{{ section.id }}"
>
  {%- for block in section.blocks -%}
    {%- case block.type -%}

      {%- comment -%} === IMAGE BLOCK === {%- endcomment -%}
      {%- when 'image' -%}
        {%- liquid
          assign layout = block.settings.layout
          assign overlay_opacity = block.settings.overlay_opacity | divided_by: 100.0
        -%}
        <div class="editorial__block editorial__image-block editorial__image-block--{{ layout }}" data-stagger {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 2560
              | image_tag:
                alt: block.settings.image.alt | default: block.settings.caption,
                widths: '375, 750, 1100, 1500, 2000, 2560',
                sizes: '100vw',
                loading: 'lazy',
                class: 'editorial__image'
            }}
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'editorial__image placeholder-svg' }}
          {%- endif -%}

          {%- if overlay_opacity > 0 and layout == 'full' -%}
            <div class="editorial__image-overlay" style="--editorial-overlay: {{ overlay_opacity }};"></div>
          {%- endif -%}

          {%- if block.settings.caption != blank and layout == 'full' -%}
            <div class="editorial__image-caption">
              <p>{{ block.settings.caption }}</p>
            </div>
          {%- endif -%}
        </div>

      {%- comment -%} === TEXT BLOCK === {%- endcomment -%}
      {%- when 'text' -%}
        <div class="editorial__block editorial__text-block" data-stagger {{ block.shopify_attributes }}>
          <div class="editorial__text-inner editorial__text-inner--{{ block.settings.alignment }}">
            {%- if block.settings.subheading != blank -%}
              <p class="editorial__text-subheading subheading">{{ block.settings.subheading }}</p>
            {%- endif -%}
            {%- if block.settings.heading != blank -%}
              <h2 class="editorial__text-heading h3">{{ block.settings.heading }}</h2>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <div class="editorial__text-body rte">{{ block.settings.text }}</div>
            {%- endif -%}
            {%- if block.settings.button_label != blank -%}
              <div class="editorial__text-cta">
                <a href="{{ block.settings.button_link }}" class="btn btn--{{ block.settings.button_style | default: 'outline' }}">
                  <span class="btn__label">{{ block.settings.button_label }}</span>
                  <span class="btn__fill" aria-hidden="true"></span>
                </a>
              </div>
            {%- endif -%}
          </div>
        </div>

      {%- comment -%} === QUOTE BLOCK === {%- endcomment -%}
      {%- when 'quote' -%}
        <div class="editorial__block editorial__quote-block" data-stagger {{ block.shopify_attributes }}>
          <blockquote class="editorial__quote-inner">
            <span class="editorial__quote-mark" aria-hidden="true">&ldquo;</span>
            {%- if block.settings.text != blank -%}
              <p class="editorial__quote-text">{{ block.settings.text }}</p>
            {%- endif -%}
            {%- if block.settings.attribution != blank -%}
              <cite class="editorial__quote-attribution">{{ block.settings.attribution }}</cite>
            {%- endif -%}
          </blockquote>
        </div>

      {%- comment -%} === VIDEO BLOCK === {%- endcomment -%}
      {%- when 'video' -%}
        {%- liquid
          assign vid_layout = block.settings.layout | default: 'contained'
        -%}
        <div class="editorial__block editorial__video-block editorial__video-block--{{ vid_layout }}" data-stagger {{ block.shopify_attributes }}>
          {%- if block.settings.video != blank -%}
            {{
              block.settings.video
              | video_tag:
                autoplay: true,
                loop: true,
                muted: true,
                playsinline: true,
                class: 'editorial__video'
            }}
          {%- elsif block.settings.video_url != blank -%}
            {%- if block.settings.video_url.type == 'youtube' -%}
              <iframe
                class="editorial__video"
                src="https://www.youtube.com/embed/{{ block.settings.video_url.id }}?autoplay=1&mute=1&loop=1&playlist={{ block.settings.video_url.id }}&controls=0&showinfo=0"
                allow="autoplay; encrypted-media"
                allowfullscreen
                loading="lazy"
                title="{{ block.settings.caption | default: 'accessibility.video' | t }}"
              ></iframe>
            {%- elsif block.settings.video_url.type == 'vimeo' -%}
              <iframe
                class="editorial__video"
                src="https://player.vimeo.com/video/{{ block.settings.video_url.id }}?autoplay=1&muted=1&loop=1&background=1"
                allow="autoplay; encrypted-media"
                allowfullscreen
                loading="lazy"
                title="{{ block.settings.caption | default: 'accessibility.video' | t }}"
              ></iframe>
            {%- endif -%}
          {%- endif -%}
        </div>

    {%- endcase -%}
  {%- endfor -%}
</div>

{% schema %}
{
  "name": "t:sections.editorial.name",
  "tag": "section",
  "class": "section-editorial",
  "disabled_on": {
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.editorial.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.editorial.padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.editorial.padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "t:sections.editorial.block_image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.editorial.image"
        },
        {
          "type": "select",
          "id": "layout",
          "label": "t:sections.editorial.image_layout",
          "options": [
            { "value": "full", "label": "t:sections.editorial.layout_full" },
            { "value": "contained", "label": "t:sections.editorial.layout_contained" }
          ],
          "default": "full"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "t:sections.editorial.overlay_opacity",
          "min": 0,
          "max": 60,
          "step": 5,
          "unit": "%",
          "default": 0
        },
        {
          "type": "text",
          "id": "caption",
          "label": "t:sections.editorial.caption"
        }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.editorial.block_text",
      "settings": [
        {
          "type": "text",
          "id": "subheading",
          "label": "t:sections.editorial.subheading"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.editorial.heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "t:sections.editorial.text"
        },
        {
          "type": "select",
          "id": "alignment",
          "label": "t:sections.editorial.text_alignment",
          "options": [
            { "value": "left", "label": "t:sections.editorial.align_left" },
            { "value": "center", "label": "t:sections.editorial.align_center" }
          ],
          "default": "center"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "t:sections.editorial.button_label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "t:sections.editorial.button_link"
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "t:sections.editorial.button_style",
          "options": [
            { "value": "primary", "label": "t:sections.editorial.button_primary" },
            { "value": "secondary", "label": "t:sections.editorial.button_secondary" },
            { "value": "outline", "label": "t:sections.editorial.button_outline" }
          ],
          "default": "outline"
        }
      ]
    },
    {
      "type": "quote",
      "name": "t:sections.editorial.block_quote",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "t:sections.editorial.quote_text",
          "default": "Beauty is in the details."
        },
        {
          "type": "text",
          "id": "attribution",
          "label": "t:sections.editorial.quote_attribution"
        }
      ]
    },
    {
      "type": "video",
      "name": "t:sections.editorial.block_video",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "t:sections.editorial.video"
        },
        {
          "type": "video_url",
          "id": "video_url",
          "label": "t:sections.editorial.video_url",
          "info": "t:sections.editorial.video_url_info",
          "accept": ["youtube", "vimeo"]
        },
        {
          "type": "select",
          "id": "layout",
          "label": "t:sections.editorial.video_layout",
          "options": [
            { "value": "full", "label": "t:sections.editorial.layout_full" },
            { "value": "contained", "label": "t:sections.editorial.layout_contained" }
          ],
          "default": "contained"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "t:sections.editorial.caption"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.editorial.preset_name",
      "blocks": [
        { "type": "image" },
        { "type": "text", "settings": { "heading": "Our story", "text": "<p>Every piece tells a story of craftsmanship, heritage, and timeless elegance.</p>" } },
        { "type": "quote", "settings": { "text": "Beauty is in the details.", "attribution": "— Creative Director" } },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
