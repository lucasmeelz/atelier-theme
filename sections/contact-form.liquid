{%- comment -%}
  Contact Form — Styled contact form with name, email, phone, message
  Used in page.contact.json template
{%- endcomment -%}

{%- liquid
  assign color_scheme = section.settings.color_scheme
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign content_width = section.settings.content_width
  assign show_phone = section.settings.show_phone
-%}

{%- style -%}
  #Section-{{ section.id }} {
    --section-padding-top: {{ padding_top }}px;
    --section-padding-bottom: {{ padding_bottom }}px;
  }

  .contact-form-section {
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
  }

  .contact-form__container {
    max-width: {{ content_width }}px;
    margin: 0 auto;
    padding: 0 var(--page-margin);
  }

  .contact-form__heading {
    margin: 0 0 12px;
  }

  .contact-form__text {
    margin: 0 0 40px;
    color: rgb(var(--color-text-subdued));
    line-height: var(--body-line-height);
  }

  .contact-form__form {
    display: grid;
    gap: 20px;
  }

  .contact-form__row {
    display: grid;
    gap: 20px;
  }

  @media screen and (min-width: 750px) {
    .contact-form__row--half {
      grid-template-columns: 1fr 1fr;
    }
  }

  .contact-form__field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .contact-form__label {
    font-family: var(--font-label-family);
    font-size: var(--label-font-size);
    font-weight: var(--font-label-weight);
    text-transform: var(--label-text-transform);
    letter-spacing: var(--label-letter-spacing);
  }

  .contact-form__input,
  .contact-form__textarea {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid rgb(var(--color-border));
    border-radius: var(--input-border-radius);
    background: transparent;
    font-family: var(--font-body-family);
    font-size: var(--body-font-size);
    color: rgb(var(--color-text));
    transition: border-color var(--duration-fast) var(--ease-ecrin);
  }

  .contact-form__input:focus,
  .contact-form__textarea:focus {
    outline: none;
    border-color: rgb(var(--color-text));
  }

  .contact-form__input::placeholder,
  .contact-form__textarea::placeholder {
    color: rgb(var(--color-text-subdued));
  }

  .contact-form__textarea {
    min-height: 160px;
    resize: vertical;
  }

  .contact-form__submit {
    justify-self: start;
  }

  .contact-form__success {
    padding: 16px 20px;
    border: 1px solid rgb(var(--color-border));
    border-radius: var(--input-border-radius);
    color: rgb(var(--color-text));
    margin-bottom: 24px;
  }

  .contact-form__errors {
    padding: 16px 20px;
    border: 1px solid rgb(var(--color-accent));
    border-radius: var(--input-border-radius);
    color: rgb(var(--color-text));
    margin-bottom: 24px;
  }
{%- endstyle -%}

<section
  id="Section-{{ section.id }}"
  class="contact-form-section color-{{ color_scheme }} full-width"
>
  <div class="contact-form__container">

    {%- if section.settings.heading != blank -%}
      <h1 class="contact-form__heading h2">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.settings.text != blank -%}
      <p class="contact-form__text">{{ section.settings.text }}</p>
    {%- endif -%}

    {%- form 'contact', id: 'ContactForm' -%}
      {%- if form.posted_successfully? -%}
        <div class="contact-form__success" role="status" autofocus tabindex="-1">
          {{ 'contact.success' | t }}
        </div>
      {%- endif -%}

      {%- if form.errors -%}
        <div class="contact-form__errors" role="alert">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <div class="contact-form__form">
        <div class="contact-form__row contact-form__row--half">
          <div class="contact-form__field">
            <label class="contact-form__label" for="ContactForm-name">
              {{ 'contact.name' | t }}
            </label>
            <input
              type="text"
              id="ContactForm-name"
              name="contact[{{ 'contact.name' | t }}]"
              class="contact-form__input"
              value="{{ form.name }}"
              autocomplete="name"
            >
          </div>

          <div class="contact-form__field">
            <label class="contact-form__label" for="ContactForm-email">
              {{ 'contact.email' | t }} <span aria-hidden="true">*</span>
            </label>
            <input
              type="email"
              id="ContactForm-email"
              name="contact[email]"
              class="contact-form__input"
              value="{{ form.email }}"
              autocomplete="email"
              required
            >
          </div>
        </div>

        {%- if show_phone -%}
          <div class="contact-form__field">
            <label class="contact-form__label" for="ContactForm-phone">
              {{ 'contact.phone' | t }}
            </label>
            <input
              type="tel"
              id="ContactForm-phone"
              name="contact[{{ 'contact.phone' | t }}]"
              class="contact-form__input"
              value="{{ form.phone }}"
              autocomplete="tel"
            >
          </div>
        {%- endif -%}

        <div class="contact-form__field">
          <label class="contact-form__label" for="ContactForm-message">
            {{ 'contact.message' | t }}
          </label>
          <textarea
            id="ContactForm-message"
            name="contact[{{ 'contact.message' | t }}]"
            class="contact-form__textarea"
            rows="6"
          >{{ form.body }}</textarea>
        </div>

        <button type="submit" class="contact-form__submit btn btn--primary">
          <span class="btn__label">{{ 'contact.submit' | t }}</span>
          <span class="btn__fill" aria-hidden="true"></span>
        </button>
      </div>
    {%- endform -%}

  </div>
</section>

{% schema %}
{
  "name": "t:sections.contact_form.name",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.contact_form.heading",
      "default": "Contact us"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "t:sections.contact_form.text",
      "default": "Have a question or need assistance? Fill out the form below and we'll get back to you as soon as possible."
    },
    {
      "type": "checkbox",
      "id": "show_phone",
      "label": "t:sections.contact_form.show_phone",
      "default": true
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "t:sections.rich_text.content_width",
      "min": 500,
      "max": 900,
      "step": 50,
      "unit": "px",
      "default": 700
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.blog_posts.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.blog_posts.padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.blog_posts.padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "t:sections.contact_form.preset_name"
    }
  ]
}
{% endschema %}
