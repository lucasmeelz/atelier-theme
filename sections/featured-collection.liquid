{%- comment -%}
  Featured Collection — Product grid section
  Displays products from a selected collection in a responsive grid
  Supports: 2-5 columns desktop, 1-2 mobile, image ratios, secondary image hover,
  vendor, rating, quick add, view all button
{%- endcomment -%}

{{ 'section-featured-collection.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign collection = section.settings.collection
  assign products_to_show = section.settings.products_to_show
  assign columns_desktop = section.settings.columns_desktop
  assign columns_mobile = section.settings.columns_mobile
  assign image_ratio = section.settings.image_ratio
  assign show_secondary_image = section.settings.show_secondary_image
  assign show_vendor = section.settings.show_vendor
  assign show_rating = section.settings.show_rating
  assign show_quick_add = section.settings.show_quick_add
  assign heading = section.settings.heading
  assign heading_size = section.settings.heading_size
  assign subheading = section.settings.subheading
  assign button_label = section.settings.button_label
  assign button_link = section.settings.button_link
  assign color_scheme = section.settings.color_scheme
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom

  if collection == blank
    assign placeholder_count = products_to_show
  endif
-%}

{%- style -%}
  #Section-{{ section.id }} {
    --section-padding-top: {{ padding_top }}px;
    --section-padding-bottom: {{ padding_bottom }}px;
    --grid-columns-desktop: {{ columns_desktop }};
    --grid-columns-mobile: {{ columns_mobile }};
  }
{%- endstyle -%}

<div
  id="Section-{{ section.id }}"
  class="featured-collection color-{{ color_scheme }}"
>
  <div class="container">
    {%- comment -%} Header — heading + subheading + view all {%- endcomment -%}
    {%- if heading != blank or subheading != blank or button_label != blank -%}
      <div class="featured-collection__header">
        <div class="featured-collection__header-text">
          {%- if subheading != blank -%}
            <p class="featured-collection__subheading label">{{ subheading }}</p>
          {%- endif -%}
          {%- if heading != blank -%}
            <{{ heading_size }} class="featured-collection__heading">{{ heading }}</{{ heading_size }}>
          {%- endif -%}
        </div>
        {%- if button_label != blank -%}
          <a href="{{ button_link | default: collection.url | default: routes.all_products_collection_url }}" class="featured-collection__view-all link-underline">
            {{ button_label }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} Product grid {%- endcomment -%}
    <div class="featured-collection__grid">
      {%- if collection != blank -%}
        {%- for product in collection.products limit: products_to_show -%}
          <div class="featured-collection__item">
            {%- render 'card-product',
              product: product,
              image_ratio: image_ratio,
              show_secondary_image: show_secondary_image,
              show_vendor: show_vendor,
              show_quick_add: show_quick_add,
              columns: columns_desktop,
              lazy: true,
              section_id: section.id
            -%}
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} Placeholder products when no collection selected {%- endcomment -%}
        {%- for i in (1..products_to_show) -%}
          <div class="featured-collection__item">
            <div class="card-product">
              <div class="card-product__media">
                <div class="card-product__media-wrapper"{% if image_ratio != 'adapt' %} style="--card-image-ratio: {% case image_ratio %}{% when 'portrait' %}3 / 4{% when 'square' %}1 / 1{% when 'landscape' %}4 / 3{% endcase %};"{% endif %}>
                  <div class="card-product__placeholder">
                    {%- capture placeholder_name -%}product-{{ i | modulo: 6 | plus: 1 }}{%- endcapture -%}
                    {{ placeholder_name | placeholder_svg_tag: 'card-product__placeholder-svg' }}
                  </div>
                </div>
              </div>
              <div class="card-product__info">
                <h3 class="card-product__title">
                  <a href="#">{{ 'product.placeholder_title' | t }}</a>
                </h3>
                <div class="price">
                  <div class="price__regular">
                    <span class="price__current">{{ 9999 | money }}</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- comment -%} Mobile view all button (shown below grid on mobile) {%- endcomment -%}
    {%- if button_label != blank -%}
      <div class="featured-collection__footer">
        <a href="{{ button_link | default: collection.url | default: routes.all_products_collection_url }}" class="btn btn--outline-dark">
          <span class="btn__label">{{ button_label }}</span>
          <span class="btn__fill" aria-hidden="true"></span>
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.featured_collection.name",
  "tag": "section",
  "class": "section-featured-collection",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.featured_collection.content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.featured_collection.heading",
      "default": "Featured collection"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.featured_collection.heading_size",
      "options": [
        { "value": "h2", "label": "t:sections.featured_collection.heading_large" },
        { "value": "h3", "label": "t:sections.featured_collection.heading_medium" }
      ],
      "default": "h2"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.featured_collection.subheading"
    },
    {
      "type": "header",
      "content": "t:sections.featured_collection.collection_header"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.featured_collection.collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "t:sections.featured_collection.products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "t:sections.featured_collection.layout_header"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "t:sections.featured_collection.columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "t:sections.featured_collection.columns_mobile",
      "options": [
        { "value": "1", "label": "t:sections.featured_collection.columns_1" },
        { "value": "2", "label": "t:sections.featured_collection.columns_2" }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "t:sections.featured_collection.image_ratio",
      "options": [
        { "value": "adapt", "label": "t:sections.featured_collection.ratio_adapt" },
        { "value": "portrait", "label": "t:sections.featured_collection.ratio_portrait" },
        { "value": "square", "label": "t:sections.featured_collection.ratio_square" },
        { "value": "landscape", "label": "t:sections.featured_collection.ratio_landscape" }
      ],
      "default": "portrait"
    },
    {
      "type": "header",
      "content": "t:sections.featured_collection.card_header"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "label": "t:sections.featured_collection.show_secondary_image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "t:sections.featured_collection.show_vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "t:sections.featured_collection.show_rating",
      "default": false,
      "info": "t:sections.featured_collection.show_rating_info"
    },
    {
      "type": "checkbox",
      "id": "show_quick_add",
      "label": "t:sections.featured_collection.show_quick_add",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.featured_collection.button_header"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.featured_collection.button_label",
      "default": "View all"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.featured_collection.button_link"
    },
    {
      "type": "header",
      "content": "t:sections.featured_collection.style_header"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.featured_collection.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.featured_collection.padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.featured_collection.padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured_collection.preset_name"
    }
  ]
}
{% endschema %}
