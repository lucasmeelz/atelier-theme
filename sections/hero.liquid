{%- comment -%}
  Hero — Section shell that hosts theme blocks.
  The merchant composes the hero by adding/reordering blocks (media,
  content, eyebrow, heading, button, …) inside the section. Section
  settings cover only what is truly section-level: layout, height,
  color scheme, and section-wide options.
{%- endcomment -%}

{{ 'section-hero.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign height = section.settings.height
  assign height_mobile = section.settings.height_mobile
  assign container_width = section.settings.container_width | default: 'full'
  assign show_scroll = section.settings.show_scroll_indicator
  assign color_scheme = section.settings.color_scheme

  case height
    when 'full'
      assign hero_height = 'calc(100svh - var(--header-height, 0px))'
    when 'large'
      assign hero_height = '80vh'
    when 'medium'
      assign hero_height = '60vh'
    when 'small'
      assign hero_height = '40vh'
  endcase

  assign hero_height_mobile = hero_height
  case height_mobile
    when 'full'
      assign hero_height_mobile = '100svh'
    when 'large'
      assign hero_height_mobile = '80vh'
    when 'medium'
      assign hero_height_mobile = '60vh'
    when 'small'
      assign hero_height_mobile = '40vh'
  endcase
-%}

{%- style -%}
  #Hero-{{ section.id }} {
    --hero-height: {{ hero_height }};
    --hero-height-mobile: {{ hero_height_mobile }};
  }
{%- endstyle -%}

<hero-section
  class="full-width"
  id="Hero-{{ section.id }}"
  data-section-id="{{ section.id }}"
>
  <div class="hero hero--{{ container_width }} color-{{ color_scheme }}">
    {%- comment -%}
      Static blocks: merchant configures them via the section settings in
      the customizer but can't add, remove, duplicate or reorder them.
      That guarantees one hero-media + one hero-content per Hero section.
    {%- endcomment -%}
    {% content_for 'block', type: 'hero-media', id: 'media' %}
    {% content_for 'block', type: 'hero-content', id: 'content' %}

    {%- if show_scroll -%}
      <div class="hero__scroll-indicator motion-auto" aria-hidden="true">
        {%- render 'icon', name: 'chevron-down', size: 20 -%}
      </div>
    {%- endif -%}
  </div>
</hero-section>

<script src="{{ 'section-hero.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "t:sections.hero.name",
  "tag": "section",
  "class": "section-hero",
  "disabled_on": {
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.hero.layout"
    },
    {
      "type": "select",
      "id": "height",
      "label": "t:sections.hero.height",
      "options": [
        { "value": "full",   "label": "t:sections.hero.height_full" },
        { "value": "large",  "label": "t:sections.hero.height_large" },
        { "value": "medium", "label": "t:sections.hero.height_medium" },
        { "value": "small",  "label": "t:sections.hero.height_small" }
      ],
      "default": "full"
    },
    {
      "type": "select",
      "id": "height_mobile",
      "label": "t:sections.hero.height_mobile",
      "options": [
        { "value": "auto",   "label": "t:sections.hero.height_mobile_auto" },
        { "value": "full",   "label": "t:sections.hero.height_full" },
        { "value": "large",  "label": "t:sections.hero.height_large" },
        { "value": "medium", "label": "t:sections.hero.height_medium" },
        { "value": "small",  "label": "t:sections.hero.height_small" }
      ],
      "default": "auto",
      "info": "t:sections.hero.height_mobile_info"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "t:sections.hero.container_width",
      "options": [
        { "value": "full",      "label": "t:sections.hero.container_full" },
        { "value": "contained", "label": "t:sections.hero.container_contained" }
      ],
      "default": "full"
    },
    {
      "type": "header",
      "content": "t:sections.hero.options"
    },
    {
      "type": "checkbox",
      "id": "show_scroll_indicator",
      "label": "t:sections.hero.show_scroll_indicator",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.hero.style_header"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.hero.color_scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "t:sections.hero.preset_name"
    }
  ]
}
{% endschema %}
