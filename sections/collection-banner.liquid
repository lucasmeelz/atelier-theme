{%- comment -%}
  Collection Banner — Shows collection title, description, and optional image
  Layouts: plain (text only), background (image behind text), split (image + text side by side)
{%- endcomment -%}

{{ 'section-collection-banner.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign layout = section.settings.layout
  assign show_description = section.settings.show_description
  assign title_size = section.settings.title_size
  assign color_scheme = section.settings.color_scheme
  assign image = collection.image

  assign overlay_opacity = section.settings.overlay_opacity | divided_by: 100.0
-%}

{%- style -%}
  #Section-{{ section.id }} {
    --banner-overlay-opacity: {{ overlay_opacity }};
  }
{%- endstyle -%}

<div
  id="Section-{{ section.id }}"
  class="collection-banner collection-banner--{{ layout }} color-{{ color_scheme }}"
>
  {%- if layout == 'background' and image != blank -%}
    <div class="collection-banner__bg">
      {{ image | image_url: width: 2000 | image_tag:
        loading: 'eager',
        widths: '750,1000,1500,2000',
        sizes: '100vw',
        class: 'collection-banner__bg-img',
        alt: collection.title
      }}
      <div class="collection-banner__overlay" aria-hidden="true"></div>
    </div>
  {%- endif -%}

  <div class="container">
    <div class="collection-banner__inner">
      {%- if layout == 'split' and image != blank -%}
        <div class="collection-banner__media">
          {{ image | image_url: width: 1200 | image_tag:
            loading: 'eager',
            widths: '400,600,800,1200',
            sizes: '(min-width: 990px) 50vw, 100vw',
            class: 'collection-banner__media-img',
            alt: collection.title
          }}
        </div>
      {%- endif -%}

      <div class="collection-banner__content">
        {%- if collection.title != blank -%}
          <h1 class="collection-banner__title collection-banner__title--{{ title_size }}">
            {{- collection.title -}}
          </h1>
        {%- endif -%}

        {%- if show_description and collection.description != blank -%}
          <div class="collection-banner__description rte">
            {{ collection.description }}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Collection banner",
  "tag": "section",
  "class": "section-collection-banner",
  "disabled_on": {
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "plain", "label": "Plain (text only)" },
        { "value": "background", "label": "Image background" },
        { "value": "split", "label": "Image and text side by side" }
      ],
      "default": "plain"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show collection description",
      "default": true
    },
    {
      "type": "select",
      "id": "title_size",
      "label": "Title size",
      "options": [
        { "value": "h1", "label": "Large" },
        { "value": "h2", "label": "Medium" },
        { "value": "h3", "label": "Small" }
      ],
      "default": "h1"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Image overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 30,
      "info": "Only applies to image background layout."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Collection banner"
    }
  ]
}
{% endschema %}
