{{ 'section-header.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-header.js' | asset_url }}" defer="defer"></script>

<sticky-header
  class="header-wrapper{% if section.settings.enable_sticky %} header-wrapper--sticky{% endif %}"
  {% if section.settings.hide_on_scroll %}data-hide-on-scroll="true"{% endif %}
>
  <div class="header__sentinel" data-sentinel></div>

  <header class="header">
    <!-- Left: hamburger -->
    <div class="header__left">
      <button class="header__menu-toggle" data-drawer-open aria-label="{{ 'header.menu' | t }}">
        {%- render 'icon', name: 'menu' -%}
      </button>
    </div>

    <!-- Center: logo -->
    <div class="header__center">
      <a href="{{ routes.root_url }}" class="header__logo">
        {%- if section.settings.logo -%}
          {{
            section.settings.logo
            | image_url: width: section.settings.logo_width
            | image_tag: alt: shop.name, class: 'header__logo-image', widths: '80,120,160,200,240,300'
          }}
        {%- else -%}
          <span class="header__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>

    <!-- Right: icons -->
    <div class="header__right">
      {%- if section.settings.show_search -%}
        <a href="{{ routes.search_url }}" class="header__icon" aria-label="{{ 'header.search' | t }}">
          {%- render 'icon', name: 'search' -%}
        </a>
      {%- endif -%}

      {%- if section.settings.show_wishlist -%}
        <a href="#" class="header__icon" aria-label="{{ 'header.wishlist' | t }}">
          {%- render 'icon', name: 'wishlist' -%}
        </a>
      {%- endif -%}

      {%- if section.settings.show_account and shop.customer_accounts_enabled -%}
        <a href="{{ routes.account_url }}" class="header__icon" aria-label="{{ 'header.account' | t }}">
          {%- render 'icon', name: 'account' -%}
        </a>
      {%- endif -%}

      <a href="{{ routes.cart_url }}" class="header__icon header__icon--cart" aria-label="{{ 'header.cart' | t }}">
        {%- render 'icon', name: 'bag' -%}
        {%- if cart.item_count > 0 -%}
          <span class="header__cart-count">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>
  </header>
</sticky-header>

<menu-drawer>
  {%- render 'menu-drawer',
    tab_1_menu: section.settings.tab_1_menu,
    tab_1_label: section.settings.tab_1_label,
    tab_2_menu: section.settings.tab_2_menu,
    tab_2_label: section.settings.tab_2_label
  -%}
</menu-drawer>

{% schema %}
{
  "name": "t:general.header",
  "class": "shopify-section--header",
  "settings": [
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "select",
      "id": "nav_style",
      "label": "Navigation style",
      "options": [
        { "value": "drawer", "label": "Drawer" },
        { "value": "mega", "label": "Mega menu" }
      ],
      "default": "drawer"
    },
    {
      "type": "checkbox",
      "id": "enable_sticky",
      "label": "Enable sticky header",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "hide_on_scroll",
      "label": "Hide on scroll down",
      "default": false
    },
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 80,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Logo width",
      "default": 120
    },
    {
      "type": "header",
      "content": "Icons"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_wishlist",
      "label": "Show wishlist",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "label": "Show account",
      "default": true
    },
    {
      "type": "header",
      "content": "Menu tabs"
    },
    {
      "type": "text",
      "id": "tab_1_label",
      "label": "Tab 1 label",
      "default": "Fashion"
    },
    {
      "type": "link_list",
      "id": "tab_1_menu",
      "label": "Tab 1 menu",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "tab_2_label",
      "label": "Tab 2 label"
    },
    {
      "type": "link_list",
      "id": "tab_2_menu",
      "label": "Tab 2 menu"
    }
  ]
}
{% endschema %}
