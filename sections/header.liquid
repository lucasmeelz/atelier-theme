{{ 'section-header.css' | asset_url | stylesheet_tag }}

{% comment %} Add sticky class directly to section wrapper via Liquid {% endcomment %}
{%- if section.settings.sticky_header -%}
  <style>
    #shopify-section-{{ section.id }} {
      position: sticky;
      top: 0;
      z-index: 100;
    }
  </style>
{%- endif -%}

{%- style -%}
  html {
    scroll-padding-top: var(--header-height, 64px);
    scroll-behavior: smooth;
  }

  /* Mobile layout grid */
  #shopify-section-{{ section.id }} .header__bar {
    {%- case section.settings.mobile_layout -%}
      {%- when 'logo_center' -%}
        --header-grid: "primary-nav logo secondary-nav" / 1fr auto 1fr;
      {%- when 'logo_left' -%}
        --header-grid: "primary-nav logo secondary-nav" / auto auto 1fr;
    {%- endcase -%}
  }

  /* Desktop layout grid */
  @media screen and (min-width: 990px) {
    #shopify-section-{{ section.id }} .header__bar {
      {%- case section.settings.desktop_layout -%}
        {%- when 'logo_center_nav_below' -%}
          --header-grid: "primary-nav logo secondary-nav" / 1fr auto 1fr;
        {%- when 'logo_left_nav_inline' -%}
          --header-grid: "primary-nav logo desktop-nav secondary-nav" / auto auto 1fr auto;
        {%- when 'logo_left_nav_center' -%}
          --header-grid: "primary-nav logo secondary-nav" / auto auto 1fr;
      {%- endcase -%}
    }
  }

  /* Logo width */
  {%- if section.settings.logo != blank -%}
    #shopify-section-{{ section.id }} .header__logo-image {
      max-width: {{ section.settings.logo_width | times: 0.7 }}px;
    }
    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} .header__logo-image {
        max-width: {{ section.settings.logo_width }}px;
      }
    }
  {%- endif -%}
{%- endstyle -%}

{%- liquid
  assign desktop_layout = section.settings.desktop_layout
  assign menu_style = section.settings.menu_style
  assign header_classes = 'header'
  assign header_classes = header_classes | append: ' header--' | append: menu_style

  if section.settings.sticky_header
    assign header_classes = header_classes | append: ' header--sticky'
  endif

  if section.settings.transparent_header
    assign header_classes = header_classes | append: ' header--transparent'
  endif
-%}

<header-element
  class="{{ header_classes }} color-{{ section.settings.color_scheme }}"
  data-desktop-layout="{{ desktop_layout }}"
  data-mobile-layout="{{ section.settings.mobile_layout }}"
  data-menu-style="{{ menu_style }}"
  data-sticky="{{ section.settings.sticky_header }}"
  data-transparent="{{ section.settings.transparent_header }}"
>
  <div class="header__bar">
    {% comment %} Primary nav — hamburger (+ optional search on split layout) {% endcomment %}
    <nav class="header__primary-nav">
      <button
        class="header__hamburger"
        aria-label="{{ 'header.open_menu' | t }}"
        aria-expanded="false"
        aria-controls="header-drawer"
      >
        <span class="header__hamburger-icon" aria-hidden="true">
          <span></span>
          <span></span>
        </span>
      </button>
    </nav>

    {% comment %} Logo {% endcomment %}
    <a href="{{ routes.root_url }}" class="header__logo">
        {%- if section.settings.logo != blank -%}
          {%- liquid
            assign logo_alt = section.settings.logo.alt | default: shop.name
            assign logo_mobile_width = section.settings.logo_width | times: 0.7 | round
            assign logo_sizes = '(max-width: 749px) ' | append: logo_mobile_width | append: 'px, ' | append: section.settings.logo_width | append: 'px'
          -%}
          <img
            srcset="{{ section.settings.logo | image_url: width: 100 }} 100w,
                    {{ section.settings.logo | image_url: width: 150 }} 150w,
                    {{ section.settings.logo | image_url: width: 200 }} 200w,
                    {{ section.settings.logo | image_url: width: 300 }} 300w"
            src="{{ section.settings.logo | image_url: width: 200 }}"
            sizes="{{ logo_sizes }}"
            alt="{{ logo_alt | escape }}"
            loading="eager"
            fetchpriority="high"
            class="header__logo-image"
            width="{{ section.settings.logo.width }}"
            height="{{ section.settings.logo.height }}"
          >
        {%- else -%}
          <span class="header__logo-text">{{ shop.name }}</span>
        {%- endif -%}
    </a>

    {% comment %} Desktop nav — inline layout (mega mode only) {% endcomment %}
    {%- if desktop_layout == 'logo_left_nav_inline' and menu_style == 'mega' -%}
      <nav class="header__nav header__nav--inline" aria-label="{{ 'header.navigation' | t | default: 'Main navigation' }}">
        {%- render 'header-desktop-nav', menu: section.settings.menu, blocks: section.blocks, color_scheme: section.settings.color_scheme, open_trigger: section.settings.menu_open_trigger -%}
      </nav>
    {%- endif -%}

    {% comment %} Secondary nav — icons {% endcomment %}
    <nav class="header__secondary-nav">
      {%- if section.settings.show_search -%}
        <button class="header__icon-btn header__search-trigger" aria-label="{{ 'header.open_search' | t }}">
          {%- render 'icon', name: 'search' -%}
        </button>
      {%- endif -%}

      {%- if shop.customer_accounts_enabled -%}
        <a href="{{ routes.account_url }}" class="header__icon-btn" aria-label="{{ 'header.account' | t }}">
          {%- render 'icon', name: 'account' -%}
        </a>
      {%- endif -%}

      {%- if section.settings.show_wishlist -%}
        <button class="header__icon-btn" aria-label="{{ 'header.wishlist' | t }}">
          {%- render 'icon', name: 'wishlist' -%}
        </button>
      {%- endif -%}

      <a href="{{ routes.cart_url }}" class="header__icon-btn header__cart-link" aria-label="{{ 'header.cart_count' | t: count: cart.item_count }}">
        {%- render 'icon', name: 'cart' -%}
        {%- if cart.item_count > 0 -%}
          <span class="header__cart-count">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </nav>
  </div>

  {% comment %} Desktop nav — below logo (mega mode only) {% endcomment %}
  {%- if desktop_layout != 'logo_left_nav_inline' and menu_style == 'mega' -%}
    <nav class="header__nav header__nav--below" aria-label="{{ 'header.navigation' | t | default: 'Main navigation' }}">
      {%- render 'header-desktop-nav', menu: section.settings.menu, blocks: section.blocks, color_scheme: section.settings.color_scheme, open_trigger: section.settings.menu_open_trigger -%}
    </nav>
  {%- endif -%}

  {% comment %} Search panel {% endcomment %}
  {%- if section.settings.show_search -%}
    <div class="header__search-panel" hidden>
      <div class="header__search-inner">
        <form action="{{ routes.search_url }}" method="get" role="search" class="header__search-form">
          <label for="header-search-input" class="visually-hidden">{{ 'search.placeholder' | t }}</label>
          <input type="search" id="header-search-input" name="q" class="header__search-input" placeholder="{{ 'search.placeholder' | t }}" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false">
          <button type="submit" class="header__search-submit" aria-label="{{ 'search.submit' | t }}">
            {%- render 'icon', name: 'search' -%}
          </button>
        </form>
        <button class="header__search-close" aria-label="{{ 'header.close_search' | t }}">
          {%- render 'icon', name: 'close' -%}
        </button>
      </div>
    </div>
  {%- endif -%}
</header-element>

{% comment %} ==========================================
   Drawer — multi-panel navigation (always present)
   Pattern: Theme-example-1 + Theme-example-2
   ========================================== {% endcomment %}
<header-drawer>
  <div class="header__drawer" id="header-drawer">
    <div class="header__drawer-panels">

      {% comment %} Main panel — L1 links {% endcomment %}
      <div class="header__drawer-panel header__drawer-panel--main is-active" data-panel="main">
        <div class="header__drawer-panel-header">
          <button class="header__drawer-close" aria-label="{{ 'header.close_menu' | t }}">
            {%- render 'icon', name: 'close' -%}
          </button>
        </div>
        <nav class="header__drawer-panel-body" aria-label="{{ 'header.navigation' | t | default: 'Main navigation' }}">
          <ul class="header__drawer-list" role="list">
            {%- for link in section.settings.menu.links -%}
              <li class="header__drawer-item">
                {%- if link.links.size > 0 -%}
                  <button type="button" class="header__drawer-link header__drawer-link--l1" data-panel-open="panel-{{ forloop.index }}">
                    <span>{{ link.title | escape }}</span>
                    {%- render 'icon', name: 'chevron-down', size: 16 -%}
                  </button>
                {%- else -%}
                  <a href="{{ link.url }}" class="header__drawer-link header__drawer-link--l1"{% if link.current %} aria-current="page"{% endif %}>
                    {{ link.title | escape }}
                  </a>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        </nav>

        {% comment %} Drawer footer — account + social {% endcomment %}
        <div class="header__drawer-footer">
          {%- if shop.customer_accounts_enabled -%}
            <a href="{{ routes.account_url }}" class="header__drawer-footer-link">
              {%- render 'icon', name: 'account', size: 16 -%}
              <span>{{ 'header.account' | t }}</span>
            </a>
          {%- endif -%}
        </div>
      </div>

      {% comment %} Secondary panels — one per L1 with children {% endcomment %}
      {%- for link in section.settings.menu.links -%}
        {%- if link.links.size > 0 -%}
          <div class="header__drawer-panel" data-panel="panel-{{ forloop.index }}">
            <div class="header__drawer-panel-header">
              <button type="button" class="header__drawer-back" data-panel-back="main">
                {%- render 'icon', name: 'chevron-down', size: 16 -%}
                <span>{{ 'header.back' | t }}</span>
              </button>
              <button class="header__drawer-close" aria-label="{{ 'header.close_menu' | t }}">
                {%- render 'icon', name: 'close' -%}
              </button>
            </div>
            <div class="header__drawer-panel-body">
              <p class="header__drawer-panel-title">{{ link.title | escape }}</p>

              <ul class="header__drawer-sublist" role="list">
                <li>
                  <a href="{{ link.url }}" class="header__drawer-link header__drawer-link--view-all">{{ 'header.view_all_in' | t: collection: link.title }}</a>
                </li>
                {%- for child_link in link.links -%}
                  <li>
                    {%- if child_link.links.size > 0 -%}
                      <p class="header__drawer-link header__drawer-link--heading">{{ child_link.title | escape }}</p>
                      <ul class="header__drawer-sublist header__drawer-sublist--nested" role="list">
                        {%- for grandchild_link in child_link.links -%}
                          <li>
                            <a href="{{ grandchild_link.url }}" class="header__drawer-link">{{ grandchild_link.title | escape }}</a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- else -%}
                      <a href="{{ child_link.url }}" class="header__drawer-link">{{ child_link.title | escape }}</a>
                    {%- endif -%}
                  </li>
                {%- endfor -%}
              </ul>

              {% comment %} Promo images for this L1 {% endcomment %}
              {%- liquid
                assign drawer_mega_block = nil
                for block in section.blocks
                  if block.type == 'mega_menu' and block.settings.menu_item == link.title
                    assign drawer_mega_block = block
                    break
                  endif
                endfor
              -%}
              {%- if drawer_mega_block -%}
                {%- render 'header-drawer-images', block: drawer_mega_block -%}
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}

    </div>
  </div>
  <div class="header__drawer-backdrop" aria-hidden="true"></div>
</header-drawer>

<script src="{{ 'section-header.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "t:general.header",
  "class": "section-header",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:labels.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:general.layout"
    },
    {
      "type": "select",
      "id": "desktop_layout",
      "label": "t:header.desktop_layout",
      "options": [
        { "value": "logo_center_nav_below", "label": "t:header.desktop_layout_center" },
        { "value": "logo_left_nav_inline", "label": "t:header.desktop_layout_inline" },
        { "value": "logo_left_nav_center", "label": "t:header.desktop_layout_left_center" }
      ],
      "default": "logo_center_nav_below"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "t:header.mobile_layout",
      "options": [
        { "value": "logo_center", "label": "t:header.mobile_layout_center" },
        { "value": "logo_left", "label": "t:header.mobile_layout_left" }
      ],
      "default": "logo_center"
    },
    {
      "type": "select",
      "id": "menu_style",
      "label": "t:header.menu_style",
      "options": [
        { "value": "drawer", "label": "t:header.menu_style_drawer" },
        { "value": "mega", "label": "t:header.menu_style_mega" }
      ],
      "default": "drawer",
      "info": "t:header.menu_style_info"
    },
    {
      "type": "select",
      "id": "menu_open_trigger",
      "label": "t:header.menu_open_trigger",
      "options": [
        { "value": "hover", "label": "t:header.menu_trigger_hover" },
        { "value": "click", "label": "t:header.menu_trigger_click" }
      ],
      "default": "hover",
      "info": "t:header.menu_trigger_info"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "t:labels.logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 60,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "t:labels.logo_width",
      "default": 100
    },
    {
      "type": "checkbox",
      "id": "sticky_header",
      "label": "t:labels.sticky_header",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "transparent_header",
      "label": "t:labels.transparent_header",
      "info": "t:labels.transparent_header_info",
      "default": true
    },
    {
      "type": "header",
      "content": "t:general.content"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu",
      "default": "main-menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "t:header.show_search",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_wishlist",
      "label": "t:labels.show_wishlist",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "mega_menu",
      "name": "t:header.mega_menu_block",
      "settings": [
        {
          "type": "text",
          "id": "menu_item",
          "label": "t:header.mega_menu_item_title",
          "info": "t:header.mega_menu_item_info"
        },
        { "type": "header", "content": "t:header.promo_1_header" },
        { "type": "image_picker", "id": "promo_1_image", "label": "t:header.promo_image" },
        { "type": "text", "id": "promo_1_heading", "label": "t:header.promo_heading" },
        { "type": "url", "id": "promo_1_link", "label": "t:header.promo_link" },
        { "type": "header", "content": "t:header.promo_2_header" },
        { "type": "image_picker", "id": "promo_2_image", "label": "t:header.promo_image" },
        { "type": "text", "id": "promo_2_heading", "label": "t:header.promo_heading" },
        { "type": "url", "id": "promo_2_link", "label": "t:header.promo_link" },
        { "type": "header", "content": "t:header.promo_3_header" },
        { "type": "image_picker", "id": "promo_3_image", "label": "t:header.promo_image" },
        { "type": "text", "id": "promo_3_heading", "label": "t:header.promo_heading" },
        { "type": "url", "id": "promo_3_link", "label": "t:header.promo_link" },
        { "type": "header", "content": "t:header.promo_4_header" },
        { "type": "image_picker", "id": "promo_4_image", "label": "t:header.promo_image" },
        { "type": "text", "id": "promo_4_heading", "label": "t:header.promo_heading" },
        { "type": "url", "id": "promo_4_link", "label": "t:header.promo_link" }
      ]
    }
  ]
}
{% endschema %}
