{{ 'section-header.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-header.js' | asset_url }}" defer="defer"></script>

{%- if section.settings.transparent_header -%}
  <style>
    .header-wrapper--transparent:not(.header-wrapper--scrolled) .header {
      color: {{ section.settings.transparent_text_color }};
    }
  </style>
{%- endif -%}

<sticky-header
  class="header-wrapper{% if section.settings.color_scheme != blank %} color-{{ section.settings.color_scheme }}{% endif %}{% if section.settings.enable_sticky %} header-wrapper--sticky{% endif %}{% if section.settings.transparent_header %} header-wrapper--transparent{% endif %}"
  {% if section.settings.hide_on_scroll %}data-hide-on-scroll="true"{% endif %}
>
  <header class="header" style="--icon-size: {{ section.settings.icon_size | default: 20 }}px;">
    <!-- Left: hamburger -->
    <div class="header__left">
      <button class="header__menu-toggle{% if section.settings.nav_style == 'mega' %} header__toggle--mega-hidden{% endif %}" data-drawer-open aria-label="{{ 'header.menu' | t }}" aria-expanded="false">
        {%- render 'icon', name: 'menu' -%}
      </button>
    </div>

    <!-- Center: logo -->
    <div class="header__center">
      <a href="{{ routes.root_url }}" class="header__logo" style="--logo-width: {{ section.settings.logo_width }}px; --logo-width-mobile: {{ section.settings.logo_width_mobile | default: 90 }}px;">
        {%- if section.settings.logo -%}
          {{
            section.settings.logo
            | image_url: width: section.settings.logo_width
            | image_tag: alt: shop.name, class: 'header__logo-image header__logo-image--default', widths: '80,120,160,200,240,300'
          }}
          {%- if section.settings.transparent_logo -%}
            {{
              section.settings.transparent_logo
              | image_url: width: section.settings.logo_width
              | image_tag: alt: shop.name, class: 'header__logo-image header__logo-image--transparent', widths: '80,120,160,200,240,300'
            }}
          {%- endif -%}
        {%- else -%}
          <span class="header__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>

    <!-- Right: icons -->
    <div class="header__right">
      {%- if section.settings.show_search -%}
        <a href="{{ routes.search_url }}" class="header__icon" aria-label="{{ 'header.search' | t }}">
          {%- render 'icon', name: 'search' -%}
        </a>
      {%- endif -%}

      {%- if section.settings.show_wishlist -%}
        <a href="#" class="header__icon" aria-label="{{ 'header.wishlist' | t }}">
          {%- render 'icon', name: 'wishlist' -%}
        </a>
      {%- endif -%}

      {%- if section.settings.show_account and shop.customer_accounts_enabled -%}
        <a href="{{ routes.account_url }}" class="header__icon" aria-label="{{ 'header.account' | t }}">
          {%- render 'icon', name: 'account' -%}
        </a>
      {%- endif -%}

      <a href="{{ routes.cart_url }}" class="header__icon header__icon--cart" aria-label="{{ 'header.cart' | t }}">
        {%- render 'icon', name: 'bag' -%}
        {%- if cart.item_count > 0 -%}
          <span class="header__cart-count">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>
  </header>

  {%- if section.settings.nav_style == 'mega' -%}
    <nav class="header__mega-nav">
      <ul class="header__mega-list">
        {%- for link in linklists[section.settings.menu].links -%}
          <li class="header__mega-item{% if link.links.size > 0 %} header__mega-item--has-children{% endif %}">
            <a href="{{ link.url }}" class="header__mega-link">
              {{ link.title }}
              {%- if link.links.size > 0 -%}
                {%- render 'icon', name: 'chevron-down' -%}
              {%- endif -%}
            </a>
            {%- if link.links.size > 0 -%}
              {%- liquid
                assign mega_block = nil
                for block in section.blocks
                  if block.type == 'mega_menu'
                    assign bh = block.settings.menu_item | downcase | strip
                    assign lh = link.title | downcase | strip
                    if bh == lh
                      assign mega_block = block
                      break
                    endif
                  endif
                endfor
                assign has_image_3 = false
                if mega_block and mega_block.settings.image_3
                  assign has_image_3 = true
                endif
              -%}
              <div class="header__mega-dropdown">
                <div class="header__mega-dropdown-inner">
                  <div class="header__mega-links-area">
                    {%- if mega_block and mega_block.settings.col_1_heading != blank -%}
                      {%- assign half = link.links.size | divided_by: 2 | plus: 1 -%}
                      <div>
                        <p class="header__mega-col-heading">{{ mega_block.settings.col_1_heading }}</p>
                        <ul class="header__mega-sublist">
                          {%- for child in link.links -%}
                            {%- if forloop.index <= half -%}
                              <li><a href="{{ child.url }}" class="header__mega-sublink">{{ child.title }}</a></li>
                            {%- endif -%}
                          {%- endfor -%}
                        </ul>
                      </div>
                      {%- if mega_block.settings.col_2_heading != blank -%}
                        <div>
                          <p class="header__mega-col-heading">{{ mega_block.settings.col_2_heading }}</p>
                          <ul class="header__mega-sublist">
                            {%- for child in link.links -%}
                              {%- if forloop.index > half -%}
                                <li><a href="{{ child.url }}" class="header__mega-sublink">{{ child.title }}</a></li>
                              {%- endif -%}
                            {%- endfor -%}
                          </ul>
                        </div>
                      {%- endif -%}
                    {%- else -%}
                      <div>
                        <ul class="header__mega-sublist">
                          {%- for child in link.links -%}
                            <li><a href="{{ child.url }}" class="header__mega-sublink">{{ child.title }}</a></li>
                          {%- endfor -%}
                        </ul>
                      </div>
                    {%- endif -%}
                  </div>
                  {%- if mega_block -%}
                    <div class="header__mega-images-area{% unless has_image_3 %} header__mega-images-area--2col{% endunless %}">
                      {%- if mega_block.settings.image_1 -%}
                        <div class="header__mega-image-item">
                          {%- if mega_block.settings.image_1_url -%}
                            <a href="{{ mega_block.settings.image_1_url }}">
                              {{ mega_block.settings.image_1 | image_url: width: 400 | image_tag: alt: mega_block.settings.image_1_label, loading: 'lazy', widths: '200,300,400' }}
                            </a>
                          {%- else -%}
                            {{ mega_block.settings.image_1 | image_url: width: 400 | image_tag: alt: mega_block.settings.image_1_label, loading: 'lazy', widths: '200,300,400' }}
                          {%- endif -%}
                          {%- if mega_block.settings.image_1_label != blank -%}
                            <p class="header__mega-image-title">{{ mega_block.settings.image_1_label }}</p>
                          {%- endif -%}
                          {%- if mega_block.settings.image_1_subtitle != blank -%}
                            <p class="header__mega-image-subtitle">{{ mega_block.settings.image_1_subtitle }}</p>
                          {%- endif -%}
                        </div>
                      {%- endif -%}
                      {%- if mega_block.settings.image_2 -%}
                        <div class="header__mega-image-item">
                          {%- if mega_block.settings.image_2_url -%}
                            <a href="{{ mega_block.settings.image_2_url }}">
                              {{ mega_block.settings.image_2 | image_url: width: 400 | image_tag: alt: mega_block.settings.image_2_label, loading: 'lazy', widths: '200,300,400' }}
                            </a>
                          {%- else -%}
                            {{ mega_block.settings.image_2 | image_url: width: 400 | image_tag: alt: mega_block.settings.image_2_label, loading: 'lazy', widths: '200,300,400' }}
                          {%- endif -%}
                          {%- if mega_block.settings.image_2_label != blank -%}
                            <p class="header__mega-image-title">{{ mega_block.settings.image_2_label }}</p>
                          {%- endif -%}
                          {%- if mega_block.settings.image_2_subtitle != blank -%}
                            <p class="header__mega-image-subtitle">{{ mega_block.settings.image_2_subtitle }}</p>
                          {%- endif -%}
                        </div>
                      {%- endif -%}
                      {%- if mega_block.settings.image_3 -%}
                        <div class="header__mega-image-item">
                          {%- if mega_block.settings.image_3_url -%}
                            <a href="{{ mega_block.settings.image_3_url }}">
                              {{ mega_block.settings.image_3 | image_url: width: 400 | image_tag: alt: '', loading: 'lazy', widths: '200,300,400' }}
                            </a>
                          {%- else -%}
                            {{ mega_block.settings.image_3 | image_url: width: 400 | image_tag: alt: '', loading: 'lazy', widths: '200,300,400' }}
                          {%- endif -%}
                          {%- if mega_block.settings.image_3_subtitle != blank -%}
                            <p class="header__mega-image-subtitle">{{ mega_block.settings.image_3_subtitle }}</p>
                          {%- endif -%}
                        </div>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </nav>
  {%- endif -%}
</sticky-header>

{%- comment -%} Drawer : toujours présent sur mobile, optionnel sur desktop {%- endcomment -%}
<menu-drawer class="{% if section.settings.nav_style == 'mega' %}header__drawer--mobile-only{% endif %}">
  {%- render 'menu-drawer',
    menu: linklists[section.settings.menu],
    blocks: section.blocks,
    tab_1_menu: linklists[section.settings.tab_1_menu],
    tab_1_label: section.settings.tab_1_label,
    tab_2_menu: linklists[section.settings.tab_2_menu],
    tab_2_label: section.settings.tab_2_label
  -%}
</menu-drawer>

{% schema %}
{
  "name": "t:general.header",
  "class": "shopify-section--header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Main menu",
      "default": "main-menu",
      "info": "Main navigation menu. Edit menus in Online Store > Navigation"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "transparent_header",
      "label": "Transparent header on home page",
      "default": false,
      "info": "Header becomes transparent at the top of the page. Use only when the first section is a full-bleed hero image"
    },
    {
      "type": "color",
      "id": "transparent_text_color",
      "label": "Transparent header text color",
      "default": "#FFFFFF",
      "info": "Text and icon color when header is transparent"
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "select",
      "id": "nav_style",
      "label": "Navigation style",
      "options": [
        { "value": "drawer", "label": "Drawer" },
        { "value": "mega", "label": "Mega menu" }
      ],
      "default": "drawer",
      "info": "Drawer: Dior-style side panel. Mega menu: horizontal dropdown below header"
    },
    {
      "type": "checkbox",
      "id": "enable_sticky",
      "label": "Enable sticky header",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "hide_on_scroll",
      "label": "Hide on scroll down",
      "default": false
    },
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo",
      "info": "Upload your logo. If empty, store name is displayed as text"
    },
    {
      "type": "image_picker",
      "id": "transparent_logo",
      "label": "Transparent header logo",
      "info": "Light logo for transparent header over dark hero images. If empty, default logo is used"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 60,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Logo width on desktop",
      "default": 120
    },
    {
      "type": "range",
      "id": "logo_width_mobile",
      "min": 40,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Logo width on mobile",
      "default": 90
    },
    {
      "type": "header",
      "content": "Icons"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_wishlist",
      "label": "Show wishlist icon",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "label": "Show account icon",
      "default": true
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 16,
      "max": 28,
      "step": 2,
      "unit": "px",
      "label": "Icon size",
      "default": 20
    },
    {
      "type": "header",
      "content": "Menu tabs"
    },
    {
      "type": "text",
      "id": "tab_1_label",
      "label": "Tab 1 label",
      "default": "Fashion",
      "info": "Leave empty to hide the universe tabs at the bottom of the drawer"
    },
    {
      "type": "link_list",
      "id": "tab_1_menu",
      "label": "Tab 1 menu",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "tab_2_label",
      "label": "Tab 2 label"
    },
    {
      "type": "link_list",
      "id": "tab_2_menu",
      "label": "Tab 2 menu"
    }
  ],
  "blocks": [
    {
      "type": "mega_menu",
      "name": "Mega menu",
      "limit": 10,
      "settings": [
        {
          "type": "text",
          "id": "menu_item",
          "label": "Menu item handle",
          "info": "Must match exactly the title of the L1 menu link (case insensitive). Ex: if link is 'Women', type 'Women'"
        },
        {
          "type": "header",
          "content": "Columns"
        },
        {
          "type": "text",
          "id": "col_1_heading",
          "label": "Column 1 heading"
        },
        {
          "type": "text",
          "id": "col_2_heading",
          "label": "Column 2 heading"
        },
        {
          "type": "text",
          "id": "col_3_heading",
          "label": "Column 3 heading"
        },
        {
          "type": "header",
          "content": "Editorial images"
        },
        {
          "type": "image_picker",
          "id": "image_1",
          "label": "Image 1",
          "info": "Portrait format recommended (3:4 ratio)"
        },
        {
          "type": "text",
          "id": "image_1_label",
          "label": "Image 1 title"
        },
        {
          "type": "text",
          "id": "image_1_subtitle",
          "label": "Image 1 subtitle"
        },
        {
          "type": "url",
          "id": "image_1_url",
          "label": "Image 1 link"
        },
        {
          "type": "image_picker",
          "id": "image_2",
          "label": "Image 2"
        },
        {
          "type": "text",
          "id": "image_2_label",
          "label": "Image 2 title"
        },
        {
          "type": "text",
          "id": "image_2_subtitle",
          "label": "Image 2 subtitle"
        },
        {
          "type": "url",
          "id": "image_2_url",
          "label": "Image 2 link"
        },
        {
          "type": "image_picker",
          "id": "image_3",
          "label": "Image 3"
        },
        {
          "type": "text",
          "id": "image_3_subtitle",
          "label": "Image 3 subtitle"
        },
        {
          "type": "url",
          "id": "image_3_url",
          "label": "Image 3 link"
        },
        {
          "type": "image_picker",
          "id": "image_4",
          "label": "Image 4"
        }
      ]
    }
  ],
  "max_blocks": 10
}
{% endschema %}
