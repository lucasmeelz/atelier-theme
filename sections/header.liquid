{{ 'section-header.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-header.js' | asset_url }}" defer="defer"></script>

{%- if section.settings.transparent_header -%}
  <style>
    .header-wrapper--transparent:not(.header-wrapper--scrolled) .header {
      color: {{ section.settings.transparent_text_color }};
    }
  </style>
{%- endif -%}

<sticky-header
  class="header-wrapper header--{{ section.settings.desktop_layout }} color-{{ section.settings.color_scheme }}{% if section.settings.enable_sticky %} header-wrapper--sticky{% endif %}{% if section.settings.transparent_header %} header-wrapper--transparent{% endif %}{% if section.settings.show_separator_border %} header-wrapper--bordered{% endif %}"
>
  <header class="header" style="--logo-width: {{ section.settings.logo_width }}px; --header-height-setting: {{ section.settings.header_height }}px; --drawer-width: {{ section.settings.drawer_width }}px; --icon-size: {{ section.settings.icon_size }}px;">

    {%- comment -%} LEFT: hamburger + search mobile {%- endcomment -%}
    <div class="header__left">
      <button
        class="header__menu-toggle{% if section.settings.nav_style == 'mega' %} header__toggle--mega-hidden{% endif %}"
        data-drawer-open
        aria-label="{{ 'header.menu' | t }}"
        aria-expanded="false"
      >
        {%- render 'icon', name: 'menu' -%}
      </button>
      {%- if section.settings.show_search -%}
        <a href="{{ routes.search_url }}" class="header__icon header__icon--search-mobile" aria-label="{{ 'header.search' | t }}">
          {%- render 'icon', name: 'search' -%}
        </a>
      {%- endif -%}
    </div>

    {%- comment -%} CENTER: logo + transparent logo {%- endcomment -%}
    <div class="header__center">
      <a href="{{ routes.root_url }}" class="header__logo">
        {%- if section.settings.logo -%}
          {%- assign logo_alt = section.settings.logo.alt | default: shop.name -%}
          {{ section.settings.logo | image_url: width: section.settings.logo_width | image_tag:
            alt: logo_alt,
            class: 'header__logo-image',
            widths: '80,120,160,200,240,300',
            loading: 'eager'
          }}
          {%- if section.settings.transparent_logo -%}
            {%- assign t_logo_alt = section.settings.transparent_logo.alt | default: shop.name -%}
            {{ section.settings.transparent_logo | image_url: width: section.settings.logo_width | image_tag:
              alt: t_logo_alt,
              class: 'header__logo-image header__logo-image--transparent',
              widths: '80,120,160,200,240,300',
              loading: 'eager'
            }}
          {%- endif -%}
        {%- else -%}
          <span class="header__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>

    {%- comment -%} RIGHT: search desktop + account + cart {%- endcomment -%}
    <div class="header__right">
      {%- if section.settings.show_search -%}
        {%- if section.settings.search_style == 'expanded' -%}
          <form action="{{ routes.search_url }}" method="get" class="header__search-form" role="search">
            <input type="search" name="q" placeholder="{{ 'header.search_placeholder' | t }}" class="header__search-input" aria-label="{{ 'header.search' | t }}">
            <button type="submit" class="header__search-submit" aria-label="{{ 'header.search' | t }}">
              {%- render 'icon', name: 'search' -%}
            </button>
          </form>
        {%- else -%}
          <a href="{{ routes.search_url }}" class="header__icon header__icon--search-desktop" aria-label="{{ 'header.search' | t }}">
            {%- render 'icon', name: 'search' -%}
          </a>
        {%- endif -%}
      {%- endif -%}
      {%- if section.settings.show_account and shop.customer_accounts_enabled -%}
        <a href="{{ routes.account_url }}" class="header__icon" aria-label="{{ 'header.account' | t }}">
          {%- render 'icon', name: 'account' -%}
        </a>
      {%- endif -%}
      <a href="{{ routes.cart_url }}" class="header__icon header__icon--cart" aria-label="{{ 'header.cart' | t }}">
        {%- render 'icon', name: 'bag' -%}
        {%- if cart.item_count > 0 -%}
          <span class="header__cart-count">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>
  </header>

  {%- comment -%} MEGA NAV — desktop only, hover-open dropdowns {%- endcomment -%}
  {%- if section.settings.nav_style == 'mega' -%}
    <nav class="header__mega-nav header__mega-nav--{{ section.settings.nav_layout }}" aria-label="{{ 'header.navigation' | t }}">
      <ul class="header__mega-list">
        {%- for link in linklists[section.settings.menu].links -%}
          {%- liquid
            assign has_children = false
            if link.links.size > 0
              assign has_children = true
            endif

            assign mega_block = nil
            for block in section.blocks
              if block.type == 'mega_menu' and block.settings.menu_item == link.title
                assign mega_block = block
                break
              endif
            endfor
          -%}

          <li class="header__mega-item{% if has_children %} header__mega-item--has-children{% endif %}" {{ mega_block.shopify_attributes }}>
            <a href="{{ link.url }}" class="header__mega-link">
              {{ link.title }}
              {%- if has_children -%}{%- render 'icon', name: 'chevron-down' -%}{%- endif -%}
            </a>

            {%- if has_children -%}
              <div class="header__mega-dropdown" aria-label="{{ link.title }}">
                <div class="header__mega-dropdown-inner">
                  <div class="header__mega-columns">
                    <div class="header__mega-links" style="--mega-columns: {{ section.settings.mega_columns }};">
                      {%- for child in link.links -%}
                        <div class="header__mega-group">
                          <a href="{{ child.url }}" class="header__mega-sublink header__mega-sublink--parent">{{ child.title }}</a>
                          {%- if child.links.size > 0 -%}
                            <ul class="header__mega-l3-list">
                              {%- for grandchild in child.links -%}
                                <li><a href="{{ grandchild.url }}" class="header__mega-l3-link">{{ grandchild.title }}</a></li>
                              {%- endfor -%}
                            </ul>
                          {%- endif -%}
                        </div>
                      {%- endfor -%}
                      <a href="{{ link.url }}" class="header__mega-view-all">{{ 'header.view_all' | t }}</a>
                    </div>

                    {%- if mega_block -%}
                      <div class="header__mega-images">
                        {%- if mega_block.settings.image_1 -%}
                          {%- assign fp_1 = mega_block.settings.image_1.presentation.focal_point | default: 'center center' -%}
                          {%- assign fp_style_1 = 'object-position: ' | append: fp_1 -%}
                          <a href="{{ mega_block.settings.image_1_url | default: '#' }}" class="header__mega-image-link">
                            {{ mega_block.settings.image_1 | image_url: width: 600 | image_tag:
                              alt: mega_block.settings.image_1_label,
                              class: 'header__mega-image',
                              widths: '200,300,400,600',
                              loading: 'lazy',
                              style: fp_style_1
                            }}
                            {%- if mega_block.settings.image_1_label != blank -%}
                              <span class="header__mega-image-label">{{ mega_block.settings.image_1_label }}</span>
                            {%- endif -%}
                          </a>
                        {%- endif -%}
                        {%- if mega_block.settings.image_2 -%}
                          {%- assign fp_2 = mega_block.settings.image_2.presentation.focal_point | default: 'center center' -%}
                          {%- assign fp_style_2 = 'object-position: ' | append: fp_2 -%}
                          <a href="{{ mega_block.settings.image_2_url | default: '#' }}" class="header__mega-image-link">
                            {{ mega_block.settings.image_2 | image_url: width: 600 | image_tag:
                              alt: mega_block.settings.image_2_label,
                              class: 'header__mega-image',
                              widths: '200,300,400,600',
                              loading: 'lazy',
                              style: fp_style_2
                            }}
                            {%- if mega_block.settings.image_2_label != blank -%}
                              <span class="header__mega-image-label">{{ mega_block.settings.image_2_label }}</span>
                            {%- endif -%}
                          </a>
                        {%- endif -%}
                      </div>
                    {%- endif -%}
                  </div>
                </div>
              </div>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </nav>
  {%- endif -%}
</sticky-header>

{%- comment -%} DRAWER — always rendered, mobile-only when mega nav active {%- endcomment -%}
<menu-drawer class="{% if section.settings.nav_style == 'mega' %}header__drawer--mobile-only{% endif %}">
  {%- render 'menu-drawer',
    menu: linklists[section.settings.menu],
    tab_1_menu: linklists[section.settings.tab_1_menu],
    tab_1_label: section.settings.tab_1_label,
    tab_2_menu: linklists[section.settings.tab_2_menu],
    tab_2_label: section.settings.tab_2_label,
    show_country_selector: section.settings.show_country_selector,
    show_language_selector: section.settings.show_language_selector,
    blocks: section.blocks
  -%}
</menu-drawer>

{% schema %}
{
  "name": "t:general.header",
  "class": "shopify-section--header",
  "settings": [
    { "type": "link_list", "id": "menu", "label": "Main menu", "default": "main-menu" },
    { "type": "header", "content": "Layout" },
    {
      "type": "select", "id": "desktop_layout", "label": "Desktop layout",
      "options": [
        { "value": "logo_center", "label": "Logo center" },
        { "value": "logo_left", "label": "Logo left" }
      ],
      "default": "logo_center"
    },
    {
      "type": "range", "id": "header_height", "min": 48, "max": 120, "step": 4, "unit": "px",
      "label": "Header height", "default": 64,
      "info": "Height of the header bar on desktop"
    },
    {
      "type": "checkbox", "id": "show_separator_border", "label": "Show separator border",
      "default": true, "info": "Display a bottom border on the header"
    },
    { "type": "header", "content": "Colors" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "checkbox", "id": "transparent_header", "label": "Transparent header on home page", "default": false, "info": "Use only when the first section is a full-bleed hero image" },
    { "type": "color", "id": "transparent_text_color", "label": "Transparent header text color", "default": "#FFFFFF" },
    { "type": "header", "content": "Logo" },
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "image_picker", "id": "transparent_logo", "label": "Transparent header logo", "info": "Light logo for transparent header. If empty, default logo is used" },
    { "type": "range", "id": "logo_width", "min": 60, "max": 300, "step": 10, "unit": "px", "label": "Logo width", "default": 120 },
    { "type": "header", "content": "Navigation" },
    {
      "type": "select", "id": "nav_style", "label": "Navigation style",
      "options": [
        { "value": "drawer", "label": "Drawer" },
        { "value": "mega", "label": "Mega menu" }
      ],
      "default": "drawer"
    },
    {
      "type": "select", "id": "nav_layout", "label": "Navigation layout",
      "options": [
        { "value": "logo_center_nav_below", "label": "Logo center, nav below" },
        { "value": "logo_center_nav_inline", "label": "Logo center, nav inline left" },
        { "value": "logo_left_nav_inline", "label": "Logo left, nav inline" },
        { "value": "logo_left_nav_center", "label": "Logo left, nav center" }
      ],
      "default": "logo_center_nav_inline",
      "info": "Layout for mega menu desktop navigation"
    },
    {
      "type": "select", "id": "mega_columns", "label": "Mega menu columns",
      "options": [
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" }
      ],
      "default": "3",
      "info": "Number of link columns in the mega dropdown"
    },
    { "type": "checkbox", "id": "enable_sticky", "label": "Enable sticky header", "default": true },
    { "type": "header", "content": "Icons" },
    { "type": "checkbox", "id": "show_search", "label": "Show search icon", "default": true },
    {
      "type": "select", "id": "search_style", "label": "Search style",
      "options": [
        { "value": "icon", "label": "Icon only" },
        { "value": "expanded", "label": "Expanded search bar" }
      ],
      "default": "icon",
      "info": "Icon redirects to search page. Expanded shows an inline search bar"
    },
    { "type": "checkbox", "id": "show_account", "label": "Show account icon", "default": true },
    {
      "type": "range", "id": "icon_size", "min": 16, "max": 28, "step": 2, "unit": "px",
      "label": "Icon size", "default": 20,
      "info": "Size of header icons (search, account, cart)"
    },
    { "type": "header", "content": "Drawer" },
    {
      "type": "range", "id": "drawer_width", "min": 280, "max": 480, "step": 20, "unit": "px",
      "label": "Drawer width", "default": 360,
      "info": "Width of the navigation drawer on desktop"
    },
    { "type": "header", "content": "Localization" },
    { "type": "checkbox", "id": "show_country_selector", "label": "Show country selector", "default": true },
    { "type": "checkbox", "id": "show_language_selector", "label": "Show language selector", "default": false },
    { "type": "header", "content": "Drawer tabs" },
    { "type": "text", "id": "tab_1_label", "label": "Tab 1 label", "default": "Fashion" },
    { "type": "link_list", "id": "tab_1_menu", "label": "Tab 1 menu", "default": "main-menu" },
    { "type": "text", "id": "tab_2_label", "label": "Tab 2 label" },
    { "type": "link_list", "id": "tab_2_menu", "label": "Tab 2 menu" }
  ],
  "blocks": [
    {
      "type": "mega_menu",
      "name": "Mega menu",
      "limit": 10,
      "settings": [
        { "type": "text", "id": "menu_item", "label": "Menu item title", "info": "Must match the L1 link title exactly" },
        { "type": "image_picker", "id": "image_1", "label": "Image 1" },
        { "type": "text", "id": "image_1_label", "label": "Image 1 title" },
        { "type": "url", "id": "image_1_url", "label": "Image 1 link" },
        { "type": "image_picker", "id": "image_2", "label": "Image 2" },
        { "type": "text", "id": "image_2_label", "label": "Image 2 title" },
        { "type": "url", "id": "image_2_url", "label": "Image 2 link" }
      ]
    }
  ],
  "max_blocks": 10
}
{% endschema %}
