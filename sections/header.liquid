{{ 'section-header.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-header.js' | asset_url }}" defer="defer"></script>

<sticky-header
  class="header-wrapper{% if section.settings.enable_sticky %} header-wrapper--sticky{% endif %}"
  {% if section.settings.hide_on_scroll %}data-hide-on-scroll="true"{% endif %}
>
  <header class="header">
    <!-- Left: hamburger -->
    <div class="header__left">
      {%- if section.settings.nav_style == 'drawer' -%}
        <button class="header__menu-toggle" data-drawer-open aria-label="{{ 'header.menu' | t }}">
          {%- render 'icon', name: 'menu' -%}
        </button>
      {%- endif -%}
    </div>

    <!-- Center: logo -->
    <div class="header__center">
      <a href="{{ routes.root_url }}" class="header__logo">
        {%- if section.settings.logo -%}
          {{
            section.settings.logo
            | image_url: width: section.settings.logo_width
            | image_tag: alt: shop.name, class: 'header__logo-image', widths: '80,120,160,200,240,300'
          }}
        {%- else -%}
          <span class="header__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>

    <!-- Right: icons -->
    <div class="header__right">
      {%- if section.settings.show_search -%}
        <a href="{{ routes.search_url }}" class="header__icon" aria-label="{{ 'header.search' | t }}">
          {%- render 'icon', name: 'search' -%}
        </a>
      {%- endif -%}

      {%- if section.settings.show_wishlist -%}
        <a href="#" class="header__icon" aria-label="{{ 'header.wishlist' | t }}">
          {%- render 'icon', name: 'wishlist' -%}
        </a>
      {%- endif -%}

      {%- if section.settings.show_account and shop.customer_accounts_enabled -%}
        <a href="{{ routes.account_url }}" class="header__icon" aria-label="{{ 'header.account' | t }}">
          {%- render 'icon', name: 'account' -%}
        </a>
      {%- endif -%}

      <a href="{{ routes.cart_url }}" class="header__icon header__icon--cart" aria-label="{{ 'header.cart' | t }}">
        {%- render 'icon', name: 'bag' -%}
        {%- if cart.item_count > 0 -%}
          <span class="header__cart-count">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>
  </header>

  {%- if section.settings.nav_style == 'mega' -%}
    <nav class="header__mega-nav">
      <ul class="header__mega-list">
        {%- for link in linklists[section.settings.menu].links -%}
          <li class="header__mega-item{% if link.links.size > 0 %} header__mega-item--has-children{% endif %}">
            <a href="{{ link.url }}" class="header__mega-link">
              {{ link.title }}
              {%- if link.links.size > 0 -%}
                {%- render 'icon', name: 'chevron-down' -%}
              {%- endif -%}
            </a>
            {%- if link.links.size > 0 -%}
              <div class="header__mega-dropdown">
                <div class="header__mega-dropdown-inner">
                  <ul class="header__mega-sublist">
                    {%- for child in link.links -%}
                      <li>
                        <a href="{{ child.url }}" class="header__mega-sublink">{{ child.title }}</a>
                      </li>
                    {%- endfor -%}
                  </ul>
                  {%- for block in section.blocks -%}
                    {%- if block.type == 'mega_menu' -%}
                      {%- assign bh = block.settings.menu_item | downcase | strip -%}
                      {%- assign lh = link.title | downcase | strip -%}
                      {%- if bh == lh -%}
                        <div class="header__mega-images">
                          {%- if block.settings.image_1 -%}
                            <div class="header__mega-image-item">
                              {{ block.settings.image_1 | image_url: width: 300 | image_tag: alt: block.settings.image_1_label, loading: 'lazy' }}
                              {%- if block.settings.image_1_label != blank -%}
                                <p class="header__mega-image-caption">{{ block.settings.image_1_label }}</p>
                              {%- endif -%}
                            </div>
                          {%- endif -%}
                          {%- if block.settings.image_2 -%}
                            <div class="header__mega-image-item">
                              {{ block.settings.image_2 | image_url: width: 300 | image_tag: alt: block.settings.image_2_label, loading: 'lazy' }}
                              {%- if block.settings.image_2_label != blank -%}
                                <p class="header__mega-image-caption">{{ block.settings.image_2_label }}</p>
                              {%- endif -%}
                            </div>
                          {%- endif -%}
                        </div>
                      {%- endif -%}
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              </div>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </nav>
  {%- endif -%}
</sticky-header>

{%- if section.settings.nav_style == 'drawer' -%}
  <menu-drawer>
    {%- render 'menu-drawer',
      menu: linklists[section.settings.menu],
      blocks: section.blocks,
      tab_1_menu: linklists[section.settings.tab_1_menu],
      tab_1_label: section.settings.tab_1_label,
      tab_2_menu: linklists[section.settings.tab_2_menu],
      tab_2_label: section.settings.tab_2_label
    -%}
  </menu-drawer>
{%- endif -%}

{% schema %}
{
  "name": "t:general.header",
  "class": "shopify-section--header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Main menu",
      "default": "main-menu",
      "info": "Main navigation menu. Edit menus in Online Store > Navigation"
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "select",
      "id": "nav_style",
      "label": "Navigation style",
      "options": [
        { "value": "drawer", "label": "Drawer" },
        { "value": "mega", "label": "Mega menu" }
      ],
      "default": "drawer",
      "info": "Drawer: Dior-style side panel. Mega menu: horizontal dropdown below header"
    },
    {
      "type": "checkbox",
      "id": "enable_sticky",
      "label": "Enable sticky header",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "hide_on_scroll",
      "label": "Hide on scroll down",
      "default": false
    },
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo",
      "info": "Upload your logo. If empty, store name is displayed as text"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 80,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Logo width",
      "default": 120,
      "info": "Pixel width of the logo on desktop. Logo scales proportionally"
    },
    {
      "type": "header",
      "content": "Icons"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_wishlist",
      "label": "Show wishlist",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "label": "Show account",
      "default": true
    },
    {
      "type": "header",
      "content": "Menu tabs"
    },
    {
      "type": "text",
      "id": "tab_1_label",
      "label": "Tab 1 label",
      "default": "Fashion",
      "info": "Leave empty to hide the universe tabs at the bottom of the drawer"
    },
    {
      "type": "link_list",
      "id": "tab_1_menu",
      "label": "Tab 1 menu",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "tab_2_label",
      "label": "Tab 2 label"
    },
    {
      "type": "link_list",
      "id": "tab_2_menu",
      "label": "Tab 2 menu"
    }
  ],
  "blocks": [
    {
      "type": "mega_menu",
      "name": "Mega menu",
      "limit": 10,
      "settings": [
        {
          "type": "text",
          "id": "menu_item",
          "label": "Menu item handle",
          "info": "Must match exactly the title of the L1 menu link (case insensitive). Ex: if link is 'Women', type 'Women'"
        },
        {
          "type": "image_picker",
          "id": "image_1",
          "label": "Editorial image 1",
          "info": "Editorial image shown in the dropdown panel (portrait format recommended, 3:4 ratio)"
        },
        {
          "type": "image_picker",
          "id": "image_2",
          "label": "Editorial image 2"
        },
        {
          "type": "image_picker",
          "id": "image_3",
          "label": "Editorial image 3"
        },
        {
          "type": "image_picker",
          "id": "image_4",
          "label": "Editorial image 4"
        },
        {
          "type": "text",
          "id": "image_1_label",
          "label": "Image 1 caption"
        },
        {
          "type": "text",
          "id": "image_2_label",
          "label": "Image 2 caption"
        }
      ]
    }
  ],
  "max_blocks": 10
}
{% endschema %}
