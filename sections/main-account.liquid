{{ 'section-customers.css' | asset_url | stylesheet_tag }}

<div class="customer color-{{ section.settings.color_scheme }}">
  <div class="container">
    <div class="customer__header">
      <h1>{{ 'customer.account.title' | t }}</h1>
    </div>

    <nav class="customer__account-nav">
      <a href="{{ routes.account_url }}" class="is-active">{{ 'customer.account.orders' | t }}</a>
      <a href="{{ routes.account_addresses_url }}">{{ 'customer.account.addresses' | t }}</a>
      <a href="{{ routes.account_logout_url }}">{{ 'customer.account.logout' | t }}</a>
    </nav>

    {%- if customer.orders.size > 0 -%}
      <table class="customer__orders" role="table">
        <thead>
          <tr>
            <th>{{ 'customer.orders.order_number' | t }}</th>
            <th>{{ 'customer.orders.date' | t }}</th>
            <th>{{ 'customer.orders.payment_status' | t }}</th>
            <th>{{ 'customer.orders.fulfillment_status' | t }}</th>
            <th>{{ 'customer.orders.total' | t }}</th>
          </tr>
        </thead>
        <tbody>
          {%- for order in customer.orders -%}
            <tr>
              <td data-label="{{ 'customer.orders.order_number' | t }}">
                <a href="{{ order.customer_url }}">{{ order.name }}</a>
              </td>
              <td data-label="{{ 'customer.orders.date' | t }}">
                {{ order.created_at | date: format: 'abbreviated_date' }}
              </td>
              <td data-label="{{ 'customer.orders.payment_status' | t }}">
                {{ order.financial_status_label }}
              </td>
              <td data-label="{{ 'customer.orders.fulfillment_status' | t }}">
                {{ order.fulfillment_status_label }}
              </td>
              <td data-label="{{ 'customer.orders.total' | t }}">
                {{ order.total_net_amount | money }}
              </td>
            </tr>
          {%- endfor -%}
        </tbody>
      </table>

      {%- if customer.orders.size > 20 -%}
        {%- paginate customer.orders by 20 -%}
          {%- if paginate.pages > 1 -%}
            <nav class="customer__pagination" role="navigation">
              {{ paginate | default_pagination }}
            </nav>
          {%- endif -%}
        {%- endpaginate -%}
      {%- endif -%}
    {%- else -%}
      <p class="customer__orders-empty">{{ 'customer.orders.none' | t }}</p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Customer account",
  "tag": "section",
  "class": "section-customer-account",
  "settings": []
}
{% endschema %}
