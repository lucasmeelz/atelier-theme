{%- comment -%}
  404 — Not found page with centered content and CTA
{%- endcomment -%}

{%- liquid
  assign color_scheme = section.settings.color_scheme
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
-%}

{%- style -%}
  #Section-{{ section.id }} {
    --section-padding-top: {{ padding_top }}px;
    --section-padding-bottom: {{ padding_bottom }}px;
  }

  .not-found-section {
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
    background: rgb(var(--color-background));
    color: rgb(var(--color-text));
    text-align: center;
  }

  .not-found__container {
    max-width: 600px;
    margin: 0 auto;
    padding: 0 var(--page-margin);
  }

  .not-found__label {
    display: block;
    margin-bottom: 16px;
    font-family: var(--font-label-family);
    font-size: var(--label-font-size);
    font-weight: var(--font-label-weight);
    text-transform: var(--label-text-transform);
    letter-spacing: var(--label-letter-spacing);
    color: rgb(var(--color-text-subdued));
  }

  .not-found__title {
    margin: 0 0 16px;
  }

  .not-found__body {
    margin: 0 0 32px;
    color: rgb(var(--color-text-subdued));
    line-height: var(--body-line-height);
  }
{%- endstyle -%}

<section
  id="Section-{{ section.id }}"
  class="not-found-section color-{{ color_scheme }}"
>
  <div class="not-found__container">
    <span class="not-found__label">404</span>
    <h1 class="not-found__title h2">{{ '404.title' | t }}</h1>
    <p class="not-found__body">{{ '404.body' | t }}</p>
    <a href="{{ routes.root_url }}" class="btn btn--primary">
      {{ '404.back_home' | t }}
    </a>
  </div>
</section>

{% schema %}
{
  "name": "t:general.404",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.blog_posts.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.blog_posts.padding_top",
      "min": 0,
      "max": 150,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.blog_posts.padding_bottom",
      "min": 0,
      "max": 150,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ]
}
{% endschema %}
