{{ 'section-customers.css' | asset_url | stylesheet_tag }}

<div class="customer color-{{ section.settings.color_scheme }}">
  <div class="container">
    <div class="customer__header">
      <h1>{{ 'customer.activate.title' | t }}</h1>
      <p>{{ 'customer.activate.subtitle' | t }}</p>
    </div>

    <div class="customer__form-wrapper">
      {%- form 'activate_customer_password' -%}
        {%- if form.errors -%}
          <div class="customer__form-errors" role="alert">
            <p>{{ form.errors | default_errors }}</p>
          </div>
        {%- endif -%}

        <div class="customer__form">
          <div class="field">
            <label for="ActivatePassword">{{ 'customer.activate.password' | t }}</label>
            <input
              type="password"
              name="customer[password]"
              id="ActivatePassword"
              autocomplete="new-password"
              required
            >
          </div>

          <div class="field">
            <label for="ActivatePasswordConfirm">{{ 'customer.activate.password_confirm' | t }}</label>
            <input
              type="password"
              name="customer[password_confirmation]"
              id="ActivatePasswordConfirm"
              autocomplete="new-password"
              required
            >
          </div>

          {%- render 'button', label: 'customer.activate.submit' | t, type: 'submit', style: 'primary' -%}

          {%- render 'button', label: 'customer.activate.decline' | t, type: 'submit', style: 'secondary', name: 'decline' -%}
        </div>
      {%- endform -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main_activate_account.name",
  "tag": "section",
  "class": "section-customer-activate-account",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.main_activate_account.color_scheme",
      "default": "scheme-1"
    }
  ]
}
{% endschema %}
