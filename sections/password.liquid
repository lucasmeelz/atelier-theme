{%- comment -%}
  Password — Storefront password page with logo, styled form, and optional message
  Displayed when the store is password-protected
{%- endcomment -%}

{%- liquid
  assign color_scheme = section.settings.color_scheme
-%}

{%- style -%}
  .password-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 40px var(--page-margin);
    background: rgb(var(--color-background));
    color: rgb(var(--color-text));
    text-align: center;
  }

  .password__container {
    max-width: 440px;
    width: 100%;
  }

  .password__logo {
    margin-bottom: 48px;
  }

  .password__logo img {
    max-width: {{ section.settings.logo_width }}px;
    height: auto;
  }

  .password__shop-name {
    margin-bottom: 48px;
    font-family: var(--font-heading-family);
    font-weight: var(--font-heading-weight);
    font-style: var(--font-heading-style);
    font-size: var(--h3-desktop);
    letter-spacing: var(--heading-letter-spacing);
    text-transform: var(--heading-text-transform);
  }

  @media screen and (max-width: 749px) {
    .password__shop-name {
      font-size: var(--h3-mobile);
    }
  }

  .password__title {
    margin: 0 0 12px;
  }

  .password__message {
    margin: 0 0 32px;
    color: rgb(var(--color-text-subdued));
    line-height: var(--body-line-height);
  }

  .password__form {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 16px;
  }

  .password__input {
    width: 100%;
    padding: 14px 16px;
    border: 1px solid rgb(var(--color-border));
    border-radius: var(--input-border-radius);
    background: transparent;
    font-family: var(--font-body-family);
    font-size: var(--body-font-size-desktop);
    color: rgb(var(--color-text));
    text-align: center;
    transition: border-color var(--duration-fast) var(--ease-ecrin);
  }

  .password__input:focus {
    outline: none;
    border-color: rgb(var(--color-text));
  }

  .password__input::placeholder {
    color: rgb(var(--color-text-subdued));
  }

  .password__errors {
    margin-bottom: 16px;
    padding: 12px 16px;
    border: 1px solid rgb(var(--color-accent));
    border-radius: var(--input-border-radius);
    font-size: 0.875em;
    color: rgb(var(--color-text));
  }

  .password__footer {
    margin-top: 48px;
    font-family: var(--font-label-family);
    font-size: var(--label-font-size);
    text-transform: var(--label-text-transform);
    letter-spacing: var(--label-letter-spacing);
    color: rgb(var(--color-text-subdued));
  }

  .password__footer a {
    color: rgb(var(--color-text));
  }
{%- endstyle -%}

<section class="password-section color-{{ color_scheme }}">
  <div class="password__container">

    {%- comment -%} Logo or Shop Name {%- endcomment -%}
    {%- if settings.logo -%}
      <div class="password__logo">
        {{
          settings.logo
          | image_url: width: 400
          | image_tag:
            alt: shop.name,
            loading: 'eager',
            widths: '200, 300, 400',
            style: 'max-width: {{ section.settings.logo_width }}px; height: auto;'
        }}
      </div>
    {%- else -%}
      <div class="password__shop-name">{{ shop.name }}</div>
    {%- endif -%}

    {%- comment -%} Title & Message {%- endcomment -%}
    <h1 class="password__title h3">{{ 'password.title' | t }}</h1>

    {%- if shop.password_message != blank -%}
      <p class="password__message">{{ shop.password_message }}</p>
    {%- else -%}
      <p class="password__message">{{ 'password.body' | t }}</p>
    {%- endif -%}

    {%- comment -%} Password Form {%- endcomment -%}
    {%- form 'storefront_password' -%}
      {%- if form.errors -%}
        <div class="password__errors" role="alert">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <div class="password__form">
        <input
          type="password"
          name="password"
          class="password__input"
          placeholder="{{ 'password.password' | t }}"
          autocomplete="current-password"
          required
        >
        <button type="submit" class="btn btn--primary">
          {{ 'password.submit' | t }}
        </button>
      </div>
    {%- endform -%}

    {%- comment -%} Footer {%- endcomment -%}
    <div class="password__footer">
      <a href="/admin">{{ shop.name }}</a>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "t:general.password",
  "tag": "section",
  "settings": [
    {
      "type": "range",
      "id": "logo_width",
      "label": "t:settings_schema.brand.logo_width",
      "min": 40,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 120
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.blog_posts.color_scheme",
      "default": "scheme-1"
    }
  ]
}
{% endschema %}
