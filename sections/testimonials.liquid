{%- comment -%}
  Testimonials — Customer quotes with optional rating, author image, and role
  Supports: Grid (1-3 columns) or Carousel (horizontal scroll-snap, no JS)
{%- endcomment -%}

{{ 'section-testimonials.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign heading = section.settings.heading
  assign heading_size = section.settings.heading_size
  assign subheading = section.settings.subheading
  assign layout = section.settings.layout
  assign columns_desktop = section.settings.columns_desktop
  assign show_rating = section.settings.show_rating
  assign color_scheme = section.settings.color_scheme
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
-%}

{%- style -%}
  #Section-{{ section.id }} {
    --section-padding-top: {{ padding_top }}px;
    --section-padding-bottom: {{ padding_bottom }}px;
    --testimonials-columns: {{ columns_desktop }};
  }
{%- endstyle -%}

<div
  id="Section-{{ section.id }}"
  class="testimonials color-{{ color_scheme }}"
>
  <div class="container">
    {%- if heading != blank or subheading != blank -%}
      <div class="testimonials__header">
        {%- if subheading != blank -%}
          <p class="testimonials__subheading label">{{ subheading }}</p>
        {%- endif -%}
        {%- if heading != blank -%}
          <{{ heading_size }} class="testimonials__heading">{{ heading }}</{{ heading_size }}>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="testimonials__{{ layout }}">
      {%- for block in section.blocks -%}
        <div class="testimonials__card" data-stagger {{ block.shopify_attributes }}>

          {%- if show_rating and block.settings.rating > 0 -%}
            <div class="testimonials__rating" role="img" aria-label="{{ block.settings.rating }} out of 5 stars">
              {%- for i in (1..5) -%}
                {%- if i <= block.settings.rating -%}
                  <span class="testimonials__star testimonials__star--filled" aria-hidden="true">&#9733;</span>
                {%- else -%}
                  <span class="testimonials__star testimonials__star--empty" aria-hidden="true">&#9733;</span>
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- if block.settings.quote != blank -%}
            <blockquote class="testimonials__quote rte">{{ block.settings.quote }}</blockquote>
          {%- endif -%}

          {%- if block.settings.author != blank or block.settings.image != blank -%}
            <div class="testimonials__author">
              {%- if block.settings.image != blank -%}
                <div class="testimonials__author-image">
                  {{ block.settings.image | image_url: width: 96 | image_tag:
                    loading: 'lazy',
                    widths: '48,96',
                    sizes: '48px',
                    alt: block.settings.author | escape
                  }}
                </div>
              {%- endif -%}

              {%- if block.settings.author != blank or block.settings.role != blank -%}
                <div class="testimonials__author-info">
                  {%- if block.settings.author != blank -%}
                    <p class="testimonials__author-name">{{ block.settings.author }}</p>
                  {%- endif -%}
                  {%- if block.settings.role != blank -%}
                    <p class="testimonials__author-role">{{ block.settings.role }}</p>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}

        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.testimonials.name",
  "tag": "section",
  "class": "section-testimonials",
  "max_blocks": 9,
  "disabled_on": {
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.testimonials.content_header"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.testimonials.subheading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.testimonials.heading",
      "default": "What our clients say"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.testimonials.heading_size",
      "options": [
        { "value": "h2", "label": "t:sections.testimonials.heading_large" },
        { "value": "h3", "label": "t:sections.testimonials.heading_medium" }
      ],
      "default": "h2"
    },
    {
      "type": "header",
      "content": "t:sections.testimonials.layout_header"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "t:sections.testimonials.layout",
      "options": [
        { "value": "grid", "label": "t:sections.testimonials.layout_grid" },
        { "value": "carousel", "label": "t:sections.testimonials.layout_carousel" }
      ],
      "default": "grid"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "t:sections.testimonials.columns_desktop",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "t:sections.testimonials.show_rating",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.testimonials.style_header"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.testimonials.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.testimonials.padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.testimonials.padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "t:sections.testimonials.blocks.testimonial",
      "settings": [
        {
          "type": "richtext",
          "id": "quote",
          "label": "t:sections.testimonials.blocks.quote",
          "default": "<p>An exceptional experience from start to finish. The attention to detail and quality of craftsmanship is truly remarkable.</p>"
        },
        {
          "type": "text",
          "id": "author",
          "label": "t:sections.testimonials.blocks.author",
          "default": "Alexandra M."
        },
        {
          "type": "text",
          "id": "role",
          "label": "t:sections.testimonials.blocks.role",
          "default": "Verified buyer"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "t:sections.testimonials.blocks.rating",
          "min": 0,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.testimonials.blocks.image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.testimonials.preset_name",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "quote": "<p>An exceptional experience from start to finish. The attention to detail and quality of craftsmanship is truly remarkable.</p>",
            "author": "Alexandra M.",
            "role": "Verified buyer",
            "rating": 5
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "<p>The quality exceeded all my expectations. Every detail has been thoughtfully considered — a true luxury experience.</p>",
            "author": "James R.",
            "role": "Loyal customer",
            "rating": 5
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "<p>Impeccable service and beautiful products. This brand understands what true craftsmanship means.</p>",
            "author": "Sophie L.",
            "role": "Verified buyer",
            "rating": 5
          }
        }
      ]
    }
  ]
}
{% endschema %}
