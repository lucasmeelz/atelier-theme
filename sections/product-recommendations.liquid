{%- comment -%}
  Product Recommendations — Related products via Shopify API
  Loaded via AJAX with section rendering for performance
{%- endcomment -%}

{{ 'section-featured-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{%- if settings.card_hover_effect == 'carousel' -%}
  <script src="{{ 'component-card-carousel.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- liquid
  assign heading = section.settings.heading
  assign products_to_show = section.settings.products_to_show
  assign columns_desktop = section.settings.columns_desktop
  assign image_ratio = section.settings.image_ratio
  assign show_secondary_image = section.settings.show_secondary_image
  assign show_vendor = section.settings.show_vendor
  assign show_rating = section.settings.show_rating
  assign show_quick_add = section.settings.show_quick_add
  assign show_color_swatches = section.settings.show_color_swatches
  assign color_scheme = section.settings.color_scheme
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
-%}

{%- style -%}
  #Section-{{ section.id }} {
    --section-padding-top: {{ padding_top }}px;
    --section-padding-bottom: {{ padding_bottom }}px;
  }
{%- endstyle -%}

<div
  id="Section-{{ section.id }}"
  class="product-recommendations color-{{ color_scheme }}"
  style="padding-top: var(--section-padding-top); padding-bottom: var(--section-padding-bottom);"
  data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ products_to_show }}&intent=related"
  data-section-id="{{ section.id }}"
>
  {%- if recommendations.performed and recommendations.products_count > 0 -%}
    <div class="container">
      {%- if heading != blank -%}
        <div class="product-recommendations__header">
          <h2 class="product-recommendations__heading">{{ heading }}</h2>
        </div>
      {%- endif -%}

      <div
        class="product-recommendations__grid"
        style="--grid-columns-desktop: {{ columns_desktop }};"
      >
        {%- for product in recommendations.products -%}
          <div class="product-recommendations__item">
            {%- render 'card-product',
              product: product,
              image_ratio: image_ratio,
              show_secondary_image: show_secondary_image,
              show_vendor: show_vendor,
              show_rating: show_rating,
              show_quick_add: show_quick_add,
              show_color_swatches: show_color_swatches,
              columns: columns_desktop,
              lazy: true
            -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</div>

<script>
  (function() {
    const section = document.querySelector('#Section-{{ section.id }}');
    if (!section) return;
    const url = section.dataset.url;
    if (!url) return;

    fetch(url)
      .then(res => res.text())
      .then(html => {
        const doc = new DOMParser().parseFromString(html, 'text/html');
        const newSection = doc.querySelector('#Section-{{ section.id }}');
        if (newSection && newSection.innerHTML.trim().length > 0) {
          section.innerHTML = newSection.innerHTML;
        }
      })
      .catch(() => {});
  })();
</script>

{% schema %}
{
  "name": "t:sections.product_recommendations.name",
  "tag": "section",
  "class": "section-product-recommendations",
  "disabled_on": {
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.product_recommendations.heading",
      "default": "You may also like"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "t:sections.product_recommendations.products_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "t:sections.product_recommendations.columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "t:sections.product_recommendations.image_ratio",
      "options": [
        { "value": "natural", "label": "t:sections.product_recommendations.ratio_natural" },
        { "value": "portrait", "label": "t:sections.product_recommendations.ratio_portrait" },
        { "value": "square", "label": "t:sections.product_recommendations.ratio_square" }
      ],
      "default": "portrait"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "label": "t:sections.product_recommendations.show_secondary_image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "t:sections.product_recommendations.show_vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "t:sections.product_recommendations.show_rating",
      "default": false,
      "info": "t:sections.product_recommendations.show_rating_info"
    },
    {
      "type": "checkbox",
      "id": "show_quick_add",
      "label": "t:sections.product_recommendations.show_quick_add",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_color_swatches",
      "label": "t:sections.product_recommendations.show_color_swatches",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.product_recommendations.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.product_recommendations.padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.product_recommendations.padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ]
}
{% endschema %}
