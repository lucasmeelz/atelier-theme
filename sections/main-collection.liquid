{%- comment -%}
  Main Collection — Product grid with filtering and sorting
  Uses Shopify's native collection filtering and sorting
  AJAX pagination for seamless browsing
{%- endcomment -%}

{{ 'section-main-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{%- if settings.product_card_enable_carousel -%}
  <script src="{{ 'component-card-carousel.js' | asset_url }}" defer="defer"></script>
{%- endif -%}
{%- if section.settings.enable_quick_view -%}
  {{ 'component-quick-view.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'component-quick-view.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- liquid
  assign products_per_page = section.settings.products_per_page
  assign columns_desktop = section.settings.columns_desktop
  assign columns_mobile = section.settings.columns_mobile
  assign image_ratio = section.settings.image_ratio
  assign show_vendor = section.settings.show_vendor
  assign show_quick_add = section.settings.show_quick_add
  assign grid_gap = section.settings.grid_gap | default: 'standard'
  assign show_color_swatches = section.settings.show_color_swatches
  assign show_sort = section.settings.show_sort
  assign show_filters = section.settings.show_filters
  assign filter_layout = section.settings.filter_layout
  assign color_scheme = section.settings.color_scheme
  assign enable_quick_view = section.settings.enable_quick_view

  assign has_promotion_blocks = false
  assign has_featured_blocks = false
  for block in section.blocks
    if block.type == 'promotion'
      assign has_promotion_blocks = true
    endif
    if block.type == 'featured_product'
      assign has_featured_blocks = true
    endif
  endfor
-%}

{%- paginate collection.products by products_per_page -%}

<div
  id="Section-{{ section.id }}"
  class="main-collection color-{{ color_scheme }}"
  data-section-id="{{ section.id }}"
>
  <div class="container">

    <collection-filters data-section-id="{{ section.id }}">

    {%- comment -%} Toolbar: filters + sort {%- endcomment -%}
    {%- if show_filters or show_sort -%}
      <div class="collection__toolbar">
        <div class="collection__toolbar-left">
          {%- if show_filters -%}
            <button
              class="collection__filter-toggle btn btn--outline"
              type="button"
              aria-expanded="false"
              aria-controls="collection-filters-{{ section.id }}"
            >
              {%- render 'icon', name: 'filter', size: 16 -%}
              <span>{{ 'collection.filter' | t }}</span>
              {%- if collection.filters.size > 0 -%}
                {%- assign active_filter_count = 0 -%}
                {%- for filter in collection.filters -%}
                  {%- assign active_filter_count = active_filter_count | plus: filter.active_values.size -%}
                {%- endfor -%}
                {%- if active_filter_count > 0 -%}
                  <span class="collection__filter-count" aria-hidden="true">{{ active_filter_count }}</span>
                  <span class="visually-hidden">{{ active_filter_count }} {{ 'collection.active_filters' | t }}</span>
                {%- endif -%}
              {%- endif -%}
            </button>
          {%- endif -%}

          <p class="collection__product-count">
            {{ 'collection.product_count' | t: count: collection.products_count }}
          </p>
        </div>

        {%- if show_sort or section.settings.show_view_toggle -%}
          <div class="collection__toolbar-right">
            {%- if show_sort -%}
              <div class="collection__sort">
                <label for="sort-by-{{ section.id }}" class="collection__sort-label">
                  {{ 'collection.sort_by' | t }}
                </label>
                <select
                  id="sort-by-{{ section.id }}"
                  class="collection__sort-select"
                  aria-label="{{ 'collection.sort_by' | t }}"
                >
                  {%- for option in collection.sort_options -%}
                    <option
                      value="{{ option.value }}"
                      {% if collection.sort_by == option.value %}selected{% endif %}
                    >
                      {{ option.name }}
                    </option>
                  {%- endfor -%}
                </select>
              </div>
            {%- endif -%}

            {%- if section.settings.show_view_toggle -%}
              <div class="collection__view-toggle" role="radiogroup" aria-label="{{ 'collection.view_as' | t }}">
                <button
                  class="collection__view-btn collection__view-btn--grid collection__view-btn--active"
                  type="button"
                  data-view="grid"
                  aria-label="{{ 'collection.view_grid' | t }}"
                  aria-pressed="true"
                >
                  {%- render 'icon', name: 'grid', size: 18 -%}
                </button>
                <button
                  class="collection__view-btn collection__view-btn--list"
                  type="button"
                  data-view="list"
                  aria-label="{{ 'collection.view_list' | t }}"
                  aria-pressed="false"
                >
                  {%- render 'icon', name: 'list', size: 18 -%}
                </button>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} Layout wrapper for sidebar mode {%- endcomment -%}
    {%- if filter_layout == 'sidebar' -%}
      <div class="collection__layout collection__layout--sidebar">
    {%- endif -%}

    {%- comment -%} Filters {%- endcomment -%}
    {%- if show_filters and collection.filters.size > 0 -%}
      <div
        id="collection-filters-{{ section.id }}"
        class="collection__filters collection__filters--{{ filter_layout }}"
        aria-hidden="{% if filter_layout == 'sidebar' %}false{% else %}true{% endif %}"
      >
        <form id="collection-filter-form" class="collection__filter-form">
          {%- for filter in collection.filters -%}
            <details class="collection__filter-group" open>
              <summary class="collection__filter-group-title">
                {{ filter.label }}
              </summary>
              <div class="collection__filter-group-content">
                {%- case filter.type -%}
                  {%- when 'list' -%}
                    <ul class="collection__filter-list">
                      {%- for value in filter.values -%}
                        <li class="collection__filter-item">
                          <label class="collection__filter-checkbox" for="filter-{{ filter.param_name }}-{{ forloop.index }}">
                            <input
                              type="checkbox"
                              id="filter-{{ filter.param_name }}-{{ forloop.index }}"
                              name="{{ value.param_name }}"
                              value="{{ value.value }}"
                              {% if value.active %}checked{% endif %}
                              {% if value.count == 0 and value.active == false %}disabled{% endif %}
                            >
                            <span class="collection__filter-checkbox-indicator"></span>
                            <span class="collection__filter-checkbox-label">
                              {{ value.label }}
                              <span class="collection__filter-checkbox-count">({{ value.count }})</span>
                            </span>
                          </label>
                        </li>
                      {%- endfor -%}
                    </ul>

                  {%- when 'price_range' -%}
                    <div class="collection__price-range">
                      <div class="collection__price-range-field">
                        <label for="filter-{{ filter.param_name }}-gte">{{ 'collection.filter_from' | t }}</label>
                        <span class="collection__price-range-input-wrap">
                          <span>{{ cart.currency.symbol }}</span>
                          <input
                            type="text"
                            inputmode="decimal"
                            id="filter-{{ filter.param_name }}-gte"
                            name="{{ filter.min_value.param_name }}"
                            {%- if filter.min_value.value != nil and filter.min_value.value != 0 %}
                              value="{{ filter.min_value.value | money_without_currency | strip }}"
                            {%- endif %}
                            placeholder="0"
                          >
                        </span>
                      </div>
                      <div class="collection__price-range-field">
                        <label for="filter-{{ filter.param_name }}-lte">{{ 'collection.filter_to' | t }}</label>
                        <span class="collection__price-range-input-wrap">
                          <span>{{ cart.currency.symbol }}</span>
                          <input
                            type="text"
                            inputmode="decimal"
                            id="filter-{{ filter.param_name }}-lte"
                            name="{{ filter.max_value.param_name }}"
                            {%- if filter.max_value.value != nil and filter.max_value.value != 0 %}
                              value="{{ filter.max_value.value | money_without_currency | strip }}"
                            {%- endif %}
                            placeholder="{{ filter.range_max | money_without_currency | strip }}"
                          >
                        </span>
                      </div>
                    </div>
                {%- endcase -%}
              </div>
            </details>
          {%- endfor -%}

          <div class="collection__filter-actions">
            <button type="submit" class="btn btn--primary collection__filter-apply">
              <span class="btn__label">{{ 'collection.filter_apply' | t }}</span>
              <span class="btn__fill" aria-hidden="true"></span>
            </button>
            {%- if collection.current_vendor or collection.current_type or collection.filters.size > 0 -%}
              <a href="{{ collection.url }}" class="collection__filter-clear">
                {{ 'collection.filter_clear' | t }}
              </a>
            {%- endif -%}
          </div>
        </form>
      </div>
    {%- endif -%}

    {%- comment -%} Active filters {%- endcomment -%}
    {%- assign has_active_filters = false -%}
    {%- for filter in collection.filters -%}
      {%- if filter.active_values.size > 0 -%}
        {%- assign has_active_filters = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if has_active_filters -%}
      <div class="collection__active-filters">
        {%- for filter in collection.filters -%}
          {%- for value in filter.active_values -%}
            <a href="{{ value.url_to_remove }}" class="collection__active-filter">
              {{ value.label }}
              <span class="collection__active-filter-remove" aria-hidden="true">&times;</span>
            </a>
          {%- endfor -%}
        {%- endfor -%}
        <a href="{{ collection.url }}" class="collection__active-filter-clear">
          {{ 'collection.filter_clear_all' | t }}
        </a>
      </div>
    {%- endif -%}

    </collection-filters>

    {%- comment -%} Collection description block (renders before the product grid) {%- endcomment -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'collection_description' -%}
        {%- liquid
          assign desc_layout = block.settings.layout | default: 'text_only'
          assign desc_image = block.settings.image
          assign desc_image_position = block.settings.image_position | default: 'left'
          assign desc_content = block.settings.content
        -%}
        {%- if desc_content != blank or desc_image != blank -%}
          <div
            class="collection__description collection__description--{{ desc_layout }}{% if desc_image_position == 'right' %} collection__description--image-right{% endif %}"
            {{ block.shopify_attributes }}
          >
            {%- if desc_layout == 'image_text' and desc_image != blank -%}
              <div class="collection__description-image">
                {{ desc_image | image_url: width: 960 | image_tag:
                  loading: 'lazy',
                  widths: '400,600,800,960',
                  sizes: '(min-width: 990px) 50vw, 100vw',
                  alt: desc_image.alt | default: collection.title
                }}
              </div>
            {%- endif -%}
            {%- if desc_content != blank -%}
              <div class="collection__description-text rte">
                {{ desc_content }}
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}

    {%- comment -%} Product grid {%- endcomment -%}
    <div
      id="collection-grid-{{ section.id }}"
      class="collection__grid collection__grid--desktop-{{ columns_desktop }} collection__grid--mobile-{{ columns_mobile }} collection__grid--gap-{{ grid_gap }}"
      {% if settings.stagger_products %}data-stagger-cards{% endif %}
    >
      {%- if collection.products.size > 0 -%}
        {%- liquid
          assign item_index = 0
        -%}
        {%- for product in collection.products -%}
          {%- assign item_index = item_index | plus: 1 -%}

          {%- comment -%}
            Check if any grid-injection block should be inserted BEFORE this product.
            Promotions and featured products are inserted after (position × columns_desktop) items.
          {%- endcomment -%}

          {%- if has_promotion_blocks or has_featured_blocks -%}
            {%- for block in section.blocks -%}

              {%- if block.type == 'promotion' -%}
                {%- liquid
                  assign promo_position = block.settings.position | default: 2
                  assign promo_insert_after = promo_position | times: columns_desktop
                  assign promo_trigger = promo_insert_after | plus: 1
                  assign promo_layout = block.settings.layout | default: 'full_width'
                  assign promo_text_color = block.settings.text_color | default: 'light'
                  assign promo_overlay = block.settings.overlay_opacity | default: 30 | times: 0.01
                  assign promo_color_scheme = block.settings.color_scheme
                -%}
                {%- if item_index == promo_trigger -%}
                  <div
                    class="collection__grid-item collection__grid-item--full collection__promotion collection__promotion--{{ promo_layout }} collection__promotion--{{ promo_text_color }}{% if promo_color_scheme != blank %} color-{{ promo_color_scheme }}{% endif %}"
                    {{ block.shopify_attributes }}
                  >
                    {%- if block.settings.image != blank -%}
                      <div class="collection__promotion-bg" aria-hidden="true">
                        {{ block.settings.image | image_url: width: 2000 | image_tag:
                          loading: 'lazy',
                          widths: '800,1200,1600,2000',
                          sizes: '100vw',
                          class: 'collection__promotion-img',
                          alt: ''
                        }}
                        {%- if promo_overlay > 0 -%}
                          <div class="collection__promotion-overlay" style="--promo-overlay: {{ promo_overlay }};"></div>
                        {%- endif -%}
                      </div>
                    {%- else -%}
                      {%- if promo_overlay > 0 -%}
                        <div class="collection__promotion-overlay" style="--promo-overlay: {{ promo_overlay }};" aria-hidden="true"></div>
                      {%- endif -%}
                    {%- endif -%}

                    <div class="collection__promotion-content">
                      {%- if block.settings.subheading != blank -%}
                        <p class="collection__promotion-subheading label">{{ block.settings.subheading }}</p>
                      {%- endif -%}
                      {%- if block.settings.heading != blank -%}
                        <h2 class="collection__promotion-heading">{{ block.settings.heading }}</h2>
                      {%- endif -%}
                      {%- if block.settings.button_label != blank -%}
                        {%- if block.settings.button_link != blank -%}
                          <a href="{{ block.settings.button_link }}" class="btn btn--primary collection__promotion-btn">
                            <span class="btn__label">{{ block.settings.button_label }}</span>
                            <span class="btn__fill" aria-hidden="true"></span>
                          </a>
                        {%- else -%}
                          <span class="btn btn--primary collection__promotion-btn">
                            <span class="btn__label">{{ block.settings.button_label }}</span>
                            <span class="btn__fill" aria-hidden="true"></span>
                          </span>
                        {%- endif -%}
                      {%- endif -%}
                    </div>
                  </div>
                {%- endif -%}

              {%- elsif block.type == 'featured_product' -%}
                {%- liquid
                  assign fp_position = block.settings.position | default: 1
                  assign fp_insert_after = fp_position | times: columns_desktop
                  assign fp_trigger = fp_insert_after | plus: 1
                  assign fp_product = block.settings.product
                  assign fp_color_scheme = block.settings.color_scheme
                -%}
                {%- if item_index == fp_trigger and fp_product != blank -%}
                  <div
                    class="collection__grid-item collection__grid-item--span2 collection__featured-product{% if fp_color_scheme != blank %} color-{{ fp_color_scheme }}{% endif %}"
                    {{ block.shopify_attributes }}
                  >
                    <a href="{{ fp_product.url }}" class="collection__featured-product-link">
                      {%- liquid
                        assign fp_sizes = '(min-width: 990px) calc(200% / ' | append: columns_desktop | append: ' - 24px), 100vw'
                      -%}
                      {%- if block.settings.image != blank -%}
                        {{ block.settings.image | image_url: width: 1200 | image_tag:
                          loading: 'lazy',
                          widths: '600,800,1000,1200',
                          sizes: fp_sizes,
                          class: 'collection__featured-product-img',
                          alt: block.settings.image.alt | default: fp_product.title
                        }}
                      {%- elsif fp_product.featured_image != blank -%}
                        {{ fp_product.featured_image | image_url: width: 1200 | image_tag:
                          loading: 'lazy',
                          widths: '600,800,1000,1200',
                          sizes: fp_sizes,
                          class: 'collection__featured-product-img',
                          alt: fp_product.featured_image.alt | default: fp_product.title
                        }}
                      {%- endif -%}
                      <div class="collection__featured-product-info">
                        {%- if block.settings.heading != blank -%}
                          <p class="collection__featured-product-label label">{{ block.settings.heading }}</p>
                        {%- endif -%}
                        <h3 class="collection__featured-product-title">{{ fp_product.title }}</h3>
                        {%- render 'price', product: fp_product, show_badges: false, hide_tax_notice: true -%}
                        {%- if block.settings.show_description and fp_product.description != blank -%}
                          <p class="collection__featured-product-description">
                            {{ fp_product.description | strip_html | truncate: 140 }}
                          </p>
                        {%- endif -%}
                        <span class="collection__featured-product-cta" aria-hidden="true">
                          {{ 'collection.continue_shopping' | t }}
                          {%- render 'icon', name: 'arrow-right', size: 16 -%}
                        </span>
                      </div>
                    </a>
                  </div>
                {%- endif -%}

              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}

          {%- comment -%} Render the product card {%- endcomment -%}
          <div class="collection__grid-item">
            {%- render 'card-product',
              product: product,
              image_ratio: image_ratio,
              show_vendor: show_vendor,
              show_quick_add: show_quick_add,
              show_color_swatches: show_color_swatches,
              show_rating: settings.product_card_show_rating,
              columns: columns_desktop,
              lazy: true,
              heading_level: 'h2'
            -%}
            {%- if enable_quick_view -%}
              <button
                type="button"
                class="card-product__quick-view-trigger"
                data-quick-view-trigger="{{ product.handle }}"
                data-quick-view-title="{{ product.title | escape }}"
                aria-label="{{ 'product.quick_view_open' | t: title: product.title | escape }}"
              >
                {%- render 'icon', name: 'eye', size: 18 -%}
              </button>
            {%- endif -%}
          </div>
        {%- endfor -%}
      {%- else -%}
        <div class="collection__empty">
          <p>{{ 'collection.empty' | t }}</p>
          <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">
            <span class="btn__label">{{ 'collection.continue_shopping' | t }}</span>
            <span class="btn__fill" aria-hidden="true"></span>
          </a>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Pagination {%- endcomment -%}
    {%- if paginate.pages > 1 -%}
      {%- if section.settings.pagination_type == 'load_more' -%}
        {%- if paginate.next -%}
          {%- assign showing_count = paginate.current_offset | plus: paginate.page_size -%}
          <div class="collection__load-more">
            <button
              class="btn btn--outline collection__load-more-btn"
              type="button"
              data-next-url="{{ paginate.next.url }}"
              data-section-id="{{ section.id }}"
              aria-label="{{ 'collection.load_more' | t }}"
            >
              <span class="btn__label">{{ 'collection.load_more' | t }}</span>
              <span class="btn__fill" aria-hidden="true"></span>
            </button>
            <p class="collection__load-more-count">
              {{ 'collection.showing_count' | t: current: showing_count, total: paginate.items }}
            </p>
          </div>
        {%- endif -%}
      {%- else -%}
        <nav class="collection__pagination" role="navigation" aria-label="{{ 'accessibility.pagination' | t }}">
          <ul class="collection__pagination-list">
            {%- if paginate.previous -%}
              <li>
                <a href="{{ paginate.previous.url }}" class="collection__pagination-link collection__pagination-link--prev" aria-label="{{ 'accessibility.previous' | t }}">
                  {%- render 'icon', name: 'chevron-left', size: 16 -%}
                </a>
              </li>
            {%- endif -%}

            {%- for part in paginate.parts -%}
              <li>
                {%- if part.is_link -%}
                  <a href="{{ part.url }}" class="collection__pagination-link">{{ part.title }}</a>
                {%- else -%}
                  {%- if part.title == paginate.current_page -%}
                    <span class="collection__pagination-link collection__pagination-link--current" aria-current="page">{{ part.title }}</span>
                  {%- else -%}
                    <span class="collection__pagination-link collection__pagination-link--gap">{{ part.title }}</span>
                  {%- endif -%}
                {%- endif -%}
              </li>
            {%- endfor -%}

            {%- if paginate.next -%}
              <li>
                <a href="{{ paginate.next.url }}" class="collection__pagination-link collection__pagination-link--next" aria-label="{{ 'accessibility.next' | t }}">
                  {%- render 'icon', name: 'chevron-right', size: 16 -%}
                </a>
              </li>
            {%- endif -%}
          </ul>
        </nav>
      {%- endif -%}
    {%- endif -%}

    {%- if filter_layout == 'sidebar' -%}
      </div>{%- comment -%} .collection__layout--sidebar {%- endcomment -%}
    {%- endif -%}

  </div>
</div>

{%- endpaginate -%}

<script>
  if (!customElements.get('collection-filters')) {
    class CollectionFilters extends HTMLElement {
      constructor() {
        super();
        this._isLoading = false;
      }

      connectedCallback() {
        this.sectionId = this.dataset.sectionId;
        this.grid = document.querySelector('#collection-grid-' + this.sectionId);
        this.productCount = this.querySelector('.collection__product-count');
        this.activeFilters = null;
        this.pagination = null;

        this._bindEvents();
      }

      _bindEvents() {
        /* Sort select */
        var sortSelect = this.querySelector('#sort-by-' + this.sectionId);
        if (sortSelect) {
          sortSelect.addEventListener('change', (function(e) {
            this._updateCollection({ sort_by: e.target.value, page: null });
          }).bind(this));
        }

        /* Filter form submit */
        var form = this.querySelector('#collection-filter-form');
        if (form) {
          form.addEventListener('submit', (function(e) {
            e.preventDefault();
            this._submitFilters(form);
          }).bind(this));

          /* Live filtering on checkbox change */
          form.addEventListener('change', (function(e) {
            if (e.target.type === 'checkbox') {
              this._submitFilters(form);
            }
          }).bind(this));
        }

        /* Filter drawer toggle */
        var toggle = this.querySelector('.collection__filter-toggle');
        var filtersEl = this.querySelector('#collection-filters-' + this.sectionId);
        if (toggle && filtersEl) {
          toggle.addEventListener('click', function() {
            var expanded = this.getAttribute('aria-expanded') === 'true';
            this.setAttribute('aria-expanded', String(!expanded));
            filtersEl.setAttribute('aria-hidden', String(expanded));
          });
        }

        /* Active filter chip removal */
        this.addEventListener('click', (function(e) {
          var chip = e.target.closest('.collection__active-filter');
          if (chip) {
            e.preventDefault();
            this._fetchAndReplace(chip.href);
          }
          var clearAll = e.target.closest('.collection__active-filter-clear');
          if (clearAll) {
            e.preventDefault();
            this._fetchAndReplace(clearAll.href);
          }
        }).bind(this));

        /* AJAX pagination */
        this._bindPagination();
      }

      _bindPagination() {
        var paginationContainer = this.closest('.main-collection');
        if (!paginationContainer) return;

        paginationContainer.addEventListener('click', (function(e) {
          var link = e.target.closest('.collection__pagination-link[href]');
          if (link) {
            e.preventDefault();
            this._fetchAndReplace(link.href);
            /* Scroll to top of grid */
            var toolbar = this.querySelector('.collection__toolbar');
            if (toolbar) {
              toolbar.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
          }
        }).bind(this));
      }

      _submitFilters(form) {
        var formData = new FormData(form);
        var url = new URL(window.location.href);

        /* Remove existing filter params */
        Array.from(url.searchParams.keys()).forEach(function(key) {
          if (key.startsWith('filter.')) url.searchParams.delete(key);
        });

        /* Add new filter params */
        formData.forEach(function(value, key) {
          if (value) url.searchParams.append(key, value);
        });

        url.searchParams.delete('page');
        this._fetchAndReplace(url.toString());
      }

      _updateCollection(params) {
        var url = new URL(window.location.href);
        Object.keys(params).forEach(function(key) {
          if (params[key] === null) {
            url.searchParams.delete(key);
          } else {
            url.searchParams.set(key, params[key]);
          }
        });
        this._fetchAndReplace(url.toString());
      }

      _fetchAndReplace(urlString) {
        if (this._isLoading) return;
        this._isLoading = true;

        var sectionId = this.sectionId;
        var url = new URL(urlString);
        url.searchParams.set('sections', sectionId);

        /* Show loading state */
        if (this.grid) this.grid.classList.add('collection__grid--loading');
        this.setAttribute('aria-busy', 'true');

        fetch(url.toString())
          .then(function(res) { if (!res.ok) throw new Error(res.status); return res.json(); })
          .then((function(data) {
            var html = data[sectionId];
            if (!html) return;

            var parser = new DOMParser();
            var doc = parser.parseFromString(html, 'text/html');

            /* Replace grid */
            var newGrid = doc.querySelector('#collection-grid-' + sectionId);
            if (newGrid && this.grid) {
              this.grid.innerHTML = newGrid.innerHTML;
              this.grid.className = newGrid.className;
            }

            /* Replace filters */
            var newFilters = doc.querySelector('#collection-filters-' + sectionId);
            var currentFilters = this.querySelector('#collection-filters-' + sectionId);
            if (newFilters && currentFilters) {
              currentFilters.innerHTML = newFilters.innerHTML;
            }

            /* Replace active filters */
            var newActive = doc.querySelector('.collection__active-filters');
            var currentActive = this.querySelector('.collection__active-filters');
            var activeParent = currentActive ? currentActive.parentNode : (this.querySelector('#collection-filters-' + sectionId) || this).parentNode;

            if (newActive && currentActive) {
              currentActive.outerHTML = newActive.outerHTML;
            } else if (newActive && !currentActive) {
              /* Insert after filters or toolbar */
              var insertAfter = this.querySelector('#collection-filters-' + sectionId) || this.querySelector('.collection__toolbar');
              if (insertAfter && insertAfter.parentNode) {
                insertAfter.insertAdjacentHTML('afterend', newActive.outerHTML);
              }
            } else if (!newActive && currentActive) {
              currentActive.remove();
            }

            /* Replace pagination */
            var parent = this.closest('.main-collection');
            if (parent) {
              var newPag = doc.querySelector('.collection__pagination');
              var currentPag = parent.querySelector('.collection__pagination');
              if (newPag && currentPag) {
                currentPag.outerHTML = newPag.outerHTML;
              } else if (newPag && !currentPag) {
                var gridEl = parent.querySelector('#collection-grid-' + sectionId);
                if (gridEl) gridEl.insertAdjacentHTML('afterend', newPag.outerHTML);
              } else if (!newPag && currentPag) {
                currentPag.remove();
              }
            }

            /* Replace product count */
            var newCount = doc.querySelector('.collection__product-count');
            if (newCount && this.productCount) {
              this.productCount.textContent = newCount.textContent;
            }

            /* Replace filter count badge */
            var newBadge = doc.querySelector('.collection__filter-count');
            var currentBadge = this.querySelector('.collection__filter-count');
            if (newBadge && currentBadge) {
              currentBadge.outerHTML = newBadge.outerHTML;
            } else if (newBadge && !currentBadge) {
              var toggleBtn = this.querySelector('.collection__filter-toggle');
              if (toggleBtn) {
                var span = toggleBtn.querySelector('span');
                if (span) span.insertAdjacentHTML('afterend', newBadge.outerHTML);
              }
            } else if (!newBadge && currentBadge) {
              currentBadge.remove();
            }

            /* Update URL without reload */
            var cleanUrl = new URL(urlString);
            cleanUrl.searchParams.delete('sections');
            window.history.pushState({}, '', cleanUrl.toString());

            /* Re-trigger stagger animation */
            if (this.grid) {
              this.grid.querySelectorAll('.collection__grid-item').forEach(function(item, i) {
                item.style.setProperty('--stagger-index', i);
              });
            }

          }).bind(this))
          .catch(function(err) {
            console.error('Collection filter error:', err);
            /* Fallback to hard navigation */
            window.location.href = urlString;
          })
          .finally((function() {
            this._isLoading = false;
            if (this.grid) this.grid.classList.remove('collection__grid--loading');
            this.removeAttribute('aria-busy');
          }).bind(this));
      }
    }

    customElements.define('collection-filters', CollectionFilters);
  }

  /* Grid/List view toggle */
  (function() {
    document.addEventListener('click', function(e) {
      var btn = e.target.closest('.collection__view-btn');
      if (!btn) return;

      var view = btn.dataset.view;
      var sectionEl = btn.closest('.main-collection');
      if (!sectionEl) return;

      var grid = sectionEl.querySelector('[class*="collection__grid"]');
      if (!grid) return;

      /* Update buttons */
      sectionEl.querySelectorAll('.collection__view-btn').forEach(function(b) {
        b.classList.remove('collection__view-btn--active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('collection__view-btn--active');
      btn.setAttribute('aria-pressed', 'true');

      /* Toggle grid class */
      grid.classList.toggle('collection__grid--list-view', view === 'list');

      /* Persist preference */
      try { localStorage.setItem('ecrin-collection-view', view); } catch(e) {}
    });

    /* Restore preference on load */
    try {
      var saved = localStorage.getItem('ecrin-collection-view');
      if (saved === 'list') {
        document.querySelectorAll('.collection__grid').forEach(function(grid) {
          grid.classList.add('collection__grid--list-view');
        });
        document.querySelectorAll('.collection__view-btn--list').forEach(function(btn) {
          btn.classList.add('collection__view-btn--active');
          btn.setAttribute('aria-pressed', 'true');
        });
        document.querySelectorAll('.collection__view-btn--grid').forEach(function(btn) {
          btn.classList.remove('collection__view-btn--active');
          btn.setAttribute('aria-pressed', 'false');
        });
      }
    } catch(e) {}
  })();

  /* Load More button */
  (function() {
    document.addEventListener('click', function(e) {
      var btn = e.target.closest('.collection__load-more-btn');
      if (!btn) return;

      var nextUrl = btn.dataset.nextUrl;
      var sectionId = btn.dataset.sectionId;
      if (!nextUrl || !sectionId) return;

      btn.classList.add('collection__load-more-btn--loading');
      btn.setAttribute('aria-busy', 'true');

      var url = new URL(nextUrl, window.location.origin);
      url.searchParams.set('sections', sectionId);

      fetch(url.toString())
        .then(function(res) { return res.json(); })
        .then(function(data) {
          var html = data[sectionId];
          if (!html) return;

          var parser = new DOMParser();
          var doc = parser.parseFromString(html, 'text/html');

          /* Append new product items to grid */
          var grid = document.querySelector('#collection-grid-' + sectionId);
          var newGrid = doc.querySelector('#collection-grid-' + sectionId);
          if (grid && newGrid) {
            var existingCount = grid.children.length;
            Array.from(newGrid.children).forEach(function(item, i) {
              item.style.setProperty('--stagger-index', existingCount + i);
              grid.appendChild(item);
            });
          }

          /* Replace load-more button with next page's or remove */
          var newLoadMore = doc.querySelector('.collection__load-more');
          var currentLoadMore = btn.closest('.collection__load-more');
          if (newLoadMore && currentLoadMore) {
            currentLoadMore.outerHTML = newLoadMore.outerHTML;
          } else if (currentLoadMore) {
            currentLoadMore.remove();
          }

          /* Update URL */
          window.history.replaceState({}, '', nextUrl);
        })
        .catch(function() {
          window.location.href = nextUrl;
        });
    });
  })();
</script>

