{%- comment -%}
  Main Product Section — Premium block-based product page
  Inspired by Dior layout: clean gallery left, minimal info right
  17 block types including 3 innovative differentiators
{%- endcomment -%}

{{ 'section-main-product.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign product = product
  assign current_variant = product.selected_or_first_available_variant

  assign media_size = section.settings.media_size
  assign media_position = section.settings.media_position
  assign gallery_layout = section.settings.gallery_layout
  assign thumbnail_position = section.settings.thumbnail_position
  assign enable_zoom = section.settings.enable_zoom
  assign enable_video_loop = section.settings.enable_video_loop
  assign sticky_info = section.settings.sticky_info
  assign color_scheme = section.settings.color_scheme
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
-%}

{%- style -%}
  #Section-{{ section.id }} {
    --section-padding-top: {{ padding_top }}px;
    --section-padding-bottom: {{ padding_bottom }}px;
    --product-media-width: {{ media_size }}%;
  }
{%- endstyle -%}

<main-product
  id="Section-{{ section.id }}"
  class="product-section color-{{ color_scheme }}"
  data-section-id="{{ section.id }}"
  data-product-url="{{ product.url }}"
  data-product-id="{{ product.id }}"
>
  <div class="container">
    <div class="product__grid product__grid--{{ media_position }}">

      {%- comment -%} ===== MEDIA COLUMN ===== {%- endcomment -%}
      <div class="product__media-column">
        <div
          class="product__gallery product__gallery--{{ gallery_layout }}"
          data-gallery
          {% if enable_zoom %}data-zoom="true"{% endif %}
        >
          {%- comment -%} Gallery: stacked / thumbnail_slider / thumbnail_grid {%- endcomment -%}
          {%- if gallery_layout == 'stacked' -%}
            {%- comment -%} Stacked — Dior-style: all images in a vertical column {%- endcomment -%}
            <div class="product__media-list product__media-list--stacked">
              {%- for media in product.media -%}
                {%- liquid
                  assign media_loading = 'lazy'
                  assign media_priority = 'auto'
                  if forloop.first
                    assign media_loading = 'eager'
                    assign media_priority = 'high'
                  endif
                -%}
                <div
                  class="product__media-item{% if forloop.first %} is-active{% endif %}"
                  data-media-id="{{ media.id }}"
                  data-media-type="{{ media.media_type }}"
                  data-index="{{ forloop.index0 }}"
                >
                  {%- case media.media_type -%}
                    {%- when 'image' -%}
                      <div class="product__media-image{% if enable_zoom %} product__media-image--zoomable{% endif %}">
                        {{ media | image_url: width: 1400 | image_tag:
                          loading: media_loading,
                          fetchpriority: media_priority,
                          widths: '400,600,800,1000,1200,1400',
                          sizes: '(min-width: 990px) calc(var(--product-media-width, 55%) * (var(--page-width, 1440px) - 40px) / 100), calc(100vw - 40px)',
                          class: 'product__media-img',
                          alt: media.alt | default: product.title
                        }}
                      </div>
                    {%- when 'video' -%}
                      <div class="product__media-video">
                        {{ media | media_tag:
                          autoplay: false,
                          loop: enable_video_loop,
                          controls: true,
                          muted: false,
                          class: 'product__media-video-el'
                        }}
                      </div>
                    {%- when 'external_video' -%}
                      <div class="product__media-video">
                        {{ media | external_video_url: autoplay: false, loop: enable_video_loop | external_video_tag:
                          class: 'product__media-iframe',
                          loading: 'lazy'
                        }}
                      </div>
                    {%- when 'model' -%}
                      <div class="product__media-model">
                        {{ media | model_viewer_tag:
                          reveal: 'interaction',
                          toggleable: true,
                          class: 'product__media-model-el'
                        }}
                      </div>
                  {%- endcase -%}
                </div>
              {%- endfor -%}

              {%- if product.media.size == 0 -%}
                <div class="product__media-placeholder">
                  {{ 'product-1' | placeholder_svg_tag: 'product__media-placeholder-svg' }}
                </div>
              {%- endif -%}
            </div>

          {%- else -%}
            {%- comment -%} Thumbnail layouts: main image + thumbnails {%- endcomment -%}
            <div class="product__media-main" data-main-media>
              {%- for media in product.media -%}
                <div
                  class="product__media-slide{% if forloop.first %} is-active{% endif %}"
                  data-media-id="{{ media.id }}"
                  data-media-type="{{ media.media_type }}"
                  data-index="{{ forloop.index0 }}"
                  {% unless forloop.first %}hidden{% endunless %}
                >
                  {%- case media.media_type -%}
                    {%- when 'image' -%}
                      <div class="product__media-image{% if enable_zoom %} product__media-image--zoomable{% endif %}">
                        {{ media | image_url: width: 1400 | image_tag:
                          loading: 'lazy',
                          fetchpriority: 'auto',
                          widths: '400,600,800,1000,1200,1400',
                          sizes: '(min-width: 990px) calc(var(--product-media-width, 55%) * (var(--page-width, 1440px) - 40px) / 100), calc(100vw - 40px)',
                          class: 'product__media-img',
                          alt: media.alt | default: product.title
                        }}
                      </div>
                    {%- when 'video' -%}
                      <div class="product__media-video">
                        {{ media | media_tag:
                          autoplay: false,
                          loop: enable_video_loop,
                          controls: true,
                          muted: false,
                          class: 'product__media-video-el'
                        }}
                      </div>
                    {%- when 'external_video' -%}
                      <div class="product__media-video">
                        {{ media | external_video_url: autoplay: false, loop: enable_video_loop | external_video_tag:
                          class: 'product__media-iframe',
                          loading: 'lazy'
                        }}
                      </div>
                    {%- when 'model' -%}
                      <div class="product__media-model">
                        {{ media | model_viewer_tag:
                          reveal: 'interaction',
                          toggleable: true,
                          class: 'product__media-model-el'
                        }}
                      </div>
                  {%- endcase -%}
                </div>
              {%- endfor -%}

              {%- if product.media.size == 0 -%}
                <div class="product__media-placeholder">
                  {{ 'product-1' | placeholder_svg_tag: 'product__media-placeholder-svg' }}
                </div>
              {%- endif -%}
            </div>

            {%- if product.media.size > 1 -%}
              <div class="product__thumbnails product__thumbnails--{{ thumbnail_position }}" data-thumbnails>
                {%- for media in product.media -%}
                  <button
                    class="product__thumbnail{% if forloop.first %} is-active{% endif %}"
                    data-thumbnail
                    data-media-id="{{ media.id }}"
                    data-index="{{ forloop.index0 }}"
                    aria-label="{{ 'product.media_label' | t: index: forloop.index }}"
                    type="button"
                  >
                    {%- if media.media_type == 'image' -%}
                      {{ media.preview_image | image_url: width: 200 | image_tag:
                        loading: 'lazy',
                        widths: '80,120,160,200',
                        class: 'product__thumbnail-img',
                        alt: media.alt | default: product.title
                      }}
                    {%- else -%}
                      <div class="product__thumbnail-icon">
                        {%- if media.media_type == 'video' or media.media_type == 'external_video' -%}
                          {%- render 'icon', name: 'play', size: 16 -%}
                        {%- elsif media.media_type == 'model' -%}
                          {%- render 'icon', name: '3d', size: 16 -%}
                        {%- endif -%}
                      </div>
                    {%- endif -%}
                  </button>
                {%- endfor -%}
              </div>
            {%- endif -%}
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} ===== INFO COLUMN ===== {%- endcomment -%}
      <div class="product__info-column{% if sticky_info %} product__info--sticky{% endif %}">
        <div class="product__info" data-product-info>

          {%- for block in section.blocks -%}
            {%- case block.type -%}

              {%- comment -%} === VENDOR === {%- endcomment -%}
              {%- when 'vendor' -%}
                {%- if product.vendor != blank -%}
                  <p class="product__vendor label" {{ block.shopify_attributes }}>
                    <a href="{{ product.vendor | url_for_vendor }}">{{ product.vendor }}</a>
                  </p>
                {%- endif -%}

              {%- comment -%} === TITLE === {%- endcomment -%}
              {%- when 'title' -%}
                <{{ block.settings.heading_size }} class="product__title" {{ block.shopify_attributes }}>
                  {{ product.title }}
                </{{ block.settings.heading_size }}>

              {%- comment -%} === PRICE === {%- endcomment -%}
              {%- when 'price' -%}
                <div class="product__price" data-product-price {{ block.shopify_attributes }}>
                  {%- render 'price', product: product, show_badges: true -%}
                  {%- if block.settings.show_tax_notice -%}
                    {%- if cart.taxes_included -%}
                      <p class="product__tax-notice">{{ 'product.tax_included' | t }}</p>
                    {%- endif -%}
                    {%- if shop.shipping_policy.body != blank -%}
                      <p class="product__tax-notice">
                        <a href="{{ shop.shipping_policy.url }}">{{ 'product.shipping_calculated' | t }}</a>
                      </p>
                    {%- endif -%}
                  {%- endif -%}
                </div>

              {%- comment -%} === BADGES === {%- endcomment -%}
              {%- when 'badges' -%}
                {%- liquid
                  assign on_sale = false
                  if current_variant.compare_at_price > current_variant.price
                    assign on_sale = true
                  endif
                  assign sold_out = true
                  if current_variant.available
                    assign sold_out = false
                  endif
                -%}
                {%- if on_sale or sold_out -%}
                  <div class="product__badges" data-product-badges {{ block.shopify_attributes }}>
                    {%- if on_sale -%}
                      <span class="product__badge product__badge--sale">{{ 'product.sale' | t }}</span>
                    {%- endif -%}
                    {%- if sold_out -%}
                      <span class="product__badge product__badge--sold-out">{{ 'product.sold_out' | t }}</span>
                    {%- endif -%}
                  </div>
                {%- endif -%}

              {%- comment -%} === RATING === {%- endcomment -%}
              {%- when 'rating' -%}
                {%- if product.metafields.reviews.rating.value != blank -%}
                  {%- liquid
                    assign rating_value = product.metafields.reviews.rating.value.rating
                    assign rating_count = product.metafields.reviews.rating_count.value | default: 0
                    assign rating_whole = rating_value | floor
                    assign rating_decimal = rating_value | modulo: 1 | times: 100 | round
                    assign rating_partial_index = rating_whole | plus: 1
                  -%}
                  <div class="product__rating" role="img" aria-label="{{ 'product.rating_label' | t: rating: rating_value, max: 5 }}" {{ block.shopify_attributes }}>
                    <span class="product__stars" aria-hidden="true">
                      {%- for i in (1..5) -%}
                        {%- if i <= rating_whole -%}
                          <span class="product__star product__star--full">&#9733;</span>
                        {%- elsif i == rating_partial_index and rating_decimal > 0 -%}
                          <span class="product__star product__star--partial" style="--fill: {{ rating_decimal }}%;">&#9733;</span>
                        {%- else -%}
                          <span class="product__star product__star--empty">&#9733;</span>
                        {%- endif -%}
                      {%- endfor -%}
                    </span>
                    {%- if rating_count > 0 -%}
                      <span class="product__rating-count">({{ rating_count }})</span>
                    {%- endif -%}
                  </div>
                {%- endif -%}

              {%- comment -%} === VARIANT PICKER === {%- endcomment -%}
              {%- when 'variant_picker' -%}
                {%- liquid
                  assign size_chart_page = blank
                  if block.settings.size_chart_page != blank
                    assign size_chart_page = pages[block.settings.size_chart_page]
                  endif
                -%}
                {%- render 'product-variant-picker',
                  product: product,
                  picker_type: block.settings.picker_type,
                  swatch_shape: block.settings.swatch_shape,
                  size_chart_page: size_chart_page,
                  block: block
                -%}

              {%- comment -%} === QUANTITY SELECTOR === {%- endcomment -%}
              {%- when 'quantity_selector' -%}
                <div class="product__quantity" {{ block.shopify_attributes }}>
                  <label for="Quantity-{{ section.id }}" class="product__quantity-label label">
                    {{ 'product.quantity' | t }}
                  </label>
                  <div class="product__quantity-input">
                    <button type="button" class="product__quantity-btn" data-quantity-minus aria-label="{{ 'accessibility.decrease_quantity' | t }}">
                      {%- render 'icon', name: 'minus', size: 14 -%}
                    </button>
                    <input
                      type="number"
                      id="Quantity-{{ section.id }}"
                      name="quantity"
                      value="1"
                      min="1"
                      class="product__quantity-value"
                      data-quantity-input
                      aria-label="{{ 'product.quantity' | t }}"
                    >
                    <button type="button" class="product__quantity-btn" data-quantity-plus aria-label="{{ 'accessibility.increase_quantity' | t }}">
                      {%- render 'icon', name: 'plus', size: 14 -%}
                    </button>
                  </div>
                </div>

              {%- comment -%} === BUY BUTTONS === {%- endcomment -%}
              {%- when 'buy_buttons' -%}
                <div class="product__buy-buttons" {{ block.shopify_attributes }}>
                  {%- form 'product', product, id: 'ProductForm-{{ section.id }}', data-product-form: '' -%}
                    <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id>

                    <button
                      type="submit"
                      class="btn btn--primary btn--full product__add-to-cart"
                      {% unless current_variant.available %}disabled{% endunless %}
                      data-add-to-cart
                    >
                      <span class="btn__label" data-add-to-cart-text>
                        {%- if current_variant.available -%}
                          {{ 'product.add_to_cart' | t }}
                        {%- else -%}
                          {{ 'product.sold_out' | t }}
                        {%- endif -%}
                      </span>
                      <span class="btn__fill" aria-hidden="true"></span>
                    </button>

                    {%- if block.settings.show_dynamic_checkout -%}
                      <div class="product__dynamic-checkout">
                        {{ form | payment_button }}
                      </div>
                    {%- endif -%}
                  {%- endform -%}
                </div>

              {%- comment -%} === DESCRIPTION === {%- endcomment -%}
              {%- when 'description' -%}
                {%- if product.description != blank -%}
                  {%- if block.settings.collapsible -%}
                    <details class="product__collapsible" {{ block.shopify_attributes }}{% if block.settings.default_open %} open{% endif %}>
                      <summary class="product__collapsible-trigger">
                        <span>{{ 'product.description' | t }}</span>
                        {%- render 'icon', name: 'chevron-down', size: 16 -%}
                      </summary>
                      <div class="product__collapsible-content rte">
                        {{ product.description }}
                      </div>
                    </details>
                  {%- else -%}
                    <div class="product__description rte" {{ block.shopify_attributes }}>
                      {{ product.description }}
                    </div>
                  {%- endif -%}
                {%- endif -%}

              {%- comment -%} === COLLAPSIBLE TAB === {%- endcomment -%}
              {%- when 'collapsible_tab' -%}
                {%- liquid
                  assign tab_content = block.settings.content
                  if block.settings.page != blank
                    assign tab_content = pages[block.settings.page].content
                  endif
                -%}
                {%- if block.settings.heading != blank -%}
                  <details class="product__collapsible" {{ block.shopify_attributes }}>
                    <summary class="product__collapsible-trigger">
                      {%- if block.settings.icon != 'none' and block.settings.icon != blank -%}
                        <span class="product__collapsible-icon">
                          {%- render 'icon', name: block.settings.icon, size: 18 -%}
                        </span>
                      {%- endif -%}
                      <span>{{ block.settings.heading }}</span>
                      {%- render 'icon', name: 'chevron-down', size: 16 -%}
                    </summary>
                    <div class="product__collapsible-content rte">
                      {{ tab_content }}
                    </div>
                  </details>
                {%- endif -%}

              {%- comment -%} === SKU === {%- endcomment -%}
              {%- when 'sku' -%}
                {%- if current_variant.sku != blank -%}
                  <p class="product__sku" data-product-sku {{ block.shopify_attributes }}>
                    <span class="product__sku-label label">{{ 'product.sku' | t }}:</span>
                    <span data-sku-value>{{ current_variant.sku }}</span>
                  </p>
                {%- endif -%}

              {%- comment -%} === PAYMENT TERMS (Shop Pay Installments) === {%- endcomment -%}
              {%- when 'payment_terms' -%}
                <div class="product__payment-terms" {{ block.shopify_attributes }}>
                  {%- form 'product', product, id: 'ProductPaymentTerms' -%}
                    <input type="hidden" name="id" value="{{ current_variant.id }}">
                    {{ form | payment_terms }}
                  {%- endform -%}
                </div>

              {%- comment -%} === SHARE === {%- endcomment -%}
              {%- when 'share' -%}
                <div class="product__share" {{ block.shopify_attributes }}>
                  <button type="button" class="product__share-btn btn--link" data-share-button aria-label="{{ 'product.share' | t }}">
                    {%- render 'icon', name: 'share', size: 18 -%}
                    <span>{{ 'product.share' | t }}</span>
                  </button>
                  <p class="product__share-success visually-hidden" data-share-success role="status">
                    {{ 'product.link_copied' | t }}
                  </p>
                </div>

              {%- comment -%} === PICKUP AVAILABILITY === {%- endcomment -%}
              {%- when 'pickup_availability' -%}
                {%- if current_variant.store_availabilities.size > 0 -%}
                  <div class="product__pickup" data-pickup-availability {{ block.shopify_attributes }}>
                    {%- for availability in current_variant.store_availabilities -%}
                      {%- if availability.available -%}
                        <div class="product__pickup-item">
                          {%- render 'icon', name: 'checkmark', size: 16 -%}
                          <div>
                            <p class="product__pickup-location">{{ availability.location.name }}</p>
                            <p class="product__pickup-status">{{ 'product.pickup_available' | t }}</p>
                          </div>
                        </div>
                        {%- break -%}
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                {%- endif -%}

              {%- comment -%} === TRUST INDICATORS (innovative) === {%- endcomment -%}
              {%- when 'trust_indicators' -%}
                <div class="product__trust" {{ block.shopify_attributes }}>
                  {%- for i in (1..4) -%}
                    {%- liquid
                      assign text_key = 'text_' | append: i
                      assign icon_key = 'icon_' | append: i
                      assign trust_text = block.settings[text_key]
                      assign trust_icon = block.settings[icon_key]
                    -%}
                    {%- if trust_text != blank -%}
                      <div class="product__trust-item">
                        {%- if trust_icon != 'none' and trust_icon != blank -%}
                          {%- render 'icon', name: trust_icon, size: 18 -%}
                        {%- endif -%}
                        <span>{{ trust_text }}</span>
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>

              {%- comment -%} === PRODUCT HIGHLIGHTS (innovative) === {%- endcomment -%}
              {%- when 'product_highlights' -%}
                {%- liquid
                  assign highlights_source = block.settings.source
                  assign manual_highlights = block.settings.highlights
                  assign metafield_key = block.settings.metafield_key
                -%}
                <div class="product__highlights" {{ block.shopify_attributes }}>
                  {%- if block.settings.heading != blank -%}
                    <h3 class="product__highlights-heading label">{{ block.settings.heading }}</h3>
                  {%- endif -%}
                  <ul class="product__highlights-list">
                    {%- if highlights_source == 'metafield' and product.metafields.custom[metafield_key] != blank -%}
                      {%- assign items = product.metafields.custom[metafield_key].value -%}
                      {%- for item in items -%}
                        <li class="product__highlights-item">
                          {%- if block.settings.icon != 'none' -%}
                            {%- render 'icon', name: block.settings.icon, size: 14 -%}
                          {%- endif -%}
                          <span>{{ item }}</span>
                        </li>
                      {%- endfor -%}
                    {%- else -%}
                      {%- assign lines = manual_highlights | split: ',' -%}
                      {%- for line in lines -%}
                        {%- assign trimmed = line | strip -%}
                        {%- if trimmed != blank -%}
                          <li class="product__highlights-item">
                            {%- if block.settings.icon != 'none' -%}
                              {%- render 'icon', name: block.settings.icon, size: 14 -%}
                            {%- endif -%}
                            <span>{{ trimmed }}</span>
                          </li>
                        {%- endif -%}
                      {%- endfor -%}
                    {%- endif -%}
                  </ul>
                </div>

              {%- comment -%} === COMPLEMENTARY PRODUCTS (innovative) === {%- endcomment -%}
              {%- when 'complementary_products' -%}
                <div class="product__complementary" {{ block.shopify_attributes }}>
                  {%- if block.settings.heading != blank -%}
                    <h3 class="product__complementary-heading label">{{ block.settings.heading }}</h3>
                  {%- endif -%}
                  <div class="product__complementary-grid">
                    {%- if block.settings.collection != blank -%}
                      {%- for comp_product in collections[block.settings.collection].products limit: block.settings.limit -%}
                        {%- if comp_product.id != product.id -%}
                          <a href="{{ comp_product.url }}" class="product__complementary-item">
                            {%- if comp_product.featured_image != blank -%}
                              {{ comp_product.featured_image | image_url: width: 200 | image_tag:
                                loading: 'lazy',
                                widths: '100,150,200',
                                class: 'product__complementary-img',
                                alt: comp_product.title
                              }}
                            {%- endif -%}
                            <div class="product__complementary-info">
                              <p class="product__complementary-title">{{ comp_product.title }}</p>
                              <p class="product__complementary-price">{{ comp_product.price | money }}</p>
                            </div>
                          </a>
                        {%- endif -%}
                      {%- endfor -%}
                    {%- endif -%}
                  </div>
                </div>

              {%- comment -%} === CUSTOM LIQUID === {%- endcomment -%}
              {%- comment -%} === BEFORE/AFTER SLIDER (innovative) === {%- endcomment -%}
              {%- when 'before_after' -%}
                {%- if block.settings.image_before != blank and block.settings.image_after != blank -%}
                  <div class="product__before-after" {{ block.shopify_attributes }}>
                    {%- if block.settings.heading != blank -%}
                      <h3 class="product__before-after-heading label">{{ block.settings.heading }}</h3>
                    {%- endif -%}
                    <before-after-slider class="before-after" style="--position: 50%;">
                      <div class="before-after__container">
                        <div class="before-after__image before-after__image--before">
                          {{ block.settings.image_before | image_url: width: 800 | image_tag:
                            loading: 'lazy',
                            widths: '400,600,800',
                            class: 'before-after__img',
                            alt: block.settings.label_before | default: 'Before'
                          }}
                          <span class="before-after__label before-after__label--before">{{ block.settings.label_before | default: 'Before' }}</span>
                        </div>
                        <div class="before-after__image before-after__image--after" style="clip-path: inset(0 0 0 var(--position));">
                          {{ block.settings.image_after | image_url: width: 800 | image_tag:
                            loading: 'lazy',
                            widths: '400,600,800',
                            class: 'before-after__img',
                            alt: block.settings.label_after | default: 'After'
                          }}
                          <span class="before-after__label before-after__label--after">{{ block.settings.label_after | default: 'After' }}</span>
                        </div>
                        <div class="before-after__handle" aria-label="Drag to compare" role="slider" aria-valuenow="50" aria-valuemin="0" aria-valuemax="100" tabindex="0">
                          <div class="before-after__handle-line"></div>
                          <div class="before-after__handle-circle">
                            {%- render 'icon', name: 'chevron-left', size: 12 -%}
                            {%- render 'icon', name: 'chevron-right', size: 12 -%}
                          </div>
                          <div class="before-after__handle-line"></div>
                        </div>
                      </div>
                    </before-after-slider>
                  </div>
                {%- endif -%}

              {%- comment -%} === INGREDIENT LIST (innovative) === {%- endcomment -%}
              {%- when 'ingredient_list' -%}
                <div class="product__ingredients" {{ block.shopify_attributes }}>
                  {%- if block.settings.heading != blank -%}
                    <details class="product__collapsible"{% if block.settings.default_open %} open{% endif %}>
                      <summary class="product__collapsible-trigger">
                        {%- if block.settings.icon != 'none' -%}
                          <span class="product__collapsible-icon">
                            {%- render 'icon', name: block.settings.icon, size: 18 -%}
                          </span>
                        {%- endif -%}
                        <span>{{ block.settings.heading }}</span>
                        {%- render 'icon', name: 'chevron-down', size: 16 -%}
                      </summary>
                      <div class="product__collapsible-content">
                        <ul class="product__ingredients-list">
                          {%- assign items = block.settings.ingredients | split: '|' -%}
                          {%- for item in items -%}
                            {%- assign parts = item | split: ':' -%}
                            {%- assign name = parts[0] | strip -%}
                            {%- assign desc = parts[1] | strip | default: '' -%}
                            {%- if name != blank -%}
                              <li class="product__ingredients-item">
                                <span class="product__ingredients-name">{{ name }}</span>
                                {%- if desc != blank -%}
                                  <span class="product__ingredients-desc">{{ desc }}</span>
                                {%- endif -%}
                              </li>
                            {%- endif -%}
                          {%- endfor -%}
                        </ul>
                      </div>
                    </details>
                  {%- endif -%}
                </div>

              {%- when 'custom_liquid' -%}
                {%- if block.settings.liquid != blank -%}
                  <div class="product__custom-liquid" {{ block.shopify_attributes }}>
                    {{ block.settings.liquid }}
                  </div>
                {%- endif -%}

              {%- comment -%} === APP BLOCK === {%- endcomment -%}
              {%- when '@app' -%}
                <div class="product__app-block" {{ block.shopify_attributes }}>
                  {% render block %}
                </div>

            {%- endcase -%}
          {%- endfor -%}
        </div>
      </div>

    </div>
  </div>

  {%- comment -%} Sticky Add-to-Cart Bar {%- endcomment -%}
  {%- if section.settings.show_sticky_atc -%}
    <div class="product__sticky-atc" data-sticky-atc hidden>
      <div class="container">
        <div class="product__sticky-atc-inner">
          <div class="product__sticky-atc-info">
            {%- if product.featured_image != blank -%}
              {{ product.featured_image | image_url: width: 80 | image_tag:
                loading: 'lazy',
                widths: '40,60,80',
                class: 'product__sticky-atc-img',
                alt: product.title
              }}
            {%- endif -%}
            <div>
              <p class="product__sticky-atc-title">{{ product.title | truncate: 40 }}</p>
              <p class="product__sticky-atc-price" data-sticky-price>{{ current_variant.price | money }}</p>
            </div>
          </div>
          <button
            type="button"
            class="btn btn--primary product__sticky-atc-btn"
            data-sticky-atc-button
            {% unless current_variant.available %}disabled{% endunless %}
          >
            <span class="btn__label">
              {%- if current_variant.available -%}
                {{ 'product.add_to_cart' | t }}
              {%- else -%}
                {{ 'product.sold_out' | t }}
              {%- endif -%}
            </span>
            <span class="btn__fill" aria-hidden="true"></span>
          </button>
        </div>
      </div>
    </div>
  {%- endif -%}

  <script type="application/json" data-product-json>
    {{ product | json }}
  </script>

  {%- comment -%} JSON-LD Structured Data for SEO {%- endcomment -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Product",
      "name": {{ product.title | json }},
      "url": "{{ shop.url }}{{ product.url }}",
      "image": [
        {%- for image in product.images limit: 3 -%}
          {{ image | image_url: width: 1200 | json }}{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ],
      "description": {{ product.description | strip_html | truncate: 5000 | json }},
      {%- if product.vendor != blank -%}
        "brand": {
          "@type": "Brand",
          "name": {{ product.vendor | json }}
        },
      {%- endif -%}
      {%- if current_variant.sku != blank -%}
        "sku": {{ current_variant.sku | json }},
      {%- endif -%}
      "offers": {
        "@type": "Offer",
        "url": "{{ shop.url }}{{ product.url }}",
        "priceCurrency": {{ cart.currency.iso_code | json }},
        "price": {{ current_variant.price | divided_by: 100.0 | json }},
        "availability": "https://schema.org/{% if current_variant.available %}InStock{% else %}OutOfStock{% endif %}"
      }
    }
  </script>
</main-product>

<script src="{{ 'section-main-product.js' | asset_url }}" defer="defer"></script>

