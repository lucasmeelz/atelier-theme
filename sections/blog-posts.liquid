{%- comment -%}
  Blog Posts — Featured articles section for homepage/landing pages
  Supports: Grid layout with optional image, author, date
{%- endcomment -%}

{{ 'section-blog-posts.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign heading = section.settings.heading
  assign heading_size = section.settings.heading_size
  assign subheading = section.settings.subheading
  assign blog = section.settings.blog
  assign posts_to_show = section.settings.posts_to_show
  assign columns_desktop = section.settings.columns_desktop
  assign show_image = section.settings.show_image
  assign image_ratio = section.settings.image_ratio
  assign show_author = section.settings.show_author
  assign show_date = section.settings.show_date
  assign show_excerpt = section.settings.show_excerpt
  assign button_label = section.settings.button_label
  assign color_scheme = section.settings.color_scheme
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
-%}

{%- style -%}
  #Section-{{ section.id }} {
    --section-padding-top: {{ padding_top }}px;
    --section-padding-bottom: {{ padding_bottom }}px;
    --blog-posts-columns: {{ columns_desktop }};
  }
{%- endstyle -%}

<div
  id="Section-{{ section.id }}"
  class="blog-posts color-{{ color_scheme }}"
>
  <div class="container">
    {%- if heading != blank or subheading != blank -%}
      <div class="blog-posts__header">
        {%- if subheading != blank -%}
          <p class="blog-posts__subheading label">{{ subheading }}</p>
        {%- endif -%}
        {%- if heading != blank -%}
          <div class="blog-posts__heading-row">
            <{{ heading_size }} class="blog-posts__heading">{{ heading }}</{{ heading_size }}>
            {%- if button_label != blank and blog != blank -%}
              <a href="{{ blog.url }}" class="blog-posts__view-all link-underline">{{ button_label }}</a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="blog-posts__grid"{% if settings.stagger_blog_posts %} data-stagger-cards{% endif %}>
      {%- if blog != blank -%}
        {%- for article in blog.articles limit: posts_to_show -%}
          <article class="blog-posts__card">
            {%- if show_image and article.image -%}
              <a href="{{ article.url }}" class="blog-posts__card-media" tabindex="-1" aria-hidden="true">
                <div class="blog-posts__card-image-wrapper blog-posts__card-image-wrapper--{{ image_ratio }}">
                  {{ article.image | image_url: width: 800 | image_tag:
                    loading: 'lazy',
                    widths: '300,400,600,800',
                    sizes: '(min-width: 990px) calc(100vw / var(--blog-posts-columns, 3)), (min-width: 750px) 50vw, 100vw',
                    class: 'blog-posts__card-image'
                  }}
                </div>
              </a>
            {%- endif -%}

            <div class="blog-posts__card-content">
              {%- if show_date or show_author -%}
                <div class="blog-posts__card-meta">
                  {%- if show_date -%}
                    <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
                      {{ article.published_at | date: format: 'abbreviated_date' }}
                    </time>
                  {%- endif -%}
                  {%- if show_author and article.author != blank -%}
                    {%- if show_date -%}<span class="blog-posts__card-meta-sep">·</span>{%- endif -%}
                    <span>{{ article.author }}</span>
                  {%- endif -%}
                </div>
              {%- endif -%}

              <h3 class="blog-posts__card-title">
                <a href="{{ article.url }}">{{ article.title }}</a>
              </h3>

              {%- if show_excerpt and article.excerpt_or_content != blank -%}
                <p class="blog-posts__card-excerpt">
                  {{ article.excerpt_or_content | strip_html | truncatewords: 20 }}
                </p>
              {%- endif -%}

              <a href="{{ article.url }}" class="blog-posts__card-link link-underline">
                {{ 'blog.read_more' | t }}
              </a>
            </div>
          </article>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..posts_to_show) -%}
          <article class="blog-posts__card">
            {%- if show_image -%}
              <div class="blog-posts__card-media">
                <div class="blog-posts__card-image-wrapper blog-posts__card-image-wrapper--{{ image_ratio }}">
                  {{ 'image' | placeholder_svg_tag: 'blog-posts__card-placeholder' }}
                </div>
              </div>
            {%- endif -%}
            <div class="blog-posts__card-content">
              {%- if show_date -%}
                <div class="blog-posts__card-meta">
                  <time>{{ 'now' | date: format: 'abbreviated_date' }}</time>
                </div>
              {%- endif -%}
              <h3 class="blog-posts__card-title">
                <a href="#">{{ 'blog.example_title' | t }}</a>
              </h3>
              {%- if show_excerpt -%}
                <p class="blog-posts__card-excerpt">{{ 'blog.example_excerpt' | t }}</p>
              {%- endif -%}
            </div>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if button_label != blank and blog != blank and heading == blank -%}
      <div class="blog-posts__footer">
        <a href="{{ blog.url }}" class="btn btn--outline">{{ button_label }}</a>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.blog_posts.name",
  "tag": "section",
  "class": "section-blog-posts",
  "disabled_on": {
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    { "type": "header", "content": "t:sections.blog_posts.content_header" },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.blog_posts.subheading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.blog_posts.heading",
      "default": "From the journal"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.blog_posts.heading_size",
      "options": [
        { "value": "h2", "label": "t:sections.blog_posts.heading_large" },
        { "value": "h3", "label": "t:sections.blog_posts.heading_medium" }
      ],
      "default": "h2"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "t:sections.blog_posts.blog"
    },
    {
      "type": "range",
      "id": "posts_to_show",
      "label": "t:sections.blog_posts.posts_to_show",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "t:sections.blog_posts.columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    { "type": "header", "content": "t:sections.blog_posts.card_header" },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "t:sections.blog_posts.show_image",
      "default": true
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "t:sections.blog_posts.image_ratio",
      "options": [
        { "value": "landscape", "label": "t:sections.blog_posts.landscape" },
        { "value": "portrait", "label": "t:sections.blog_posts.portrait" },
        { "value": "square", "label": "t:sections.blog_posts.square" }
      ],
      "default": "landscape"
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "t:sections.blog_posts.show_date",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "t:sections.blog_posts.show_author",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "t:sections.blog_posts.show_excerpt",
      "default": true
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.blog_posts.button_label",
      "default": "View all"
    },
    { "type": "header", "content": "t:sections.blog_posts.style_header" },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.blog_posts.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.blog_posts.padding_top",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.blog_posts.padding_bottom",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "t:sections.blog_posts.preset_name"
    }
  ]
}
{% endschema %}
