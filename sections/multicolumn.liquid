{%- comment -%}
  Multicolumn — Flexible column grid with icon/image + text blocks
  Supports: 2-5 columns desktop, 1-2 mobile, image sizes, circle/square shapes,
  column alignment, internal borders
{%- endcomment -%}

{{ 'section-multicolumn.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign heading = section.settings.heading
  assign heading_size = section.settings.heading_size
  assign subheading = section.settings.subheading
  assign columns_desktop = section.settings.columns_desktop
  assign columns_mobile = section.settings.columns_mobile
  assign image_width = section.settings.image_width
  assign image_ratio = section.settings.image_ratio
  assign column_alignment = section.settings.column_alignment
  assign show_borders = section.settings.show_borders
  assign color_scheme = section.settings.color_scheme
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
-%}

{%- style -%}
  #Section-{{ section.id }} {
    --section-padding-top: {{ padding_top }}px;
    --section-padding-bottom: {{ padding_bottom }}px;
    --mc-columns-desktop: {{ columns_desktop }};
    --mc-columns-mobile: {{ columns_mobile }};
  }
{%- endstyle -%}

<div
  id="Section-{{ section.id }}"
  class="multicolumn color-{{ color_scheme }} full-width"
>
  <div class="container">
    {%- if heading != blank or subheading != blank -%}
      <div class="multicolumn__header multicolumn__header--{{ column_alignment }}">
        {%- if subheading != blank -%}
          <p class="multicolumn__subheading label">{{ subheading }}</p>
        {%- endif -%}
        {%- if heading != blank -%}
          <{{ heading_size }} class="multicolumn__heading">{{ heading }}</{{ heading_size }}>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="multicolumn__grid{% if show_borders %} multicolumn__grid--borders{% endif %}">
      {%- for block in section.blocks -%}
        <div class="multicolumn__item multicolumn__item--{{ column_alignment }}" data-stagger {{ block.shopify_attributes }}>

          {%- if block.settings.image != blank -%}
            <div class="multicolumn__image multicolumn__image--{{ image_width }} multicolumn__image--{{ image_ratio }}">
              {{ block.settings.image | image_url: width: 600 | image_tag:
                loading: 'lazy',
                widths: '200,300,400,600',
                sizes: '(min-width: 990px) calc(100vw / ' | append: columns_desktop | append: '), calc(100vw / ' | append: columns_mobile | append: ')',
                class: 'multicolumn__img',
                alt: block.settings.image.alt | default: block.settings.heading | escape
              }}
            </div>
          {%- elsif block.settings.icon != 'none' and block.settings.icon != blank -%}
            <div class="multicolumn__icon multicolumn__icon--{{ image_width }}">
              {%- render 'icon', name: block.settings.icon, size: 48 -%}
            </div>
          {%- endif -%}

          {%- if block.settings.heading != blank -%}
            <h3 class="multicolumn__title">{{ block.settings.heading }}</h3>
          {%- endif -%}

          {%- if block.settings.text != blank -%}
            <div class="multicolumn__text rte">{{ block.settings.text }}</div>
          {%- endif -%}

          {%- if block.settings.link_label != blank -%}
            <a href="{{ block.settings.link | default: '#' }}" class="multicolumn__link link-underline">
              {{ block.settings.link_label }}
            </a>
          {%- endif -%}

        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.multicolumn.name",
  "tag": "section",
  "class": "section-multicolumn",
  "max_blocks": 12,
  "disabled_on": {
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.multicolumn.content_header"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.multicolumn.subheading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.multicolumn.heading",
      "default": "Multicolumn"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.multicolumn.heading_size",
      "options": [
        { "value": "h2", "label": "t:sections.multicolumn.heading_large" },
        { "value": "h3", "label": "t:sections.multicolumn.heading_medium" }
      ],
      "default": "h2"
    },
    {
      "type": "header",
      "content": "t:sections.multicolumn.layout_header"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "t:sections.multicolumn.columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "t:sections.multicolumn.columns_mobile",
      "options": [
        { "value": "1", "label": "t:sections.multicolumn.columns_1" },
        { "value": "2", "label": "t:sections.multicolumn.columns_2" }
      ],
      "default": "1"
    },
    {
      "type": "select",
      "id": "column_alignment",
      "label": "t:sections.multicolumn.column_alignment",
      "options": [
        { "value": "left", "label": "t:sections.multicolumn.align_left" },
        { "value": "center", "label": "t:sections.multicolumn.align_center" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "t:sections.multicolumn.image_header"
    },
    {
      "type": "select",
      "id": "image_width",
      "label": "t:sections.multicolumn.image_width",
      "options": [
        { "value": "small", "label": "t:sections.multicolumn.width_small" },
        { "value": "medium", "label": "t:sections.multicolumn.width_medium" },
        { "value": "large", "label": "t:sections.multicolumn.width_large" },
        { "value": "full", "label": "t:sections.multicolumn.width_full" }
      ],
      "default": "full"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "t:sections.multicolumn.image_ratio",
      "options": [
        { "value": "adapt", "label": "t:sections.multicolumn.ratio_adapt" },
        { "value": "circle", "label": "t:sections.multicolumn.ratio_circle" },
        { "value": "square", "label": "t:sections.multicolumn.ratio_square" },
        { "value": "portrait", "label": "t:sections.multicolumn.ratio_portrait" }
      ],
      "default": "adapt"
    },
    {
      "type": "header",
      "content": "t:sections.multicolumn.style_header"
    },
    {
      "type": "checkbox",
      "id": "show_borders",
      "label": "t:sections.multicolumn.show_borders",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.multicolumn.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.multicolumn.padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.multicolumn.padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "t:sections.multicolumn.blocks.column",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.multicolumn.blocks.image"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "t:sections.multicolumn.blocks.icon",
          "info": "t:sections.multicolumn.blocks.icon_info",
          "options": [
            { "value": "none", "label": "t:sections.multicolumn.blocks.icon_none" },
            { "value": "checkmark", "label": "t:sections.multicolumn.blocks.icon_checkmark" },
            { "value": "star", "label": "t:sections.multicolumn.blocks.icon_star" },
            { "value": "heart", "label": "t:sections.multicolumn.blocks.icon_heart" },
            { "value": "shipping", "label": "t:sections.multicolumn.blocks.icon_shipping" },
            { "value": "return", "label": "t:sections.multicolumn.blocks.icon_return" },
            { "value": "lock", "label": "t:sections.multicolumn.blocks.icon_lock" },
            { "value": "leaf", "label": "t:sections.multicolumn.blocks.icon_leaf" },
            { "value": "gift", "label": "t:sections.multicolumn.blocks.icon_gift" }
          ],
          "default": "none"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.multicolumn.blocks.heading",
          "default": "Column heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "t:sections.multicolumn.blocks.text",
          "default": "<p>Pair text with an image to focus on your chosen product, collection, or blog post.</p>"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "t:sections.multicolumn.blocks.link_label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.multicolumn.blocks.link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.multicolumn.preset_name",
      "blocks": [
        { "type": "column" },
        { "type": "column" },
        { "type": "column" }
      ]
    }
  ]
}
{% endschema %}
