{%- comment -%}
  List Collections — Grid of collection cards with image, title, and count
  Used in list-collections.json template
{%- endcomment -%}

{%- liquid
  assign color_scheme = section.settings.color_scheme
  assign columns_desktop = section.settings.columns_desktop
  assign columns_mobile = section.settings.columns_mobile
  assign image_ratio = section.settings.image_ratio
  assign show_count = section.settings.show_count
  assign heading_size = section.settings.heading_size
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
-%}

{%- style -%}
  #Section-{{ section.id }} {
    --section-padding-top: {{ padding_top }}px;
    --section-padding-bottom: {{ padding_bottom }}px;
  }

  .list-collections-section {
    padding-top: var(--section-padding-top);
    padding-bottom: var(--section-padding-bottom);
  }

  .list-collections__title {
    margin: 0 0 40px;
    text-align: center;
  }

  .list-collections__grid {
    display: grid;
    grid-template-columns: repeat({{ columns_mobile }}, 1fr);
    gap: 16px 12px;
  }

  @media screen and (min-width: 750px) {
    .list-collections__grid {
      gap: 24px 20px;
    }
  }

  @media screen and (min-width: 990px) {
    .list-collections__grid {
      grid-template-columns: repeat({{ columns_desktop }}, 1fr);
      gap: 32px 24px;
    }
  }

  /* Collection card */
  .list-collections__card {
    position: relative;
    display: block;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    border-radius: var(--card-border-radius, 0);
  }

  .list-collections__card-media {
    position: relative;
    overflow: hidden;
    {%- case image_ratio -%}
      {%- when 'portrait' -%}
        aspect-ratio: 3 / 4;
      {%- when 'square' -%}
        aspect-ratio: 1 / 1;
      {%- when 'landscape' -%}
        aspect-ratio: 4 / 3;
      {%- when 'wide' -%}
        aspect-ratio: 16 / 9;
    {%- endcase -%}
    background-color: rgb(var(--color-background, 245, 244, 240));
  }

  .list-collections__card-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow, 600ms) var(--ease-ecrin, ease);
  }

  @media (hover: hover) {
    .list-collections__card:hover .list-collections__card-img {
      transform: scale(1.04);
    }
  }

  .list-collections__card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(var(--color-text, 0, 0, 0), 0.45) 0%, rgba(var(--color-text, 0, 0, 0), 0) 60%);
    pointer-events: none;
    transition: opacity var(--duration-base, 350ms) var(--ease-ecrin, ease);
  }

  .list-collections__card-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 20px;
    color: rgb(var(--color-button-text, 255, 255, 255));
    z-index: 1;
  }

  @media screen and (min-width: 990px) {
    .list-collections__card-content {
      padding: 28px;
    }
  }

  .list-collections__card-name {
    font-family: var(--font-heading-family, serif);
    font-weight: var(--font-heading-weight, 300);
    font-style: var(--font-heading-style, normal);
    line-height: var(--heading-line-height, 1.1);
    letter-spacing: var(--heading-letter-spacing, 0);
    text-transform: var(--heading-text-transform, none);
    margin: 0;
    font-size: clamp(1rem, 2vw, 1.5rem);
  }

  .list-collections__card-count {
    margin-top: 4px;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.8;
  }

  /* Placeholder */
  .list-collections__card-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    background-color: rgb(var(--color-background, 245, 244, 240));
  }

  .list-collections__card-placeholder svg {
    width: 48px;
    height: 48px;
    opacity: 0.25;
  }

  /* No-image variant — text below instead of overlay */
  .list-collections__card--no-image .list-collections__card-content {
    position: static;
    color: rgb(var(--color-text, 10, 10, 10));
    padding: 16px 0 0;
  }

  .list-collections__card--no-image .list-collections__card-count {
    color: rgb(var(--color-text-subdued, 107, 107, 107));
  }

  /* Empty state */
  .list-collections__empty {
    text-align: center;
    padding: 80px 0;
    color: rgb(var(--color-text-subdued, 107, 107, 107));
  }
{%- endstyle -%}

<section
  id="Section-{{ section.id }}"
  class="list-collections-section color-{{ color_scheme }} full-width"
>
  <div class="container">

    {%- if section.settings.heading != blank -%}
      <h1 class="list-collections__title {{ heading_size }}">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if collections.size > 0 -%}
      <div class="list-collections__grid">
        {%- for collection in collections -%}
          <a href="{{ collection.url }}" class="list-collections__card{% unless collection.featured_image %} list-collections__card--no-image{% endunless %}">
            <div class="list-collections__card-media">
              {%- if collection.featured_image -%}
                {{
                  collection.featured_image
                  | image_url: width: 800
                  | image_tag:
                    alt: collection.title,
                    class: 'list-collections__card-img',
                    loading: 'lazy',
                    widths: '400, 600, 800',
                    sizes: '(min-width: 990px) calc(100vw / ' | append: columns_desktop | append: '), (min-width: 750px) 50vw, ' | append: '100vw'
                }}
                <div class="list-collections__card-overlay" aria-hidden="true"></div>
              {%- else -%}
                <div class="list-collections__card-placeholder">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                    <circle cx="8.5" cy="8.5" r="1.5"></circle>
                    <polyline points="21 15 16 10 5 21"></polyline>
                  </svg>
                </div>
              {%- endif -%}
            </div>
            <div class="list-collections__card-content">
              <h2 class="list-collections__card-name">{{ collection.title }}</h2>
              {%- if show_count -%}
                <p class="list-collections__card-count">
                  {{ 'collection.product_count' | t: count: collection.products_count }}
                </p>
              {%- endif -%}
            </div>
          </a>
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="list-collections__empty">
        <p>{{ 'collections.title' | t }}</p>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "t:sections.list_collections.name",
  "tag": "section",
  "class": "section-list-collections",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.list_collections.heading",
      "default": "Collections"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.list_collections.heading_size",
      "options": [
        { "value": "h2", "label": "t:sections.list_collections.size_medium" },
        { "value": "h1", "label": "t:sections.list_collections.size_large" }
      ],
      "default": "h1"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "t:sections.list_collections.columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "t:sections.list_collections.columns_mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "1"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "t:sections.list_collections.image_ratio",
      "options": [
        { "value": "portrait", "label": "t:sections.list_collections.ratio_portrait" },
        { "value": "square", "label": "t:sections.list_collections.ratio_square" },
        { "value": "landscape", "label": "t:sections.list_collections.ratio_landscape" },
        { "value": "wide", "label": "t:sections.list_collections.ratio_wide" }
      ],
      "default": "portrait"
    },
    {
      "type": "checkbox",
      "id": "show_count",
      "label": "t:sections.list_collections.show_product_count",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.list_collections.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.list_collections.padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.list_collections.padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ]
}
{% endschema %}
