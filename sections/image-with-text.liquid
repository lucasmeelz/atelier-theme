{%- comment -%}
  Image with Text — Editorial split section
  50/50 or asymmetric image + text, reversible, with content blocks
{%- endcomment -%}

{{ 'section-image-with-text.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign image = section.settings.image
  assign image_ratio = section.settings.image_ratio
  assign layout = section.settings.layout
  assign image_width = section.settings.desktop_image_width
  assign vertical_alignment = section.settings.vertical_alignment
  assign label = section.settings.label
  assign heading = section.settings.heading
  assign heading_size = section.settings.heading_size
  assign text = section.settings.text
  assign button_label = section.settings.button_label
  assign button_link = section.settings.button_link
  assign button_style = section.settings.button_style
  assign color_scheme = section.settings.color_scheme
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom

  assign ratio_css = ''
  case image_ratio
    when 'portrait'
      assign ratio_css = '3 / 4'
    when 'square'
      assign ratio_css = '1 / 1'
    when 'landscape'
      assign ratio_css = '4 / 3'
  endcase

  assign width_pct = '50'
  case image_width
    when 'small'
      assign width_pct = '33'
    when 'medium'
      assign width_pct = '50'
    when 'large'
      assign width_pct = '60'
  endcase
-%}

{%- style -%}
  #Section-{{ section.id }} {
    --section-padding-top: {{ padding_top }}px;
    --section-padding-bottom: {{ padding_bottom }}px;
    --iwt-image-width: {{ width_pct }}%;
    --iwt-text-width: {{ 100 | minus: width_pct }}%;
  }
{%- endstyle -%}

<div
  id="Section-{{ section.id }}"
  class="image-with-text color-{{ color_scheme }}"
>
  <div class="container">
    <div class="image-with-text__grid image-with-text__grid--{{ layout }} image-with-text__grid--align-{{ vertical_alignment }}">

      {%- comment -%} Image column {%- endcomment -%}
      <div class="image-with-text__media">
        <div class="image-with-text__media-wrapper"{% if ratio_css != blank %} style="aspect-ratio: {{ ratio_css }};"{% endif %}>
          {%- if image != blank -%}
            {{ image | image_url: width: 1200 | image_tag:
              loading: 'lazy',
              widths: '375,550,750,1000,1200',
              sizes: '(min-width: 990px) ' | append: width_pct | append: 'vw, 100vw',
              class: 'image-with-text__img',
              alt: image.alt | default: heading | strip_html | escape
            }}
          {%- else -%}
            <div class="image-with-text__placeholder">
              {{ 'lifestyle-2' | placeholder_svg_tag: 'image-with-text__placeholder-svg' }}
            </div>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} Text column {%- endcomment -%}
      <div class="image-with-text__content">
        <div class="image-with-text__content-inner">
          {%- if label != blank -%}
            <p class="image-with-text__label label">{{ label }}</p>
          {%- endif -%}

          {%- if heading != blank -%}
            <{{ heading_size }} class="image-with-text__heading">{{ heading }}</{{ heading_size }}>
          {%- endif -%}

          {%- if text != blank -%}
            <div class="image-with-text__text rte">{{ text }}</div>
          {%- endif -%}

          {%- if button_label != blank -%}
            <div class="image-with-text__button">
              <a href="{{ button_link | default: '#' }}" class="btn btn--{{ button_style }}">
                <span class="btn__label">{{ button_label }}</span>
                <span class="btn__fill" aria-hidden="true"></span>
              </a>
            </div>
          {%- endif -%}
        </div>
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.image_with_text.name",
  "tag": "section",
  "class": "section-image-with-text",
  "disabled_on": {
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.image_with_text.image_header"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.image_with_text.image"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "t:sections.image_with_text.image_ratio",
      "options": [
        { "value": "adapt", "label": "t:sections.image_with_text.ratio_adapt" },
        { "value": "portrait", "label": "t:sections.image_with_text.ratio_portrait" },
        { "value": "square", "label": "t:sections.image_with_text.ratio_square" },
        { "value": "landscape", "label": "t:sections.image_with_text.ratio_landscape" }
      ],
      "default": "adapt"
    },
    {
      "type": "header",
      "content": "t:sections.image_with_text.layout_header"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "t:sections.image_with_text.layout",
      "options": [
        { "value": "image_first", "label": "t:sections.image_with_text.image_first" },
        { "value": "text_first", "label": "t:sections.image_with_text.text_first" }
      ],
      "default": "image_first"
    },
    {
      "type": "select",
      "id": "desktop_image_width",
      "label": "t:sections.image_with_text.desktop_image_width",
      "options": [
        { "value": "small", "label": "t:sections.image_with_text.width_small" },
        { "value": "medium", "label": "t:sections.image_with_text.width_medium" },
        { "value": "large", "label": "t:sections.image_with_text.width_large" }
      ],
      "default": "medium"
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "t:sections.image_with_text.vertical_alignment",
      "options": [
        { "value": "top", "label": "t:sections.image_with_text.align_top" },
        { "value": "middle", "label": "t:sections.image_with_text.align_middle" },
        { "value": "bottom", "label": "t:sections.image_with_text.align_bottom" }
      ],
      "default": "middle"
    },
    {
      "type": "header",
      "content": "t:sections.image_with_text.content_header"
    },
    {
      "type": "text",
      "id": "label",
      "label": "t:sections.image_with_text.label"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "t:sections.image_with_text.heading",
      "default": "<p>Image with text</p>"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.image_with_text.heading_size",
      "options": [
        { "value": "h2", "label": "t:sections.image_with_text.heading_large" },
        { "value": "h3", "label": "t:sections.image_with_text.heading_medium" },
        { "value": "h4", "label": "t:sections.image_with_text.heading_small" }
      ],
      "default": "h2"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "t:sections.image_with_text.text"
    },
    {
      "type": "header",
      "content": "t:sections.image_with_text.button_header"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.image_with_text.button_label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.image_with_text.button_link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "t:sections.image_with_text.button_style",
      "options": [
        { "value": "primary", "label": "t:sections.image_with_text.button_primary" },
        { "value": "secondary", "label": "t:sections.image_with_text.button_secondary" },
        { "value": "outline", "label": "t:sections.image_with_text.button_outline" }
      ],
      "default": "primary"
    },
    {
      "type": "header",
      "content": "t:sections.image_with_text.style_header"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.image_with_text.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.image_with_text.padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.image_with_text.padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "t:sections.image_with_text.preset_name"
    }
  ]
}
{% endschema %}
